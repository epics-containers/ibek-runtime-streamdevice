record(ai, "$(P)$(Q):REF_SPEED")
{
    field(DESC, "Reference Speed")
    field(DTYP, "stream")
    field(SCAN, "1 second")
    field(EGU, "rpm")
    field(INP, "@celerotonChopper.proto getReferenceSpeed $(PORT)")
}

record(ao, "$(P)$(Q):REF_SPEED_SP")
{
    field(DESC, "Set Reference Speed")
    field(DTYP, "stream")

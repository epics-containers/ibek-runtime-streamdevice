}

record(ai, "$(P)$(Q):REF_SPEED:TWV") 
{
  field(VAL, "1")
  field(DRVH, "10000")
  field(DRVL, "0")
  field(PREC, "1")
  field(EGU, "rpm")
}

record(calcout, "$(P)$(Q):REF_SPEED:TWF") 
{
  field(INPA, "$(P)$(Q):REF_SPEED_SP NPP NMS")
  field(INPB, "$(P)$(Q):REF_SPEED:TWV NPP NMS")
  field(CALC, "A+B")
  field(OUT, "$(P)$(Q):REF_SPEED_SP PP")
}

record(calcout, "$(P)$(Q):REF_SPEED:TWR") 
{
  field(INPA, "$(P)$(Q):REF_SPEED_SP NPP NMS")
  field(INPB, "$(P)$(Q):REF_SPEED:TWV NPP NMS")
  field(CALC, "A-B")
  field(OUT, "$(P)$(Q):REF_SPEED_SP PP")
}


# % macro, P,      PV name prefix
# % macro, Q,      PV name suffix
# % macro, PORT,   asyn port

# % gui, $(name=), edm, celerotonChopper.edl, P=$(P),Q=$(Q)


# ==========================================================
# CONTROL SIGNALS (START/STOP)
# ==========================================================

record(bo, "$(P)$(Q):START")
{
    field(DESC, "Chopper start")
    field(DTYP, "stream")
    field(ZNAM, "0")
    field(ONAM, "1")
    field(OUT, "@celerotonChopper.proto start $(PORT)")
}

record(bo, "$(P)$(Q):STOP")
{
    field(DESC, "Chopper stop")
    field(DTYP, "stream")
    field(ZNAM, "0")
    field(ONAM, "1")
    field(OUT, "@celerotonChopper.proto stop $(PORT)")
}

record(ai, "$(P)$(Q):GET_STATUS")
{
    field(DESC, "Get Status")
    field(DTYP, "stream")
    field(SCAN, "1 second")
    field(INP, "@celerotonChopper.proto getStatus($(P)$(Q)) $(PORT)")
}

record(longin, "$(P)$(Q):ERROR_CODE_1")
{
    field(DESC, "Error Code 1")
    field(DTYP, "Soft Channel")
}

record(longin, "$(P)$(Q):ERROR_CODE_2")
{
    field(DESC, "Error Code 2")
    field(DTYP, "Soft Channel")
}

record(calc, "$(P)$(Q):ERROR_CODE")
{
    field(DESC, "Bitwise sum of both error codes")
    field(CALC, "A|B")
    field(SCAN, "1 second")
    field(INPA, "$(P)$(Q):ERROR_CODE_1")
    field(INPB, "$(P)$(Q):ERROR_CODE_2")
}


record(longin, "$(P)$(Q):WARNING_CODE")
{
    field(DESC, "Warning code")
    field(DTYP, "Soft Channel")
}

record(longin, "$(P)$(Q):INFO_CODE")
{
    field(DESC, "Info code")
    field(DTYP, "Soft Channel")
}


record(bo, "$(P)$(Q):ACK_ERRORS")
{
    field(DESC, "Acknowledge errors")
    field(DTYP, "stream")
    field(ZNAM, "0")
    field(ONAM, "1")
    field(OUT, "@celerotonChopper.proto ackErrors($(P)$(Q)) $(PORT)")
}




record(calc, "$(P)$(Q):IRATEMATCHES") {
  field(DESC, "True if readback for infuse rate matches setpoint")
  field(INPA, "$(P)$(Q):IRATE")
  field(INPB, "$(P)$(Q):IRATE:RBV PP")
  field(INPC, "$(P)$(Q):IRATEUNITS")
  field(INPD, "$(P)$(Q):IRATEUNITS:RBV PP")
  field(SCAN, "Passive")
  field(CALC, "(A=B)&&(C=D)")
  field(FLNK, "$(P)$(Q):INFUSEDISABLE")
}


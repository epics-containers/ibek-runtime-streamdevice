record(ao, "$(P)$(Q):POLLON") {
  field(DESC, "Set Polling")
  field(DTYP, "stream")
  field(OUT, "@harvardSyringe.proto setPollOn($(P)$(Q)) $(PORT)")
  field(SDIS, "$(P)$(Q):DISABLE")
  field(PINI, "YES")
}

record(bo, "$(P)$(Q):DISABLE") {
  field(DESC, "Disable comms")
  field(PINI, "YES")
  field(VAL, "$(DISABLE=1)")
  field(OMSL, "supervisory")
  field(ZNAM, "Enabled")
  field(ONAM, "Disabled")
  field(FLNK, "$(P)$(Q):ENABLEFANOUT")  
}

record(fanout, "$(P)$(Q):ENABLEFANOUT") {
  field(SELM, "All")
  field(LNK0, "$(P)$(Q):POLLON")

######################################################################################

######################################################################################
# Read ID string every 10s to check comms.

record(waveform, "$(P)$(Q):IDN:RBV") {
  field(DESC, "Agilent Device ID")
  field(DTYP, "stream")
  field(INP, "@agilent53220.proto read_string(*IDN) $(PORT)")
  field(SCAN, "10 second")
  field(PINI, "YES")
  field(FTVL, "CHAR")
  field(NELM, "256")
  field(SDIS, "$(P)$(Q):DISABLE")
}

#####################################################################################

record(bo, "$(P)$(Q):DISABLE") {
  field(DESC, "Disable comms")
  field(VAL, "1")
  field(OMSL, "supervisory")
  field(ZNAM, "Enabled")
  field(ONAM, "Disabled")
}

record(asyn, "$(P)$(Q):ASYN") {
  field(PORT, "$(PORT)")
  field(OEOS, "\n")
  field(IEOS, "\n")  
}


record (calcout, "$(P):$(R):power"){
	field(DESC, "consumed power")
	field(EGU, "W")
	field(INPA, "$(P):$(R):F:RET:STAT")
	field(INPB, "$(P):$(R):T:RET:STAT")
	field(INPC, "$(P):$(R):T:FWD:STAT")
	field(CALC, "(A*27.5*(B-C))")
        field(PREC, "2")
	field(SCAN, ".5 second")
}

record (calcout, "$(P):$(R):AP:status"){
        field(DTYP, "Soft Channel")
        field(INPA, "$(P):$(R):AP:CD:DISA:STAT PP MS")
        field(INPB, "$(P):$(R):AP:PU:DISA:STAT PP MS")
        field(INPC, "$(P):$(R):AP:RF:DISA:STAT PP MS")
        field(INPD, "$(P):$(R):AP:WU:DISA:STAT PP MS")
        field(INPE, "$(P):$(R):AP:MAN:DISA:STAT PP MS")
        field(CALC, "A|B|C|D|E")
        field(SCAN, ".5 second")
        field(OUT,  "$(P):$(R):AP:DISABLE PP MS") 
        field(OOPT, "On Change")
        field(DOPT, "Use CALC")
}

record (dfanout, "$(P):$(R):AP:DISABLE"){
	field(DESC, "disable APs")
	field(OUTA, "$(P):$(R):AP:CD:CTL.DISA")
        field(OUTB, "$(P):$(R):AP:PU:CTL.DISA")
        field(OUTC, "$(P):$(R):AP:RF:CTL.DISA")
        field(OUTD, "$(P):$(R):AP:WU:CTL.DISA")
	field(OUTE, "$(P):$(R):P:PV:PID:CTL.DISA")
        field(OUTF, "$(P):$(R):LN2:PUMP:CTL.DISA")
        field(OUTG, "$(P):$(R):VLV:DISABLE")
	field(FLNK, "$(P):$(R):VLV:DISABLE")
}

record (dfanout, "$(P):$(R):VLV:DISABLE"){
        field(DESC, "disable valves")
        field(OUTA, "$(P):$(R):V:PV:FILL:CTL.DISA")
        field(OUTB, "$(P):$(R):V:SC:FILL:CTL.DISA")
        field(OUTC, "$(P):$(R):V:PV:PR:CTL.DISA")
        field(OUTD, "$(P):$(R):V:FWD:CTL.DISA")
        field(OUTE, "$(P):$(R):V:RET:CTL.DISA")
        field(OUTF, "$(P):$(R):V:N2P:CTL.DISA")
	field(OUTG, "$(P):$(R):V:CL1:PR:CTL.DISA")
        field(OUTH, "$(P):$(R)::V:BYP:CTL.DISA")
}



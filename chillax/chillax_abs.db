
record (ai,"$(P):$(R):V:BYP:STAT"){
        field (DESC, "bypass valve status")
        field (EGU, "%")
        field (DTYP, "stream")
        field (INP, "@chillax.proto getai(16#4040,16#974A4,4,4) $(PORT)")
        field (SCAN, "1 second")
        field (HIGH, "1")
        field (LOW, "0")
        field (HSV, "NO_ALARM")
        field (LSV, "MAJOR")
}






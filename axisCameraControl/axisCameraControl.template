}

record(seq, "$(P):INITIALISE")
{
    field(SCAN, "2 second")
    field(SELM, "All")
    field(DOL1, "1")
    field(LNK1, "$(P):DISABLE PP")
    field(DOL2, "1")
    field(LNK2, "$(P):GETAUTOFOCUS PP")
    field(DOL3, "1")
    field(LNK3, "$(P):GETAUTOIRIS PP")
    field(DLY4, "2")
    field(DOL4, "1")
    field(LNK4, "$(P):INITIALISE2.PROC")
    field(DOL5, "1")
    field(LNK5, "$(P):INITIALISE.DISA")
}

record(seq, "$(P):INITIALISE2")
{
    field(SELM, "All")
    field(DOL1, "1")
    field(LNK1, "$(P):GETPAN PP")
    field(DOL2, "1")
    field(LNK2, "$(P):GETTILT PP")
    field(DOL3, "1")
    field(LNK3, "$(P):GETZOOM PP")
    field(DOL4, "1")
    field(LNK4, "$(P):GETFOCUS PP")
    field(DOL5, "1")
    field(LNK5, "$(P):GETIRIS PP")
    field(DLY6, "2")
    field(DOL6, "0")
    field(LNK6, "$(P):DISABLE PP")
}


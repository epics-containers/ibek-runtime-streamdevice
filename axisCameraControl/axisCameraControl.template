{
    field(DTYP, "stream")
    field(OUT,  "@ptz.proto autofocus() $(PORT) 0")
    field(ZNAM, "Off")
    field(ONAM, "On")
    field(SDIS, "$(P):DISABLE")
    field(FLNK, "$(P):GETFOCUS")
}


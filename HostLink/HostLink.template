
record(seq, "$(device):UPDATE") {
  field(DESC, "Update all passive PVs")
  
  field(DOL1, "1")
  field(DLY1, "0.0")
  field(LNK1, "$(device):CPUSTATUS.PROC")
  
  field(DOL2, "1")
  field(DLY2, "1.0")
  field(LNK2, "$(device):CYCLE.PROC")

  field(DOL3, "1")
  field(DLY3, "1.0")
  field(LNK3, "$(device):MULTI1.PROC")

  field(DOL4, "1")
  field(DLY4, "1.0")
  field(LNK4, "$(device):MULTI2.PROC")

  field(DOL5, "1")
  field(DLY5, "1.0")
  field(LNK5, "$(device):CLOCK.PROC")
}

record(bi, "$(device):STA") {
  field(INP, "$(device):CPUSTATUS MS")
  field(SCAN, "10 second")
}

################################################################################

record(calcout, "$(device):CPUSTATUS") {
  field(DTYP, "stream")
  field(OUT, "@HostlinkFINS.proto CPU_UNIT_STATUS_READ $(port)")
  field(FLNK, "$(device):STATUSFAN")
  field(CALC, "1")
  field(SCAN, "10 second")
   field(PINI, "YES")
}

record(fanout, "$(device):STATUSFAN") {
  field(LNK1, "$(device):MODE")
  field(LNK2, "$(device):FATAL")
  field(LNK3, "$(device):NONFATAL")
}

# 00 Program, 02 Monitor, 04 Run

record(mbbi, "$(device):MODE") {
  field(DTYP, "Raw Soft Channel")
  field(ZRVL, "0")
  field(TWVL, "2")
  field(FRVL, "4")
  field(ZRST, "Program")
  field(ZRSV, "MAJOR")
  field(TWST, "Monitor")
  field(TWSV, "NO_ALARM")
  field(FRST, "Run")
  field(FRSV, "MINOR")
  field(NOBT, "3")
  field(INP, "$(device):CPUSTATUS.A MS")
}


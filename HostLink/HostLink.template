record(calcout, "$(device):CYCLE") {
  field(DTYP, "stream")
  field(CALC, "0")
  field(OUT, "@HostlinkFINS.proto CYCLE_TIME_READ $(port)")
  field(FLNK, "$(device):CYCLEFAN")
}

record(fanout, "$(device):CYCLEFAN") {
  field(LNK1, "$(device):CYCLEMEAN")
  field(LNK2, "$(device):CYCLEMAX")
  field(LNK3, "$(device):CYCLEMIN")
}
 
record(calc, "$(device):CYCLEMEAN") {
  field(INPA, "$(device):CYCLE.A MS")
  field(CALC, "A * 0.1")
  field(PREC, "1")
  field(EGU, "ms")
}

record(calc, "$(device):CYCLEMAX") {
  field(INPA, "$(device):CYCLE.B MS")

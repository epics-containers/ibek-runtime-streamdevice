record(calcout, "$(device):CALCRAWPRESS")
{
    field(DESC, "Convert press to raw")
    field(DTYP, "stream")
    field(CALC, "0.6*(LOG(A)+12)*100000") # times 100000 makes it raw units from volts
    field(EGU,  "raw units")
    field(INPA, "$(device):SETPRESSURE MS") # What to read as INPA?
    field(FLNK, "$(device):WRITEPRESS")
    field(OUT,  "@$(proto=V590.proto) set_raw_press $(port)")
#   field(DOL,  "1e-11")
#   field(VAL,  "1e-11")
}

record(calc, "$(device):PRESSURE") # This is a readback/display record!
{
    field(DESC, "Convert Pressure")
    field(DTYP, "stream")
    field(CALC, "(10**(((A/100000)/0.6)-12))/0.750062")
    field(EGU,  "mbar")
    field(INPA, "$(device):RAWPRESSURE MS")
    field(FLNK, "$(device):VALVESPEED")
}


record(ai, "$(device):RAWPRESSURE") # This is a readback record but NOT for display
{
    field(DESC, "read current pressure")
    field(DTYP, "stream")
    field(INP,  "@$(proto=V590.proto) get_pressure $(port)")
    field(SCAN, "1 second")
    field(EGU,  "raw units") # to be converted to mbar/Torrs by $(device):CALCPRESSURE
    field(FLNK, "$(device):PRESSURE")
}

# Read current position and output in %
record(calc, "$(device):POSITION")
{
    field(DESC, "Convert read-in Pos to %")
    field(DTYP, "stream")
    field(CALC, "A/1000")

# VATLeakValve590series.template
# % macro, __doc__, Template database for VAT Variable Leak Valve 590 Series
# Famous Alele - 24/11/2025
#
# substitutions:
#% macro, device, device name
#% macro, name, Object name and gui association name
#% macro, port, asyn serial port number (e.g. ty_40_0)
#% macro, proto, name of protocol file, either V590.proto
#  records which do not explicitly state their protocols will use the protocol
#  provided by the macro substitution of 'protocol'

# These define what PVs a valve detail screen should contain
# Status:
# % gui, $(name=), readback, Operation Mode,            $(device):ACCESSMODE
# % gui, $(name=), readback, Control Mode,              $(device):CTRLMODE
# % gui, $(name=), readback, Warnings,                  $(device):WARNINGS
# % gui, $(name=), readback, Backup Battery,            $(device):POWERFAIL
# % gui, $(name=), readback, Compressed Air,            $(device):COMPAIR
# % gui, $(name=), readback, Current Valve Speed,       $(device):VALVESPEED
# % gui, $(name=), readback, Controller,                $(device):PRESSCTRLR
# % gui, $(name=), readback, Current Valve Pressure,    $(device):PRESSURE
# % gui, $(name=), readback, Current Valve Position,    $(device):POSITION
# % gui, $(name=), readback, Simulation Mode,           $(device):SIMULATION
# % gui, $(name=), readback, Service Needed Warning,    $(device):SERVICEWARN
# % gui, $(name=), readback, Backup Batt. Fail,         $(device):POWERFAIL
# % gui, $(name=), readback, Measurement Unit,          $(device):PRESSUNIT
# % gui, $(name=), readback, Fixed 2 Direction,         $(device):F2CTLRDIR
# % gui, $(name=), readback, Fixed 2 P-gain,            $(device):F2PGAIN
# % gui, $(name=), readback, Fixed 2 I-gain,            $(device):F2IGAIN
# % gui, $(name=), readback, Sensor Metric Unit,        $(device):UNIT
# % gui, $(name=), readback, Sensor Scaling Factor,     $(device):SCALE
# % gui, $(name=), readback, Sensor Exponent Value,     $(device):EXP
# % gui, $(name=), readback, Sensor Exponent Sign,      $(device):SIGN
# % gui, $(name=), readback, Target Pressure,           $(device):TARGETPRESSURE
# % gui, $(name=), readback, Pressure Reading Range     $(device):PRESSRANGE
# % gui, $(name=), readback, Position Movement Range    $(device):POSITIONRANGE
#
#
# Control:
# % gui, $(name=), demand,  Pressure,               $(device):SETPRESSURE
# % gui, $(name=), demand,  Position,               $(device):SETPOSITION
# % gui, $(name=), enum,    Pressure Controller,    $(device):SETPRESSCTRLR
# % gui, $(name=), command, Close valve,            $(device):CLOSE
# % gui, $(name=), enum,    Clear Warings,          $(device):CLEAR
# % gui, $(name=), demand,  Fixed 2 P-gain,         $(device):SETF2PGAIN
# % gui, $(name=), demand,  Fixed 2 I-gain,         $(device):SETF2IGAIN
# % gui, $(name=), demand,  Value to Inc./Dec. by,  $(device):SETINCDECVAL
# % gui, $(name=), demand,  Decrememnt Position,    $(device):BUTTONDECPOS
# % gui, $(name=), demand,  Incrememnt Position,    $(device):BUTTONINCPOS

# Config:
# % gui, $(name=), enum,    Access Mode,             $(device):SETACCESSMODE
# % gui, $(name=), demand,  Valve Speed,             $(device):SETVALVESPEED
# % gui, $(name=), demand,  Pressure Controller,     $(device):SETPRESSRANGE
# % gui, $(name=), demand,  Sensor Scale,            $(device):SETSCALE
# % gui, $(name=), enum,    Sensor Exponent,         $(device):SETEXP
# % gui, $(name=), enum,    Sensor Metric Unit,      $(device):SETUNIT
# % gui, $(name=), enum,    Sensor Exp. Sign,        $(device):SETSIGN
# % gui, $(name=), demand,  Position Limit,          $(device):SETPOSITIONLIMIT
# % gui, $(name=), demand,  Pressure Range,          $(device):SETPRESSRANGE
# % gui, $(name=), enum,    Position Range,          $(device):SETPOSITIONRANGE
# % gui, $(name=), enum,    Fixed 2 Direction,       $(device):SETF2CTLRDIRUP
#
# This associates an edm screen with the template
# % gui, $(name=), edm, VATLeakValve590Series.edl, device=$(device)
# % gui, $(name=), edm, VatValve590.edl, device=$(P)$(R)
# These define what PVs a valve detail screen should contain
# 



record(bo, "$(device):CLEAR")
{
    field(DESC, "Clear Warnings")
    field(DTYP, "stream")
    field(OUT,  "@$(proto=V590.proto) reset_warnings $(port)")
    field(ZNAM, "Clear Service Warnings")
    field(ONAM, "Clear Fatal Error")
}

record(bo, "$(device):CLOSE")
{
    field(DESC, "Close Valve")
    field(DTYP, "stream")
    field(OUT,  "@$(proto=V590.proto) close_command $(port)")
    field(ZNAM, "Close Valve")
    field(ONAM, "Close Valve")
    field(PINI, "YES")
}

record(mbbo, "$(device):SETACCESSMODE")
{
    field(DESC, "set access mode")
    field(DTYP, "stream")
    field(OUT,  "@$(proto=V590.proto) set_access_mode $(port)")
    field(ZRST, "Local Operation")
    field(ONST, "Remote Operation")
    field(TWST, "Locked Operation")
    field(DOL,  "0")
    field(OMSL, "supervisory")
    field(PINI, "YES")
    field(FLNK, "$(device):ACCESSMODE")
}

record (mbbi, "$(device):ACCESSMODE")
{
    field(DESC, "current access mode")
    field(PINI, "YES")
    field(DTYP, "stream")
    field(INP,  "@$(proto=V590.proto) DS_access_mode $(port)")
    field(ZRST, "Local Op.")
    field(ONST, "Remote Op.")
    field(TWST, "Locked Remote Op.")
    field(UNSV, "MAJOR")
    field(ZRSV, "NO_ALARM")
    field(ONSV, "NO_ALARM")
    field(THSV, "MINOR")
}

record(mbbi, "$(device):CTRLMODE")
{
    field(DESC, "Control Mode-See Manual Pg-44")
    field(PINI, "YES")
    field(DTYP, "stream")
    field(INP,  "@$(proto=V590.proto) DS_ctrl_mode $(port)")
    field(ZRST, "Unknown")
    field(ONST, "synchronization")
    field(TWST, "POSITION CONTROL")
    field(THST, "CLOSED")
    field(FRST, "OPEN")
    field(FVST, "PRESSURE CONTROL")
    field(SXST, "HOLD")
    field(SVST, "Manf. reserved")
    field(EIST, "INTERLOCK OPEN")
    field(NIST, "INTERLOCK CLOSED")
    field(TEST, "power failure")
    field(ELST, "safety mode")
    field(TVST, "fatal error")

    field(UNSV, "MAJOR")
    field(ONSV, "NO_ALARM")
    field(TWSV, "NO_ALARM")
    field(THSV, "NO_ALARM")
    field(FRSV, "NO_ALARM")
    field(FVSV, "NO_ALARM")
    field(SXSV, "NO_ALARM")
    field(SVSV, "MAJOR")
    field(EISV, "NO_ALARM")
    field(NISV, "NO_ALARM")
    field(TESV, "MAJOR")
    field(ELSV, "MINOR")
    field(TVSV, "MAJOR")
    field(SCAN, "1 second")
    field(FLNK, "$(device):ACCESSMODE")
}


  field(INPH, "$(P):PUCK_33_BYTES_2.C")
  field(INPI, "$(P):PUCK_33_BYTES_2.D")
  field(FTA,  "LONG")
  field(FTB,  "LONG")
  field(FTC,  "LONG")
  field(FTD,  "LONG")
  field(FTE,  "LONG")
  field(FTF,  "LONG")
  field(FTG,  "LONG")
  field(FTH,  "LONG")

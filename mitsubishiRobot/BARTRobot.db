########## Monitoring For New Lid Data at PLC ##########

# Monitoring for new lid data signal at PLC
# When received, trigger data fetch process

record(calcout, "$(P):NEW_LID")
{
  field(DESC, "Detect New Lid Data at PLC")
  field(INPA, "$(P):LID_BITS.B2 CP")
  field(CALC, "A")
  field(OOPT, "Transition To Non-zero")
  # Trigger data fetch when bit goes high
  field(OUT,  "$(P):NEW_LID_FAN PP")
}

record(fanout, "$(P):NEW_LID_FAN")
{
  field(DESC, "Get All Lid Data")
  field(SELM, "All")
  field(LNK1, "$(P):CAM_RATIO:GET")
  field(LNK2, "$(P):X_OFFSET:GET")
  field(LNK3, "$(P):Y_OFFSET:GET")
  field(LNK4, "$(P):DISTANCE:GET")
  field(LNK5, "$(P):SUCCESS:GET")
  field(LNK6, "$(P):CORRELATION:GET")
}

########## Monitoring For Lid Data Match at PLC ##########

# Monitoring for lid data match at PLC
# When received, write data to robot,
# read it back, and confirm correct,
# send confirmation to PLC

record(calcout, "$(P):LID_MATCH")
{
  field(DESC, "Detect Lid Match at PLC")
  field(INPA, "$(P):LID_BITS.B3 CP")
  field(CALC, "A")
  field(OOPT, "Transition To Non-zero")
  field(OUT,  "$(P):WRITE_DATA_SEQ PP")
}

record(seq, "$(P):WRITE_DATA_SEQ")
{
  field(DESC, "Write Offsets to Robot")
  field(DOL1, "$(P):X_OFFSET")
  field(LNK1, "$(P):SET_X_OFFSET PP")
  field(DOL2, "$(P):Y_OFFSET")
  field(LNK2, "$(P):SET_Y_OFFSET PP")
}

record(ao, "$(P):SET_X_OFFSET")
{
  field(DESC, "Write X Offset to Robot")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto writeVariable($(P),M_LIDX) $(STREAMS_PORT,undefined)")
}

record(ao, "$(P):SET_Y_OFFSET")
{
  field(DESC, "Write Y Offset to Robot")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto writeVariable($(P),M_LIDY) $(STREAMS_PORT,undefined)")
  field(FLNK, "$(P):CHECK_X_OFFSET")
}

record(ai, "$(P):CHECK_X_OFFSET")
{
  field(DESC, "Check X Offset Written")
  field(DTYP, "stream")
  field(INP,  "@robotPLC.proto readVariable(M_LIDX) $(STREAMS_PORT,undefined)")
  field(FLNK, "$(P):CHECK_Y_OFFSET")
  field(MDEL, "-1")
}

record(ai, "$(P):CHECK_Y_OFFSET")
{
  field(DESC, "Check Y Offset Written")
  field(DTYP, "stream")
  field(INP,  "@robotPLC.proto readVariable(M_LIDY) $(STREAMS_PORT,undefined)")
  field(FLNK, "$(P):CONFIRM_OFFSETS")
  field(MDEL, "-1")
}

record(calcout, "$(P):CONFIRM_OFFSETS")
{
  field(DESC, "Confirm Data Written to Robot")
  field(INPA, "$(P):CHECK_X_OFFSET")
  field(INPB, "$(P):X_OFFSET")
  field(INPC, "$(P):CHECK_Y_OFFSET")
  field(INPD, "$(P):Y_OFFSET")
  field(CALC, "((((A-B)^2) + ((C-D)^2))<0.1)?0:1")
  field(OOPT, "When Zero")
  field(DOPT, "Use OCAL")
  field(OCAL, "1")
  field(OUT,  "$(P):LID_WRITTEN.PROC PP")
}

record(calcout, "$(P):LID_WRITTEN")
{
  field(INPA, "$(P):LID_STATUS")
  field(CALC, "(A XOR 16)")
  field(OUT,  "$(P):LID_OK PP")
}

########## Vision System PLC Reset Triggers ##########

# If the PLC routine gets interupted part way through
# its process, its state can be reset ready for next run

record(bo, "$(P):RESET_LID")
{
  field(DESC, "Reset Lid PLC")
}

record(calcout, "$(P):SEND_LID_RESET")
{
  field(DESC, "Set Bit 5 on PLC to Reset")
  field(INPA, "$(P):RESET_LID CP")
  field(CALC, "32")
  field(OUT,  "$(P):LID_OK PP")
}

record(bo, "$(P):RESET_BARCODE")
{
  field(DESC, "Reset Barcode PLC")
}

record(calcout, "$(P):SEND_BARCODE_RESET")
{
  field(DESC, "Set Bit 5 on PLC to Reset")
  field(INPA, "$(P):RESET_BARCODE CP")
  field(CALC, "32")
  field(OUT,  "$(P):BARCODE_OK PP")
}

record(bo, "$(P):SOFT_REBOOT_VISION")
{
  field(DESC, "Soft Reboot Vision System")
}

record(bo, "$(P):HARD_REBOOT_VISION")
{
  field(DESC, "Hard Reboot Vision System")
}

# A soft reboot requires a 1 to be sent to
# REBOOT_OMRON, and a hard reboot requires a 2
# These both come from the GUI which resets the 
# value back to 0 upon button release to stop
# constant reboots.  This is why the calc values
# are A rather than values
record(calcout, "$(P):SEND_SOFT_REBOOT")
{
  field(DESC, "Send Soft Reset Bit to Omron")
  field(INPA, "$(P):SOFT_REBOOT_VISION CP")
  field(CALC, "A")
  field(OUT,  "$(P):REBOOT_OMRON PP")
}

record(calcout, "$(P):SEND_HARD_REBOOT")
{
  field(DESC, "Send Hard Reset Bit to Omron")
  field(INPA, "$(P):HARD_REBOOT_VISION CP")
  field(CALC, "A")
  field(OUT,  "$(P):REBOOT_OMRON PP")
}


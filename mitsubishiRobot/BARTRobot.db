# Corresponding edm screen: HeaterSettings.edl

################# Gripper Temperature #################

record(subArray, "$(P):GRIPPER_TEMP_10")
{
  field(DESC, "Gripper Temperature")
  field(DTYP, "Soft Channel")
  field(FTVL, "FLOAT")
  field(INP,  "$(P):DM181XX CP MS")
  field(MALM, "100")
  field(NELM, "1")
  field(INDX, "2")
}

#% archiver 1 Monitor
record(calcout, "$(P):GRIPPER_TEMP")
{
  field(DESC, "Divide Temperature by 10")
  field(INPA, "$(P):GRIPPER_TEMP_10 CP MS")
  field(CALC, "A/10")
  field(PREC, "1")
}

# This check is independent of the PLC gripper
# temperature check (ie Over temperature) and
# is used to pick up on a failure of the sensor
# (When the sensor fails the temperature is read
# at > 1000K)
# This record will check if the gripper is over a
# nominal value of 350K.  If so, it will latch
# GRIPPER_TEMP_WARNING which displays a 'Gripper Temp
# Too High!' text message on UserGUI. GRIPPER_TEMP_WARNING
# can only be set back to zero by RESET_GRIPPER_TEMP_WARNING
# monitoring the RESET button which lives under
# ControllerState.template
# This record uses scan so that the condition is
# still raised after a reset if the temperature is
# still too high, but the value isn't changing
# (ie a condition that won't be picked up by CP)
record(calcout, "$(P):GRIPPER_TEMP_CHECK")
{
  field(DESC, "Check Gripper Temperature")
  field(INPA, "$(P):GRIPPER_TEMP CP")
  field(CALC, "(A>350)?1:0")
  field(OOPT, "When Non-zero")
  field(DOPT, "Use CALC")
  field(OUT,  "$(P):GRIPPER_TEMP_WARNING PP")
  field(SCAN, "2 second")
}

record(bi, "$(P):GRIPPER_TEMP_WARNING")
{
  field(DESC, "Gripper Temperature Warning")
  field(ZNAM, "Gripper Temp Not Too High")
  field(ONAM, "Gripper Temp Too High")
  field(VAL,  "0")
}

# Monitoring a press of the reset button
# (the RESET PV is processed) and passing
# on its value of 0 to reset the temperature
# warning latch
record(calcout, "$(P):RESET_GRIPPER_TEMP_WARNING")
{
  field(DESC, "Reset Gripper Temp Warning")
  field(INPA, "$(P):RESET CP")
  field(CALC, "A")
  field(OOPT, "Every Time")
  field(OUT,  "$(P):GRIPPER_TEMP_WARNING PP")
}

record(bi, "$(P):GRIPPER_UNDER_TEMP")
{
  field(DESC, "Gripper Under Temperature Indicator")
  field(INP,  "$(P):ROBOT_IP_0_BITS.BA CP")
  field(ZNAM, "Gripper Temp Not Too Low")
  field(ONAM, "Gripper Temp Too Low")
}

record(bi, "$(P):GRIPPER_OVER_TEMP")
{
  field(DESC, "Gripper Over Temperature Indicator")
  field(INP,  "$(P):ROBOT_IP_0_BITS.BB CP")
  field(ZNAM, "Gripper Temp Not Too High")
  field(ONAM, "Gripper Temp Too High")
}


  field(INDX, "4")
}

record(mbbiDirect, "$(P):PIN_DETECTION_BITS")
{
  field(DESC, "Pin Detection Status in Bits")
  field(DTYP, "Soft Channel")
  field(INP,  "$(P):PIN_DETECTION_STATUS CP")
}


# Corresponding edm screen: VisionSystem.edl

################## Barcode PLC Status ######################

# Read the status of the barcode PLC and 
# translate into individual bits

record(subArray, "$(P):BARCODE_STATUS")
{
  field(DESC, "Barcode PLC State")
  field(DTYP, "Soft Channel")
  field(FTVL, "SHORT")
  field(INP,  "$(P):DM5XX CP MS")
  field(MALM, "100")
  field(NELM, "1")
  field(INDX, "90")
}

record(mbbiDirect, "$(P):BARCODE_BITS")
{
  field(DESC, "Barcode Status in Bits")
  field(DTYP, "Soft Channel")
  field(INP,  "$(P):BARCODE_STATUS CP")
  field(NOBT, "8")
}

############## Barcode PLC Sequence Progress ############

# Monitor where the barcode PLC has got
# to in its sequence of checks, and break
# down into individual bits

record(subArray, "$(P):CODE_PROGRESS")
{
  field(DESC, "Barcode PLC Progress")
  field(DTYP, "Soft Channel")
  field(FTVL, "SHORT")
  field(INP,  "$(P):DM5XX CP MS")
  field(MALM, "100")
  field(NELM, "1")
  field(INDX, "95")
}

record(mbbiDirect, "$(P):CODE_PROGRESS_BITS")
{
  field(DESC, "Barcode Progress in Bits")
  field(DTYP, "Soft Channel")
  field(INP,  "$(P):CODE_PROGRESS CP")
  field(NOBT, "8")
}

########## Monitoring For New Barcode Data at PLC ##########

# Monitoring for new barcode signal at PLC
# When received, trigger data fetch process

record(calcout, "$(P):NEW_CODE")
{
  field(DESC, "Detect New Barcode at PLC")
  field(INPA, "$(P):BARCODE_BITS.B2 CP")
  field(CALC, "A")
  field(OOPT, "Transition To Non-zero")
  # Trigger data fetch when bit goes high
  field(OUT,  "$(P):NEW_CODE_FAN_1 PP")
}

record(fanout, "$(P):NEW_CODE_FAN_1")
{
  field(DESC, "Fetch First 6 Bytes")
  field(SELM, "All")
  field(LNK1, "$(P):BARCODE_BYTE_0:GET")
  field(LNK2, "$(P):BARCODE_BYTE_1:GET")
  field(LNK3, "$(P):BARCODE_BYTE_2:GET")
  field(LNK4, "$(P):BARCODE_BYTE_3:GET")
  field(LNK5, "$(P):BARCODE_BYTE_4:GET")
  field(LNK6, "$(P):BARCODE_BYTE_5:GET")
  field(FLNK, "$(P):NEW_CODE_FAN_2 PP")
}

record(fanout, "$(P):NEW_CODE_FAN_2")
{
  field(DESC, "Fetch Last 4 Bytes")
  field(SELM, "All")
  field(LNK1, "$(P):BARCODE_BYTE_6:GET")
  field(LNK2, "$(P):BARCODE_BYTE_7:GET")
  field(LNK3, "$(P):BARCODE_BYTE_8:GET")
  field(LNK4, "$(P):BARCODE_BYTE_9:GET")
}

########## Monitoring For Barcode Match at PLC ##########

# Monitoring for barcode data match at PLC
# When received, trigger byte to string translation

record(calcout, "$(P):CODE_MATCH")
{
  field(DESC, "Detect Barcode Match at PLC")
  field(INPA, "$(P):BARCODE_BITS.B3 CP")
  field(CALC, "A")
  field(OOPT, "Transition To Non-zero")
  # Trigger data translation when bit goes high
  field(OUT,  "$(P):GET_BARCODE.PROC PP")
}

# Record takes in up to ten barcode data bytes
# (Each byte can hold 2 ASCII characters of the
# barcode string) and returns a string of the
# complete barcode.  Triggers a acknowledgement
# to the PLC once a barcode has been translated

record(genSub, "$(P):GET_BARCODE")
{
  field(DESC, "Translate Bytes to Barcode")
  field(SNAM, "DecToAsc")
  field(INPA, "$(P):BARCODE_BYTE_0")
  field(INPB, "$(P):BARCODE_BYTE_1")
  field(INPC, "$(P):BARCODE_BYTE_2")
  field(INPD, "$(P):BARCODE_BYTE_3")
  field(INPE, "$(P):BARCODE_BYTE_4")
  field(INPF, "$(P):BARCODE_BYTE_5")
  field(INPG, "$(P):BARCODE_BYTE_6")
  field(INPH, "$(P):BARCODE_BYTE_7")
  field(INPI, "$(P):BARCODE_BYTE_8")
  field(INPJ, "$(P):BARCODE_BYTE_9")
  field(FTA,  "LONG")
  field(FTB,  "LONG")
  field(FTC,  "LONG")
  field(FTD,  "LONG")
  field(FTE,  "LONG")
  field(FTF,  "LONG")
  field(FTG,  "LONG")
  field(FTH,  "LONG")
  field(FTI,  "LONG")
  field(FTJ,  "LONG")
  field(FTVA, "STRING")
  field(OUTA, "$(P):BARCODE PP")
  field(FLNK, "$(P):BARCODE_WRITTEN")
}

# Display the translated barcode string
# and send confirmation of translation to PLC

record(waveform, "$(P):BARCODE")
{
  field(DESC, "Barcode Result")
  field(NELM, "1")
  field(FTVL, "STRING")
}

record(calcout, "$(P):BARCODE_WRITTEN")
{
  field(DESC, "Send Confirmation to PLC")
  field(INPA, "$(P):BARCODE_STATUS")
  field(CALC, "(A XOR 16)")
  field(OUT,  "$(P):BARCODE_OK PP")
}

# Clear the barcode upon starting a Load
record(stringout, "$(P):CLEAR_BARCODE")
{
  field(DESC, "Clear the Barcode")
  field(VAL,  "")
  field(OUT,  "$(P):BARCODE PP")
}

################## Puck PLC Status ######################

record(waveform, "$(P):READ_400")
{
  field(DESC, "Read 400 words starting at 2000")
  field(DTYP, "asynInt16ArrayIn")
  field(INP,  "@asyn($(PORT,undefined), 2000, 0) FINS_DM_READ")
  field(NELM, "400")
  field(FTVL, "USHORT")
  field(PRIO, "MEDIUM")
  field(PINI, "YES")
}

# Read the status of the puck PLC and 
# translate into individual bits
record(subArray, "$(P):PUCK_STATUS2")
{
  field(DESC, "Barcode PLC State")
  field(DTYP, "Soft Channel")
  field(FTVL, "SHORT")
  field(INP,  "$(P):DM6XX CP MS")
  field(MALM, "100")
  field(NELM, "1")
  field(INDX, "0")
}

record(mbbiDirect, "$(P):PUCK_BITS2")
{
  field(DESC, "Barcode Status in Bits")
  field(DTYP, "Soft Channel")
  field(INP,  "$(P):PUCK_STATUS2 CP")
  field(NOBT, "8")
}

record(subArray, "$(P):PUCK_STATUS")
{
  field(DESC, "Puck PLC State")
  field(DTYP, "Soft Channel")
  field(FTVL, "SHORT")
  field(INP,  "$(P):DM23XX CP MS")
  field(MALM, "100")
  field(NELM, "1")
  field(INDX, "99")
}

record(mbbiDirect, "$(P):PUCK_BITS")
{
  field(DESC, "Puck Status in Bits")
  field(DTYP, "Soft Channel")
  field(INP,  "$(P):PUCK_STATUS CP")
  field(NOBT, "8")
}

############## Puck PLC Sequence Progress ############

# Monitor where the puck PLC has got
# to in its sequence of checks, and break
# down into individual bits


record(subArray, "$(P):PUCK_PROGRESS")
{
  field(DESC, "Puck PLC Progress")
  field(DTYP, "Soft Channel")
  field(FTVL, "SHORT")
  field(INP,  "$(P):DM6XX CP MS")
  field(MALM, "100")
  field(NELM, "1")
  field(INDX, "5")
}

record(mbbiDirect, "$(P):PUCK_PROGRESS_BITS")
{
  field(DESC, "Puck Progress in Bits")
  field(DTYP, "Soft Channel")
  field(INP,  "$(P):PUCK_PROGRESS CP")
  field(NOBT, "8")
}

########## Monitoring For New Puck Data at PLC ##########

# Monitoring for new puck signal at PLC
# When received, trigger data fetch process

record(calcout, "$(P):NEW_PUCK")
{
  field(DESC, "Detect New Puck at PLC")
  field(INPA, "$(P):PUCK_BITS2.B2 CP")
  field(CALC, "A")
  field(OOPT, "Transition To Non-zero")
  # Trigger data fetch when bit goes high
  field(OUT,  "$(P):READ_400.PROC PP")
}

# When new data is read in, pull out the 39th word
# which contains the number of the last modified position
# Also trigger the sending of a confirmation bit
record(acalcout, "$(P):PUCK_POSITION")
{
  field(DESC, "Last Modified Puck Position")
  field(NELM, "400")
  field(NUSE, "400")
  field(INAA, "$(P):READ_400.VAL CP MS")
  field(CALC, "a:=aa[390,390];1")
  field(FLNK, "$(P):SEND_LOAD_CONFIRM")
  field(MDEL, "-1")
}

# Write a 1 to the PLC to confirm that a non-zero
# puck position was received 
record(calcout, "$(P):SEND_LOAD_CONFIRM")
{
  field(DESC, "Set Load Confirmation Bit")
  field(INPA, "$(P):PUCK_POSITION")
  field(CALC, "A")
  field(OOPT, "When Non-zero")
  field(OUT,  "$(P):CONFIRM_PUCK PP")
  field(DOPT, "Use OCAL")
  field(OCAL, "1")
}

# Button for clearing all puck IDs
# Stays high for 1 second to avoid race conditions
record(bo, "$(P):CLEAR_ALL_PUCKS")
{
  field(DESC, "Clear All Puck Names")
  field(HIGH, "1")
}

# When clear all pucks button is pressed,
# write to clear pucks bit on PLC, then trigger 
# a re-read of puck data to refresh the GUI
record(calcout, "$(P):SEND_CLEAR_ALL_PUCKS")
{
  field(DESC, "Send Clear All Pucks to PLC")
  field(INPA, "$(P):PUCK_STATUS")
  field(INPB, "$(P):PUCK_BITS.B4")
  field(INPC, "$(P):CLEAR_ALL_PUCKS CP")
  field(CALC, "(A XOR ((B XOR C) * 16))")
  field(OUT,  "$(P):WRITE_PUCKS PP")
  field(FLNK, "$(P):READ_400")
}


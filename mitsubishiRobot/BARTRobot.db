{
  field(DESC, "Cryo PLC Fault subArray")
  field(DTYP, "Soft Channel")
  field(FTVL, "FLOAT")
  field(INP,  "$(P):DM0XX CP MS")
  field(MALM, "100")
  field(NELM, "1")
  field(INDX, "69")
}

# this PV updates at approximately 2 Hz, so archiver buffer set for data once every half a second
#% archiver 0.5 Monitor
record(ai, "$(P):CRYO_FAULT_STATUS:AI")
{
  field(DESC, "Cryo PLC Fault Status")
  field(INP,  "$(P):CRYO_FAULT_STATUS.VAL CP")
}

# SMS Alarms are triggered by any fault bits 
# or on auto fill time out condition
# or on LN2 goes below level 2 when on autofill mode

#% alh $SEVRCOMMAND UP_ANY dls-alh-handler.py $(P):CRYO_ALARM
#% alh $SEVRCOMMAND UP_ANY dls-sendsms-alarm.py $(P):CRYO_ALARM
record(calcout, "$(P):CRYO_ALARM")
{
  field(DESC, "Cryo Alarm State")
  field(INPA, "$(P):CRYO_FAULT_STATUS:AI CP")
  field(INPB, "$(P):CRYO_BITS.B8 CP")
  field(INPC, "$(P):CRYO_BITS.BA CP")
  field(CALC, "(A+B+C)>0?1:0")
  field(HSV,  "MAJOR")
  field(HIGH, "1")
}

###################### Cryo / Warm Mode Control #####################

# Choose between cryo mode or warm mode
# The values are offset to make them work 
# with the following seq record

# Set to start in Warm Mode upon IOC start

# We want this button to always process
# (ie if same selection made again, still
# act on it).  This would normally be done
# by setting MDEL to -1 but the mbbo record
# doesn't have an MDEL field.  So instead
# it FLNKs to CRYO_MODE_SEL which has a PP 
# on its SELL field to pull in (and process)
# the CRYO_MODE_CTRL selection

record(mbbo, "$(P):CRYO_MODE_CTRL")
{
  field(DESC, "Toggle Cryo Mode")
  field(ZRST, "Warm Mode")
  field(ONST, "Cryo Mode")
  field(ZRVL, "1")
  field(ONVL, "2") 
  field(VAL,  "0")
  field(PINI, "YES")
  field(FLNK, "$(P):CRYO_MODE_SEL")
}

record(seq, "$(P):CRYO_MODE_SEL")
{
  field(DESC, "Mode Settings Selection")
  field(SELM, "Specified")
  field(SELL, "$(P):CRYO_MODE_CTRL.RVAL PP")
  field(DOL1, "1")
  field(LNK1, "$(P):WARM_MODE_SEQ.PROC CA")
  field(DOL2, "1")
  field(LNK2, "$(P):CRYO_MODE_SEQ.PROC CA")
}

# Warm Mode:
#
# Auto Fill Disabled
# Warm Mode Set on Robot

record(sseq, "$(P):WARM_MODE_SEQ")
{
  field(DESC, "Warm Mode Settings")
  field(DOL1, "1")
  field(LNK1, "$(P):STOP_AUTO_FILL CA") 
  field(DOL2, "0")
  field(LNK2, "$(P):CRYO_MODE CA")
}

# Cryo Mode:
#
# Auto Fill Enabled
# Cryo Mode Set on Robot

record(sseq, "$(P):CRYO_MODE_SEQ")
{
  field(DESC, "Cryo Mode Settings")
  field(DOL1, "1")
  field(LNK1, "$(P):AUTO_FILL CA")
  field(DOL2, "1")
  field(LNK2, "$(P):CRYO_MODE CA")
}

# Set mode on robot so it can choose 
# appropriate soak and dry times
record(ao, "$(P):CRYO_MODE")
{
  field(DESC, "Set Cryo Mode on Robot")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto writeVariable($(P),M_LN2) $(STREAMS_PORT,undefined)")
  field(DRVH, "1")
  field(DRVL, "0")
}

record(ai, "$(P):CRYO_MODE_RBV")
{
  field(DESC, "Mode Readback from Robot")
  field(DTYP, "stream")
  field(SCAN, "1 second")
  field(INP,  "@robotPLC.proto readVariable(M_LN2) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):VARS_POLL.RVAL CP")
}

###################### Fill Controls ##################

# Auto Fill is disabled upon IOC startup
# This is only a momentary pulse so the
# HIGH field is used to keep it on for 1 sec

record(bo, "$(P):AUTO_FILL")
{
  field(DESC, "Auto Fill Toggle")
  field(HIGH, "1")
}

# Auto Fill enable is set by the first
# bit of D51. Pulsing this bit high enables
# auto fill (disabling is done by a different
# bit and corresponding record)

record(calcout, "$(P):AUTO_CALC")
{
  field(DESC, "Enable / Disable Auto Fill")
  field(INPA, "$(P):AUTO_FILL CP")
  field(CALC, "(A=1)?1:0")
  field(OUT,  "$(P):DEWAR_FILL PP")
}

# This is only a momentary pulse so the
# HIGH field is used to keep it on for 1 sec

# % alh $SEVRCOMMAND UP_ANY dls-alh-handler.py $(P):STOP_AUTO_FILL
# % alh $SEVRCOMMAND UP_ANY dls-sendsms-alarm.py $(P):STOP_AUTO_FILL
record(bo, "$(P):STOP_AUTO_FILL")
{
  field(DESC, "Stop Auto Fill")
  field(HIGH, "1")
  # OSV field so that record goes into alarm 
  # state when triggered (ie when record = 1)
  field(OSV,  "MAJOR")
}

# Disabling Auto Fill is set by the second
# bit of D51. Pulsing this bit high disables
# auto fill (enabling is done by a different
# bit and corresponding record)

record(calcout, "$(P):STOP_AUTO_CALC")
{
  field(DESC, "Enable / Disable Auto Fill")
  field(INPA, "$(P):STOP_AUTO_FILL CP")
  field(CALC, "(A=1)?2:0")
  field(OUT,  "$(P):DEWAR_FILL PP")
}

# Manual control of fill
# Fills whilst button held down
record(bo, "$(P):FILL")
{
  field(DESC, "Manual Fill Toggle")
}

# Using XORs to ensure that bits are not
# overwritten when manual fill is engaged
# Behaviour can become reversed if ignored
record(calcout, "$(P):CRYO_CALC")
{
  field(DESC, "Set Bits for Manual Fill")
  field(INPA, "$(P):CRYO_FILL_STATUS")
  field(INPB, "$(P):CRYO_FILL_BITS.B2")
  field(INPC, "$(P):FILL CP")
  field(CALC, "(A XOR ((B XOR C) * 4))")
  field(OUT,  "$(P):DEWAR_FILL PP")
}


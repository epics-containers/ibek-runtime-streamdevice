  field(INPA, "$(P):CRYO_FILL_STATUS")
  field(INPB, "$(P):CRYO_FILL_BITS.B3")
  field(INPC, "$(P):SENSOR_FAULT_RESET CP")
  field(CALC, "(A XOR ((B XOR C) * 8))")
  field(OUT,  "$(P):DEWAR_FILL PP")
}




# Corresponding edm screen: VisionDebug.edl

#######################################################

# Template to read barcode data byte off of the PLC
# then send it straight back to the PLC for verification

# Read single bytes of barcode data
# 10 bytes are read in total, each 
# can contain 2 barcode characters
# Once all 10 are collected, they are
# glued together and translated as a string

record(subArray, "$(P):BARCODE_BYTE_0:GET")
{
  field(DESC, "Get Byte 0")
  field(DTYP, "Soft Channel")
  field(FTVL, "SHORT")
  field(INP,  "$(P):DM5XX PP MS")
  field(MALM, "100")
  field(NELM, "1")
  field(INDX, "50")
}

record(ai, "$(P):BARCODE_BYTE_0")
{
  field(DESC, "Byte 0 of Barcode")
  field(INP,  "$(P):BARCODE_BYTE_0:GET CP MS")
  field(PREC, "0")
  field(MDEL, "-1")
}

# Whenever data is received (whether different
# than before or not), send it straight back
# to the PLC to be verified

record(calcout, "$(P):BYTE_0_ACK")
{
  field(DESC, "Return Byte 0 to Confirm on PLC")
  field(INPA, "$(P):BARCODE_BYTE_0 CP")
  field(CALC, "A")
  field(OUT,  "$(P):W_BARCODE_BYTE_0 PP")
  field(OOPT, "Every Time")
}



# Corresponding edm screen: VisionDebug.edl


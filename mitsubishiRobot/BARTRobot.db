# Corresponding edm screen: Overrides.edl

###################### Inputs #######################

# The user selects whether they want to force
# a bit on or off, or not at all

# The option values are offset so they can
# work with a dfanout record

record(mbbo, "$(P):IP_0_FORCE_OPTION")
{
  field(DESC, "Force Option Output Bit 0")
  field(ZRVL, "1")
  field(ONVL, "2")
  field(TWVL, "3")
  field(ZRST, "On")
  field(ONST, "No")
  field(TWST, "Off")
  field(VAL,  "1")
  field(PINI, "YES")
}

# This choice is sent to the appropriate force bit

record(dfanout, "$(P):IP_0_FORCE_SEL")
{
  field(DESC, "Force On/Off Selection")
  field(SELM, "Specified")
  field(SELL, "$(P):IP_0_FORCE_OPTION.RVAL CP")
  field(VAL,  "1")
  field(OUTA, "$(P):IP_0_FORCE_ON CA")
  field(OUTB, "$(P):IP_0_NORMAL_FAN.PROC CA")
  field(OUTC, "$(P):IP_0_FORCE_OFF CA")
}

# If no force is selected, the zero is sent to
# both the force on and force off bits to reset them

record(dfanout, "$(P):IP_0_NORMAL_FAN")
{
  field(DESC, "Unforce Output Bit 0")
  field(SELM, "All")
  field(VAL,  "0")
  field(OUTA, "$(P):IP_0_FORCE_ON CA")
  field(OUTB, "$(P):IP_0_FORCE_OFF CA")  
}

# The appropriate decimal value is set for each bit
# and the sum of all bits is triggered, to send
# the forced bits of the whole port together

record(mbbo, "$(P):IP_0_FORCE_ON")
{
  field(DESC, "Force On Output Bit 0")
  field(ZRVL, "0")

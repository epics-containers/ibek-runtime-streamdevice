# Corresponding edm screen: Advanced.edl

####################### Control ########################

record(stringout, "$(P):FREE_CMD")
{
  field(DESC, "Free Command Line")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto freeCommand($(P)) $(STREAMS_PORT,undefined)")
}

record(waveform, "$(P):CMD_RESPONSE")
{
  field(DESC, "Response from Free Command")
  field(NELM, "1")
  field(FTVL, "STRING")
}

record(ao, "$(P):OVERRIDE")
{
  field(DESC, "Override Speed")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto writeOverride($(P)) $(STREAMS_PORT,undefined)")
  field(DRVH, "100")
  field(DRVL, "0")
}

# No scanning on this record as values are
# pushed in from the result of a (polled)
# GET_STATE command in ControllerState.template

record(ai, "$(P):OVERRIDE_RBV")
{
  field(DESC, "Present Override Value")
  field(EGU,  "%")
}

record(ao, "$(P):CONTROL_ON")
{ 
  field(DESC, "Turn Control On")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto controlOn($(P)) $(STREAMS_PORT,undefined)")
}

record(ao, "$(P):OPEN_GRIPPER")
{ 
  field(DESC, "Open Gripper")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto openGripper($(P)) $(STREAMS_PORT,undefined)")
}

record(ao, "$(P):CLOSE_GRIPPER")
{ 
  field(DESC, "Close Gripper")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto closeGripper($(P)) $(STREAMS_PORT,undefined)")
}

record(ai, "$(P):REBOOT")
{
  field(DESC, "Reboot the Robot Controller")
  field(DTYP, "stream")
  field(INP,  "@robotPLC.proto rebootController($(P)) $(STREAMS_PORT,undefined)")
  field(MDEL, "-1")
  field(FLNK, "$(P):REBOOT_MSG")
}

record(stringout, "$(P):REBOOT_MSG")
{
  field(DESC, "Reboot Message")
  field(VAL,  "System Rebooted")
  field(OUT,  "$(P):LOGGING.D PP")
} 

#################### Polling ###################

record(bo, "$(P):STATUS_POLL")
{
  field(DESC, "Control Status Polling")
  field(DTYP, "Soft Channel")
  field(ZNAM, "Enabled")
  field(ONAM, "Disabled")
}

record(bo, "$(P):IO_POLL")
{
  field(DESC, "Control I/O Polling")
  field(DTYP, "Soft Channel")
  field(ZNAM, "Enabled")
  field(ONAM, "Disabled")
}

record(bo, "$(P):VARS_POLL")
{
  field(DESC, "Control Variable Polling")
  field(DTYP, "Soft Channel")
  field(ZNAM, "Enabled")
  field(ONAM, "Disabled")
}

############## Power Status ###################

record(ai, "$(P):GET_POWER_STATE")
{
  field(DESC, "Get Power Status")
  field(DTYP, "stream")
  field(SCAN, "10 second")
  field(INP,  "@robotPLC.proto powerTime($(P)) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):STATUS_POLL.RVAL CP")
}

record(ai, "$(P):POWER_ON_TIME")
{
  field(DESC, "Power On Time")
}

record(ai, "$(P):BATT_REMAIN_TIME")
{
  field(DESC, "Battery Time Remaining")
}

############### Watch Window Clear ####################

# These records are not under the watch window
# template as they are only needed once
# whereas the watch window template is used
# multiple times

record(fanout, "$(P):VAR_ALL_CLR")
{
  field(DESC, "Call Clear on First Six Variables")
  field(SELM, "All")
  field(LNK1, "$(P):VAR_1_CLR")
  field(LNK2, "$(P):VAR_2_CLR")
  field(LNK3, "$(P):VAR_3_CLR")
  field(LNK4, "$(P):VAR_4_CLR")
  field(LNK5, "$(P):VAR_5_CLR")
  field(LNK6, "$(P):VAR_6_CLR")
  field(FLNK, "$(P):VAR_ALL_CLR_2 PP")
}

record(fanout, "$(P):VAR_ALL_CLR_2")
{
  field(DESC, "Call Clear on Last Four Variables")
  field(SELM, "All")
  field(LNK1, "$(P):VAR_7_CLR")
  field(LNK2, "$(P):VAR_8_CLR")
  field(LNK3, "$(P):VAR_9_CLR")
  field(LNK4, "$(P):VAR_10_CLR")
}

################# Fetch Positions #######################

record(stringout, "$(P):FETCH_POSITION")
{
  field(DESC, "Get the Position")
  field(OMSL, "closed_loop")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto fetchPosition($(P)) $(STREAMS_PORT,undefined)")
  field(SCAN, "Passive")
}

# If a variable name returns mismatch (ie it's invalid)
# then set this record high (to be used by GUI)
# If the mismatch is for a blank variable name
# (can happen for a second) when a name is cleared)
# then don't mark as invalid

record(scalcout, "$(P):FETCH_POSITION_INVALID")
{
  field(DESC, "Check for Invalid Position Name")
  field(INAA, "$(P):FETCH_POSITION CP")
  field(INPA, "$(P):FETCH_POSITION.SEVR CP")
  field(CALC, "(AA=='' && A == 3)?0:A")
}

#########################################################


# Corresponding edm screen: TeachMode.edl

######################### Program Control #######################

# Open up the positions program for editing

# GET_TEACH_POS is forward linked here so that this 
# record processes when the positions program is 
# loaded.  This is to ensure that any teach position 
# variable left in the TP field is read immediately 
# when the program is loaded
record(ao, "$(P):LOAD_POSITIONS")
{ 
  field(DESC, "Load the Positions Program")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto loadProgram($(P)) $(STREAMS_PORT,undefined)")
  field(FLNK, "$(P):GET_TEACH_POS")
}

record(ao, "$(P):SAVE_POSITIONS")
{
  field(DESC, "Save the Positions Program")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto saveProgram($(P)) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):EDIT_MODE")
}

record(ao, "$(P):UNDO_POSITIONS")
{
  field(DESC, "Undo Changes to the Positions Program")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto undoProgram($(P)) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):EDIT_MODE")
}

# Poll the edit status to retrieve the name
# of a program being edited.
# If a name is present, sets an edit mode bit high
# This is used as an SDIS input to other records
# in this template, and the GUI, to know that a
# program is loaded into the edit slot

record(ai, "$(P):GET_EDIT_STATE")
{
  field(DESC, "Program Edit Status")
  field(DTYP, "stream")
  field(SCAN, "1 second")
  field(INP,  "@robotPLC.proto getEditState($(P)) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):STATUS_POLL.RVAL CP")
}

record(stringin, "$(P):EDIT_NAME")
{
  field(DESC, "Program Currently Being Edited")
}

# Record is high when program being edit, low otherwise
record(scalcout, "$(P):EDIT_MODE")
{
  field(DESC, "Check for Program Being Edited")
  field(INAA, "$(P):EDIT_NAME CP")
  field(CALC, "(AA='')?1:0")
}

##################### Direct Execution ############################

# Allow raw MELFA BASIC commands to be sent to the robot directly
# Can only happen when the positions program is open (ie in edit mode)
# Servo On & Off provided as convenience buttons - could be sent
# as commands instead

record(stringout, "$(P):TURN_SERVO_ON")
{
  field(DESC, "Turn Servo On with EXEC")
  field(DTYP, "stream")
  field(VAL,  "SERVO ON")
  field(OUT,  "@robotPLC.proto directCommand($(P)) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):EDIT_MODE")
}

record(stringout, "$(P):TURN_SERVO_OFF")
{
  field(DESC, "Turn Servo Off with EXEC")
  field(DTYP, "stream")
  field(VAL,  "SERVO OFF")
  field(OUT,  "@robotPLC.proto directCommand($(P)) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):EDIT_MODE")
}

record(stringout, "$(P):DIRECT_CMD")
{
  field(DESC, "Direct Execution Command")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto directCommand($(P)) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):EDIT_MODE")
}

# When a direct command is entered, send it to a regular
# expression genSub routine for the P variable to be extracted
# and then send this P variable on to the position name box
record(genSub, "$(P):DIRECT_CMD_REGEX")
{
  field(DESC, "Regex on the Direct Command")
  field(SNAM, "Regex")
  field(INPA, "$(P):DIRECT_CMD CP")
  field(FTA,  "STRING")
  field(FTVA, "STRING")
  field(OUTA, "$(P):TP PP")
}

########################### Teaching ##############################

# Teach positions are fetched by position name
# This name is fetched from TP by GET_TEACH_POS
# whenever TP is changed

record(stringout, "$(P):TP")
{
  field(DESC, "Teach Position")
  field(FLNK, "$(P):GET_TEACH_POS")
  field(SDIS, "$(P):EDIT_MODE")
}

record(ao, "$(P):GET_TEACH_POS")
{
  field(DESC, "Get the Teach Position")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto getPosition($(P),TP) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):EDIT_MODE")
}

record(ao, "$(P):GET_CURR_POS")
{
  field(DESC, "Get the Current Positions")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto getCurrentPosition($(P)) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):EDIT_MODE")
}

# A 'set' triggers a 'get' to ensure the values
# displayed on the GUI are the latest

record(ao, "$(P):SET_TEACH_POS")
{
  field(DESC, "Set the Teach Position")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto setPosition($(P),X,Y,Z,A,B,C,L1,F1) $(STREAMS_PORT,undefined)")
  field(FLNK, "$(P):GET_TEACH_POS")
  field(SDIS, "$(P):EDIT_MODE")
}



# Position readback is pushed down from the robot

record(ai, "$(P):X_RBV")
{
  field(DESC, "X Position Readback")
}

# The position is updated when the readback is refreshed

record(calcout, "$(P):X_REFRESH")
{
  field(DESC, "Update X with Readback")
  field(INPA, "$(P):X_RBV CP")
  field(CALC, "A")
  field(OUT,  "$(P):X PP")
}

record(ai, "$(P):X")
{
  field(DESC, "X Position")
  field(VAL,  "0")
  field(PINI, "YES")
  field(SDIS, "$(P):EDIT_MODE")
}



# The LOAD program doesn't call
# program selection directly - it goes
# via the sequence template to confirm that
# the sample positions are correct first

record(dfanout, "$(P):LOAD")
{
  field(DESC, "LOAD Program Trigger")
  field(VAL,  "1")
  field(OUTA, "$(P):LOAD_SEQ.PROC PP")
  field(OMSL, "closed_loop")
  field(SDIS, "$(P):PROGRAM_READY")
  field(FLNK, "$(P):CLEAR_BARCODE")
}



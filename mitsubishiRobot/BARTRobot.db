################ Timeout & Fault Monitoring ################

#% autosave 1 VAL
record(ao, "$(P):FILL_TIME")
{
  field(DESC, "Fill Time")
  field(PREC, "0")
  field(VAL,  "60")
  field(DRVL, "0")
  field(DRVH, "600")
  field(PINI, "YES")
  field(OUT,  "$(P):SET_FILL_TIME PP")
}

#% autosave 1 VAL
record(ao, "$(P):FILL_PAUSE")
{
  field(DESC, "Fill Pause Time")
  field(PREC, "0")
  field(VAL,  "180")
  field(DRVL, "0")
  field(DRVH, "600")
  field(PINI, "YES")
  field(OUT,  "$(P):SET_FILL_PAUSE PP")
}

#% autosave 1 VAL
record(ao, "$(P):FILL_TIMEOUT")
{
  field(DESC, "Fill Timeout")
  field(PREC, "0")
  field(VAL,  "180")
  field(DRVL, "0")
  field(DRVH, "999")
  field(PINI, "YES")
  field(OUT,  "$(P):SET_FILL_TIMEOUT PP")
}

# Read the fill timeout remainder 
record(subArray, "$(P):FILL_TIMEOUT_RAW_1")
{
  field(DESC, "Fill Timeout Part A")
  field(DTYP, "Soft Channel")
  field(FTVL, "USHORT")
  field(INP,  "$(P):DM0XX CP MS")
  field(MALM, "100")
  field(NELM, "1")
  field(INDX, "78")
}

# Read the fill timeout quotient
record(subArray, "$(P):FILL_TIMEOUT_RAW_2")
{
  field(DESC, "Fill Timeout Part B")
  field(DTYP, "Soft Channel")
  field(FTVL, "USHORT")
  field(INP,  "$(P):DM0XX CP MS")
  field(MALM, "100")
  field(NELM, "1")
  field(INDX, "79")
}

# Calculate the full fill timeout value
record(calcout, "$(P):FILL_TIMEOUT_RAW")
{
  field(DESC, "Fill Timeout Readback")
  field(INPA, "$(P):FILL_TIMEOUT_RAW_1 CP")
  field(INPB, "$(P):FILL_TIMEOUT_RAW_2 CP")
  field(CALC, "((B*65536)+A)")
}

# Convert this value into minutes
record(calcout, "$(P):FILL_TIMEOUT_MINS")
{
  field(DESC, "Fill Timeout in MM.SS Format")
  field(CALC, "FLOOR(A/600)+(FLOOR(A/10)%60)/100")
  field(INPA, "$(P):FILL_TIMEOUT_RAW CP MS")
  field(PREC, "2")
}

record(bo, "$(P):FILL_TIMEOUT_RESET")
{
  field(DESC, "Auto Fill Timeout Reset")
}

record(calcout, "$(P):FILL_RESET_CALC")
{
  field(DESC, "Set Bits for Timeout Reset")
  field(INPA, "$(P):CRYO_FILL_STATUS")
  field(INPB, "$(P):CRYO_FILL_BITS.B4")
  field(INPC, "$(P):FILL_TIMEOUT_RESET CP")
  field(CALC, "(A XOR ((B XOR C) * 16))")
  field(OUT,  "$(P):DEWAR_FILL PP")
}

record(bo, "$(P):SENSOR_FAULT_RESET")
{
  field(DESC, "Sensor Fault Reset")
}

record(calcout, "$(P):SENSOR_RESET_CALC")
{

# Corresponding edm screen: VisionSystem.edl

########################################################

# Template to read a lid data variable off of the PLC
# then send it straight back to the PLC for verification

# Read variable from PLC

record(waveform, "$(P):CAM_RATIO:GET") 
{
  field(DESC, "Read CAM_RATIO from PLC")
  field(DTYP, "asynFloat32ArrayIn")
  field(INP,  "@asyn($(PORT), 500, 1) FINS_DM_READ_32")
  field(FTVL, "FLOAT")
  field(PRIO, "MEDIUM")
}

# PV that will hold the variable read above
# (without the messy waveform bits)

record(ai, "$(P):CAM_RATIO") 
{
  field(DESC, "CAM_RATIO")
  field(INP,  "$(P):CAM_RATIO:GET CP MS")
  field(PREC, "3")
  field(MDEL, "-1")
}

# Whenever data is received (whether different
# than before or not), send it straight back
# to the PLC to be verified

record(calcout, "$(P):CAM_RATIO_ACK")
{
  field(DESC, "Return CAM_RATIO to Confirm on PLC")
  field(INPA, "$(P):CAM_RATIO CP")
  field(CALC, "A")
  field(OUT,  "$(P):W_CAM_RATIO PP")
  field(OOPT, "Every Time")
}




# Corresponding edm screen: VisionSystem.edl

#######################################################

# Template to read puck data byte off of the PLC

# Read single bytes of puck data
# 9 bytes are read in total, each 
# can contain 2 barcode characters
# Once all 9 are collected, they are
# glued together and translated as a string

# When new puck data is read from the PLC, pull out 
# all the 9 individual bytes which store a puck's name
#
# Bytes 0 to 4
record(acalcout, "$(P):PUCK_34_BYTES_1")
{
  field(DESC, "Bytes 0 to 4 of Puck 34")
  field(NELM, "400")
  field(NUSE, "400")
  field(INAA, "$(P):READ_400.VAL CP MS")
  field(CALC, "a:=aa[340,340];b:=aa[341,341];c:=aa[342,342];d:=aa[343,343];e:=aa[344,344];1")
  field(FLNK, "$(P):PUCK_34_BYTES_2")
}

# Bytes 5 to 8
record(acalcout, "$(P):PUCK_34_BYTES_2")
{
  field(DESC, "Bytes 5 to 8 of Puck 34")
  field(NELM, "400")
  field(NUSE, "400")
  field(INAA, "$(P):READ_400.VAL")
  field(CALC, "a:=aa[345,345];b:=aa[346,346];c:=aa[347,347];d:=aa[348,348];1")
  field(FLNK, "$(P):PUCK_34_CALC")
}

# Once all 9 bytes have been read in, pull them to a genSub
# function to be translated into a text string
record(genSub, "$(P):PUCK_34_CALC")
{
  field(DESC, "Translate Bytes to Puck")
  field(SNAM, "PuckLabel")
  field(INPA, "$(P):PUCK_34_BYTES_1.A")
  field(INPB, "$(P):PUCK_34_BYTES_1.B")
  field(INPC, "$(P):PUCK_34_BYTES_1.C")
  field(INPD, "$(P):PUCK_34_BYTES_1.D")
  field(INPE, "$(P):PUCK_34_BYTES_1.E")
  field(INPF, "$(P):PUCK_34_BYTES_2.A")
  field(INPG, "$(P):PUCK_34_BYTES_2.B")
  field(INPH, "$(P):PUCK_34_BYTES_2.C")
  field(INPI, "$(P):PUCK_34_BYTES_2.D")
  field(FTA,  "LONG")
  field(FTB,  "LONG")
  field(FTC,  "LONG")
  field(FTD,  "LONG")
  field(FTE,  "LONG")
  field(FTF,  "LONG")
  field(FTG,  "LONG")
  field(FTH,  "LONG")
  field(FTI,  "LONG")
  field(FTVA, "STRING")
  field(NOVA, "1")
  field(OUTA, "$(P):PUCK_34_NAME PP")
}

# Display the translated puck name string
record(waveform, "$(P):PUCK_34_NAME")
{
  field(DESC, "Puck 34 Result")
  field(NELM, "1")
  field(FTVL, "STRING")
}




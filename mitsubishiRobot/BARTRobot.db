# Whenever data is received (whether different
# than before or not), send it straight back
# to the PLC to be verified

record(calcout, "$(P):BYTE_5_ACK")
{
  field(DESC, "Return Byte 5 to Confirm on PLC")
  field(INPA, "$(P):BARCODE_BYTE_5 CP")
  field(CALC, "A")
  field(OUT,  "$(P):W_BARCODE_BYTE_5 PP")
  field(OOPT, "Every Time")
}




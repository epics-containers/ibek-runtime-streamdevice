#####################################################




# Corresponding edm screen: Overrides.edl

# Sum together the decimal values of all the forced 
# input and output bits of a port and send the result
# to the PLC to force all selected bits in one go

record(calcout, "$(P):IP_0_ON_BYTE_1")
{
  field(DESC, "Sum of First Byte of Port 0")
  field(INPA, "$(P):IP_0_FORCE_ON.RVAL PP")
  field(INPB, "$(P):IP_1_FORCE_ON.RVAL PP")
  field(INPC, "$(P):IP_2_FORCE_ON.RVAL PP")
  field(INPD, "$(P):IP_3_FORCE_ON.RVAL PP")
  field(INPE, "$(P):IP_4_FORCE_ON.RVAL PP")
  field(INPF, "$(P):IP_5_FORCE_ON.RVAL PP")
  field(INPG, "$(P):IP_6_FORCE_ON.RVAL PP")
  field(INPH, "$(P):IP_7_FORCE_ON.RVAL PP")
  field(CALC, "(A+B+C+D+E+F+G+H)")
}

record(calcout, "$(P):IP_0_ON_BYTE_2")
{
  field(DESC, "Sum of Second Byte of Port 0")
  field(INPA, "$(P):IP_8_FORCE_ON.RVAL PP")
  field(INPB, "$(P):IP_9_FORCE_ON.RVAL PP")
  field(INPC, "$(P):IP_10_FORCE_ON.RVAL PP")
  field(INPD, "$(P):IP_11_FORCE_ON.RVAL PP")
  field(INPE, "$(P):IP_12_FORCE_ON.RVAL PP")
  field(INPF, "$(P):IP_13_FORCE_ON.RVAL PP")
  field(INPG, "$(P):IP_14_FORCE_ON.RVAL PP")
  field(INPH, "$(P):IP_15_FORCE_ON.RVAL PP")
  field(CALC, "(A+B+C+D+E+F+G+H)")
}

record(calcout, "$(P):IP_0_ON_SUM")
{
  field(DESC, "Sum of Both Bytes of Port 0")
  field(INPA, "$(P):IP_0_ON_BYTE_1 PP")
  field(INPB, "$(P):IP_0_ON_BYTE_2 PP")
  field(CALC, "(A+B)")
  field(OUT,  "$(P):FORCE_IP_0_ON PP")
}

record(calcout, "$(P):IP_16_ON_BYTE_1")
{
  field(DESC, "Sum of First Byte of Port 16")
  field(INPA, "$(P):IP_16_FORCE_ON.RVAL PP")
  field(INPB, "$(P):IP_17_FORCE_ON.RVAL PP")
  field(INPC, "$(P):IP_18_FORCE_ON.RVAL PP")
  field(INPD, "$(P):IP_19_FORCE_ON.RVAL PP")
  field(INPE, "$(P):IP_20_FORCE_ON.RVAL PP")
  field(INPF, "$(P):IP_21_FORCE_ON.RVAL PP")
  field(INPG, "$(P):IP_22_FORCE_ON.RVAL PP")
  field(INPH, "$(P):IP_23_FORCE_ON.RVAL PP")
  field(CALC, "(A+B+C+D+E+F+G+H)")
}

record(calcout, "$(P):IP_16_ON_BYTE_2")
{
  field(DESC, "Sum of Second Byte of Port 16")
  field(INPA, "$(P):IP_24_FORCE_ON.RVAL PP")
  field(INPB, "$(P):IP_25_FORCE_ON.RVAL PP")
  field(INPC, "$(P):IP_26_FORCE_ON.RVAL PP")
  field(INPD, "$(P):IP_27_FORCE_ON.RVAL PP")
  field(INPE, "$(P):IP_28_FORCE_ON.RVAL PP")
  field(INPF, "$(P):IP_29_FORCE_ON.RVAL PP")
  field(INPG, "$(P):IP_30_FORCE_ON.RVAL PP")
  field(INPH, "$(P):IP_31_FORCE_ON.RVAL PP")
  field(CALC, "(A+B+C+D+E+F+G+H)")
}

record(calcout, "$(P):IP_16_ON_SUM")
{
  field(DESC, "Sum of Both Bytes of Port 16")
  field(INPA, "$(P):IP_16_ON_BYTE_1 PP")
  field(INPB, "$(P):IP_16_ON_BYTE_2 PP")
  field(CALC, "(A+B)")
  field(OUT,  "$(P):FORCE_IP_16_ON PP")
}




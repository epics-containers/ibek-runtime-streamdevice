  field(DESC, "Set Hotel Number")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto writeVariable($(P),M_HOTEL) $(STREAMS_PORT,undefined)")
  field(DRVH, "2")
  field(DRVL, "0")
  field(SDIS, "$(P):PROGRAM_READY")
}


# Corresponding edm screens: UserGUI.edl & AdvancedDebug.edl

#######################################################

record(asyn,"$(P):ASYN_RECORD")
{
  field(DESC, "Robot Comms Asyn Record")
  field(DTYP, "asynRecordDevice")
  field(PORT, "robot_serial")
  field(ADDR, "0")
  field(OMAX, "255")
  field(IMAX, "255")
}

#################### Program Control ###################

record(ao, "$(P):ABORT")
{
  field(DESC, "Abort the Current Program")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto servoOff($(P)) $(STREAMS_PORT,undefined)")
  field(MDEL, "-1")
  field(FLNK, "$(P):ABORT_MSG")
}

record(stringout, "$(P):ABORT_MSG")
{
  field(DESC, "Abort Message")
  field(VAL,  "Stop button pressed")
  field(OUT,  "$(P):LOGGING.D PP")
}

#################### Programs #####################

record(mbbo, "$(P):PROGRAM_SELECTION")
{
  field(DESC, "Program Selection List")
  field(DTYP, "Soft Channel")
  field(ZRVL, "0")
  field(ONVL, "1")
  field(TWVL, "2")
  field(THVL, "3")
  field(FRVL, "4")
  field(FVVL, "5")
  field(SXVL, "6")
  field(SVVL, "7")
  field(EIVL, "8")
  field(NIVL, "9")
  field(TEVL, "10")
  field(ELVL, "11")
  field(TVVL, "12")
  field(TTVL, "13")
  field(FTVL, "14")
  field(FFVL, "15")
  field(ZRST, "SOAK")
  field(ONST, "LOAD")
  field(TWST, "GOHM")
  field(THST, "UNLD")
  field(FRST, "DISP")
  field(FVST, "DRY")
  field(SXST, "RETURN")
  field(SVST, "")
  field(EIST, "INSP")
  field(NIST, "INIT")
  field(TEST, "TESTLID")
  field(ELST, "TESTBARC")
  field(TVST, "TESTPUCK")
  field(TTST, "READ")
  field(FTST, "MOVE")
  field(FFST, "GOGO")
  field(FLNK, "$(P):RUN_PROGRAM")
}

record(mbbo, "$(P):PROGRAM_SELECTION_1")
{
  field(DESC, "Program Selection List")
  field(DTYP, "Soft Channel")
  field(ZRVL, "0")
  field(ONVL, "1")
  field(TWVL, "2")
  field(THVL, "3")
  field(FRVL, "4")
  field(FVVL, "5")
  field(SXVL, "6")
  field(SVVL, "7")
  field(EIVL, "8")
  field(NIVL, "9")
  field(TEVL, "10")
  field(ELVL, "11")
  field(TVVL, "12")
  field(TTVL, "13")
  field(FTVL, "14")
  field(FFVL, "15")
  field(ZRST, "LLPICK")
  field(ONST, "20CPICK")
  field(TWST, "20CTOLL")
  field(THST, "LLSTORE")
  field(FRST, "NEWLLTO20C")
  field(FVST, "20CSTORE")
  field(SXST, "LOADPREP")
  field(SVST, "UNLDPREP")
  field(EIST, "")
  field(NIST, "")
  field(TEST, "")

### Port Transition ###

record(scalcout, "$(P):PORT_TRANSITION_CALC_20")
{
  field(DESC, "Port in transition state")
  field(INAA, "BL02I-EA-FMLTX-02:AUTOMATION_PORT_STATUS PP")
  field(BB,   "Ejecting")
  field(CC,   "Retracting")
  field(DD,   "Securing")
  field(CALC, "((AA==BB)||(AA==CC)||(AA==DD))?1:0")
}

### Port Open ###

record(scalcout, "$(P):PORT_FULLY_OPEN_CALC_20") 
{
  field(DESC, "Port fully open")
  field(INAA, "BL02I-EA-FMLTX-02:AUTOMATION_PORT_STATUS PP")
  field(BB,   "Ejected")
  field(CALC, "(AA==BB)?1:0")
}

#### Port Closed ####

record(calc, "$(P):PORT_FULLY_CLOSED_CALC_20") 
{
  field(DESC, "Port fully closed")
  field(INPA, "$(P):PORT_TRANSITION_CALC_20 CP")
  field(INPB, "$(P):PORT_FULLY_OPEN_CALC_20 CP")
  field(CALC, "A==1||B==1?0:1")
} 

### Final M_AutoOpen calculation###

record(calc, "$(P):PORT_CALC_FINAL_20")
{
  field(DESC, "Open and trnasition state")
  field(INPA, "$(P):PORT_TRANSITION_CALC_20 PP")
  field(INPB, "$(P):PORT_FULLY_OPEN_CALC_20 PP")
  field(CALC, "(-1*A) + (B)") 
  field(SCAN, ".1 second")
}

# Check if force on or force off is on (both for AUTO_OPEN and AUTO_CLOSE).
# If yes, ignore PORT_CALC_FINA (A) and use the value of FORCE OPEN ON (B) 
# or FORCE CLOSE OFF.
# Notice that CLOSE OFF is same as OPEN ON. 

record(calcout, "$(P):PORT_OUT_FINAL_20")
{
  field(DESC, "AutoOpen to robot var")
  field(INPA, "$(P):PORT_CALC_FINAL_20 CP")
  field(INPB, "$(P):OP_AUTO_OPEN_FORCE_ON_20.RVAL CP")
  field(INPC, "$(P):OP_AUTO_OPEN_FORCE_OFF_20.RVAL CP")
  field(INPD, "$(P):OP_AUTO_CLOSE_FORCE_ON_20.RVAL CP")
  field(INPE, "$(P):OP_AUTO_CLOSE_FORCE_OFF_20.RVAL CP") #close off is same as open on
  field(CALC, "(!(B+C+D+E)*A)+(B)+(E)" )
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto writeVariable($(P),M_AutoOpen20) $(STREAMS_PORT,undefined)")
  field(PINI, "YES")
}

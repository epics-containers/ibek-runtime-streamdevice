############### Hotel Dropdown ########################

record(mbbo, "$(P):SET_HOTEL")
{
  field(DESC, "Hotel List")
  field(DTYP, "Raw Soft Channel")
  field(PINI, "YES")
  field(ZRVL, "2")
  #field(ONVL, "1")
  field(ZRST, "20 Deg Hotel")
  #field(ONST, "4 Deg Hotel")
  field(OUT, "$(P):NEXT_HOTEL PP")
  field(VAL, "0")
}

record(mbbi, "$(P):GET_HOTEL_RBV")
{
  field(DESC, "Hotel Readback")
  field(DTYP, "Soft Channel")
  field(INP,  "$(P):NEXT_HOTEL_RBV CP")
  field(ZRST, "Not Selected")
  field(ONST, "4 Deg Hotel")
  field(TWST, "20 Deg Hotel")
}


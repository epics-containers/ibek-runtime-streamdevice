  field(TVST, "")
  field(TTST, "")
  field(FTST, "")
  field(FFST, "")
  field(FLNK, "$(P):RUN_PROGRAM_1")
}

record(stringout, "$(P):RUN_PROGRAM")
{
  field(DESC, "Run Program")
  field(OMSL, "closed_loop")
  field(DOL,  "$(P):PROGRAM_SELECTION")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto runProgram($(P)) $(STREAMS_PORT,undefined)")
}

record(stringout, "$(P):RUN_PROGRAM_1")
{
  field(DESC, "Run Program")
  field(OMSL, "closed_loop")
  field(DOL,  "$(P):PROGRAM_SELECTION_1")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto runProgram($(P)) $(STREAMS_PORT,undefined)")
}


record(stringout, "$(P):RUN_ERROR_CODE")
{
  field(DESC, "runProgram error code")
  field(VAL,  "")
}

# Gripper actions are not controlled by 
# programs but by firing robot controller
# outputs directly.  This is to ensure
# the gripper is still controllable even when
# the programs are not available





################### Program Status ###################

# All of the following records in this section
# are populated as a result of the protocol file
# response to the GET_STATE request below

record(ai, "$(P):GET_STATE")
{
  field(DESC, "Robot Program Status")
  field(DTYP, "stream")
  field(SCAN, "1 second")
  field(INP,  "@robotPLC.proto getState($(P)) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):STATUS_POLL.RVAL CP")
}

record(stringin, "$(P):PROGRAM_NAME")
{
  field(DESC, "Currently Running Program Name")
}

# Request the currently executed program line
record(ao, "$(P):LINE_NUMBER")
{
  field(DESC, "Current Program Line Number")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto currentLine($(P)) $(STREAMS_PORT,undefined)")
}

# Display the returned error number

# This record is populated as a result 
# of the protocol file response to the 
# above LINE_NUMBER request
record(waveform, "$(P):LINE_CONTENTS")
{
  field(DESC, "Current Line Contents")
  field(NELM, "1")
  field(FTVL, "STRING")
}

record(ai, "$(P):EDIT_STATUS")
{
  field(DESC, "Edit Status")
}

record(ai, "$(P):STEP_NUMBER")
{
  field(DESC, "Execution Step Number")
}

record(ai, "$(P):MECH_INFO")
{
  field(DESC, "Mech Info")
}

record(stringin, "$(P):TASK_NAME")
{
  field(DESC, "Current Task Name")
}

record(mbbi, "$(P):TASK_MODE")
{
  field(DESC, "Operation Mode of Slot Table")
  field(DTYP, "Soft Channel")
  field(ZRST, "REP")
  field(ZRVL, "0")
  field(ONST, "CYC")
  field(ONVL, "1")
}

record(mbbi, "$(P):TASK_CONDITION")
{
  field(DESC, "Operation Mode of Slot Table")
  field(DTYP, "Soft Channel")
  field(ZRST, "START")
  field(ZRVL, "0")
  field(ONST, "ALWAYS")
  field(ONVL, "1")
  field(TWST, "ERROR")
  field(TWVL, "2")
}

record(ai, "$(P):TASK_PRIORITY")
{
  field(DESC, "Priority of Slot Table")
}

record(ai, "$(P):MECH_NUM_IN_USE")
{
  field(DESC, "Mech Number In Use")
}

################ Convenience Statuses ###################

# These records are used to give nice PV names to 
# individual status bits (rather than have nameless
# B1, B4, PVs etc)  This is done for PVs which are
# used by GDA or regularly by the user

record(bi, "$(P):TEACH_MODE")
{
  field(DESC, "Teach Mode State")
  field(INP,  "$(P):RUN_STATUS.B3 CP")
  field(ZNAM, "Exec Mode")
  field(ONAM, "Teach Mode")
}

record(bi, "$(P):SERVO_ON")
{
  field(DESC, "Servo State")
  field(INP,  "$(P):RUN_STATUS.B5 CP")
  field(ZNAM, "Servo Off")
  field(ONAM, "Servo On")
}

record(bi, "$(P):PROGRAM_RUNNING")
{
  field(DESC, "Program Running State")
  field(INP,  "$(P):RUN_STATUS.B6 CP")
  field(ZNAM, "No Program Running")
  field(ONAM, "Program Running")
}

record(bi, "$(P):CONTROL_STATE")
{
  field(DESC, "Control State")
  field(INP,  "$(P):RUN_STATUS.B7 CP")
  field(ZNAM, "Control Off")
  field(ONAM, "Control On")
}

record(bi, "$(P):PROGRAM_SELECT")
{
  field(DESC, "Program Select State")
  field(INP,  "$(P):STOP_STATUS.B4 CP")
  field(ZNAM, "Program Select Disabled")
  field(ONAM, "Program Select Enabled")
}

# Read the gripper type from the robot
# 1 = BART
# 2 = VMXi
# 3 = ALS
record(ai, "$(P):GRIPPER_TYPE")
{
  field(DESC, "Gripper Type")
  field(DTYP, "stream")
  field(INP,  "@robotPLC.proto readVariable(M_GRIP) $(STREAMS_PORT,undefined)")
  field(MDEL, "-1")
  field(PINI, "YES")
}

# Read the dewar setup from the robot
#  1 = Cryotherm dewar (I03, I04, I04-1)
#  2 = Little CL2 dewar inside the cryotherm dewar (Very rarely used on I03)
#  3 = 1 ACTOR dewar (Previous I19 setup)
#  4 = Cryotherm plus plates (I24)
#  5 = Plates only (Very rarely used on I03)
#  6 = 2 ACTOR dewars (I19)
record(ai, "$(P):DEWAR_SETUP")
{
  field(DESC, "Dewar Setup")
  field(DTYP, "stream")
  field(INP,  "@robotPLC.proto readVariable(M_DEWAR) $(STREAMS_PORT,undefined)")
  field(MDEL, "-1")
  field(PINI, "YES")
}

record(calc, "$(P):VMXI_GRIPPER_POLL")
{
  field(DESC, "VMXi Gripper Poll")
  field(INPA, "$(P):GRIPPER_TYPE CP")
  field(INPB, "$(P):IO_POLL.RVAL CP")
  field(CALC, "(A#2|B)?1:0")
}

record(bi, "$(P):BART_GRIPPER")
{
  field(DESC, "BART Gripper State")
  field(INP,  "$(P):ROBOT_IP_0_BITS.B8 CP")
  field(ZNAM, "Gripper Open")
  field(ONAM, "Gripper Closed")
}

record(bi, "$(P):BART_GRIPPER_WIDE")
{
  field(DESC, "BART Gripper Wide State")
  field(INP,  "$(P):ROBOT_IP_0_BITS.B9 CP")
  field(ZNAM, "Gripper Wide")
  field(ONAM, "Gripper Not Wide")
}

record(ai, "$(P):VMXI_GRIPPER")
{
  field(DESC, "VMXi Gripper State")
  field(DTYP, "stream")
  field(INP,  "@robotPLC.proto readVariable(M_In(900)) $(STREAMS_PORT,undefined)")
  field(SCAN, ".5 second")
  field(MDEL, "-1")
  field(SDIS, "$(P):VMXI_GRIPPER_POLL CP")
}

record(calcout, "$(P):GRIPPER_FB_CALC")
{
  field(DESC, "Check Gripper Feedback")
  field(INPA, "$(P):GRIPPER_TYPE CP")
  field(INPB, "$(P):BART_GRIPPER CP")
  field(INPC, "$(P):VMXI_GRIPPER CP")
  field(INPD, "$(P):BART_GRIPPER_WIDE")
  field(CALC, "(A=1?(!B+!D):C)")
  field(OUT,  "$(P):GRIPPER_STATE PP")
}

record(mbbi, "$(P):GRIPPER_STATE")
{
  field(DESC, "Gripper State")
  field(ZRVL, "0")
  field(ONVL, "1")
  field(TWVL, "2")
  field(ZRST, "Closed")
  field(ONST, "Open")
  field(TWST, "Wide")
}

record(bi, "$(P):PIN_MOUNTED")
{
  field(DESC, "Pin Mounted State")
  field(INP,  "$(P):ROBOT_IP_16_BITS.B5 CP")
  field(ZNAM, "No Pin Mounted")
  field(ONAM, "Pin Mounted")
}

############### Visibility / Ready PVs #################

# These records are used by the GUI or by SDIS
# fields of other records to determine that certain
# conditions are met before allowing something
# to be controlled or to be visible on the GUI

record(calcout, "$(P):PROGRAM_READY")
{
  field(DESC, "Program Ready State")
  field(INPA, "$(P):PROGRAM_RUNNING CP")
  field(INPB, "$(P):CONTROL_STATE CP")
  field(CALC, "(A|!B)?1:0")
}

record(calc, "$(P):PROGRAM_VIS")
{
  field(DESC, "Program Button Visibility")
  field(INPA, "$(P):PROGRAM_SELECT CP")
  field(INPB, "$(P):TEACH_MODE CP")
  field(INPC, "$(P):CONTROL_STATE CP")
  field(INPD, "$(P):EDIT_MODE CP")
  field(CALC, "(A&!B&C&D)?1:0")
}

############################################################

record(genSub, "$(P):LOGGING")
{
  field(SNAM, "Logging")
  field(INPA, "$(P):RUN_PROGRAM.VAL CP")
  field(FTA,  "STRING")
  field(FTD,  "STRING")
}

######################## Resets ##############################

# Pressing the reset button on the main GUI triggers
# a chain of reset events:

# 1) Reset of alarm state
# 2) Enabling control
# 3) Reset of program
# 4) Reset of program error code to zero
# 5) Reset of run error code to zero
# 6) Reset of the top level program variable to zero

# This is achieved through a mixture of forward links
# and return statements from the protocol file

record(busy, "$(P):RESET_STATUS")
{
  field(DESC, "Status of reset")
  field(VAL, "0")
}

record(ai, "$(P):RESET")
{
  field(DESC, "Reset Robot State")
  field(DTYP, "stream")
  field(INP,  "@robotPLC.proto openComms($(P)) $(STREAMS_PORT,undefined)")
  field(MDEL, "-1")
  field(FLNK, "$(P):TRIGGER_BUSY")
}

record(calcout, "$(P):TRIGGER_BUSY")
{
  field(DESC, "Start of reset")
  field(CALC, "1")
  field(OUT, "$(P):RESET_STATUS.VAL PP")
}

record(calcout, "$(P):CLEAR_BUSY")
{
  field(DESC, "reset completed")
  field(CALC, "0")
  field(OUT, "$(P):RESET_STATUS.VAL PP")
}

record(ai, "$(P):RESET_ALARM")
{
  field(DESC, "Reset Robot Alarm")
  field(DTYP, "stream")
  field(INP,  "@robotPLC.proto resetAlarm($(P)) $(STREAMS_PORT,undefined)")
  field(MDEL, "-1")
  field(FLNK, "$(P):RESET_MSG")
}

record(stringout, "$(P):RESET_MSG")
{
  field(DESC, "Reset Message")
  field(VAL,  "Reset button pressed")
  field(OUT,  "$(P):LOGGING.D PP")
}

record(ao, "$(P):RESET_CONTROL_ON")
{
  field(DESC, "Turn Control On")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto controlOn($(P)) $(STREAMS_PORT,undefined)")
  field(FLNK, "$(P):RESET_PROGRAM")
}

record(ao, "$(P):RESET_PROGRAM")
{
  field(DESC, "Reset Program")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto resetProgram($(P)) $(STREAMS_PORT,undefined)")
}

# The reset value of 0 is actually sent to this record
# by the protocol file during a reset procedure
# This is to avoid the error code value being 
# overwritten upon startup by the streamDevice init
# command reading a previous error code in
record(ao, "$(P):RESET_ERROR_CODE")
{
  field(DESC, "Reset Program Error Code")
  field(DTYP, "stream")
  field(VAL,  "0")
  field(OUT,  "@robotPLC.proto writeVariable($(P),M_AERR) $(STREAMS_PORT,undefined)")
  field(FLNK, "$(P):RESET_RUN_ERR")
}

record(ao, "$(P):RESET_RUN_ERR")
{
  field(DESC, "Reset Program")
  field(VAL,  "0")
  field(OUT,  "$(P):RUN_ERR_CODE PP")
  field(FLNK, "$(P):TOPPRG_ZERO")
}

record(ao, "$(P):TOPPRG_ZERO")
{
  field(DESC, "Write zero to M_TOPPRG")
  field(VAL,  "0")
  field(OUT,  "$(P):RESET_M_TOPPRG PP")
}

# The variable M_TOPPRG keeps a record of the
# 'top level program' - ie the one which kicked
# off the current action.  So if a load triggered
# a soak, the load program is the top program
# so the robot knows which program to carry on 
# with after the soak program finishes

record(ao, "$(P):RESET_M_TOPPRG")
{
  field(DESC, "Reset M_TOPPRG")
  field(DTYP, "stream")
  field(VAL,  "0")
  field(OUT,  "@robotPLC.proto writeVariable($(P),M_TOPPRG) $(STREAMS_PORT,undefined)")
  field(FLNK, "$(P):CLEAR_BUSY")
}

###################### Error Monitors ##########################

record(ai, "$(P):PRG_ERR_CODE")
{
  field(DESC, "Program Error Code")
  field(DTYP, "stream")
  field(SCAN, "1 second")
  field(INP,  "@robotPLC.proto readVariable(M_AERR) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):STATUS_POLL.RVAL CP")
}

# Record takes in a numeric program error
# code, looks up a error string on a lookup
# table, and returns the string to
# be displayed by the waveform record

record(genSub, "$(P):PRG_ERR_LOOKUP")
{
  field(SNAM, "ErrorLookup")
  field(INPA, "$(P):PRG_ERR_CODE CP")
  field(FTA,  "LONG")
  field(FTVA, "STRING")
  field(NOVA, "1")
  field(OUTA, "$(P):PRG_ERR_MSG PP")
}

record(waveform, "$(P):PRG_ERR_MSG")
{
  field(DESC, "Program Error Message")
  field(NELM, "1")
  field(FTVL, "STRING")
}

# Triggered whenever a run command is sent
# Request the message associated with an error number
record(ao, "$(P):RUN_ERR_CODE")
{
  field(DESC, "Run Command Error Code")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto runErrorMessage($(P)) $(STREAMS_PORT,undefined)")
}

# Display the returned error message
record(waveform, "$(P):RUN_ERR_RET")
{
  field(DESC, "Returned Run Error Message")
  field(NELM, "1")
  field(FTVL, "STRING")
}

record(genSub, "$(P):RUN_ERR_LOOKUP")
{
  field(SNAM, "CmdErrorLookup")
  field(INPA, "$(P):RUN_ERR_CODE NP")
  field(INPB, "$(P):RUN_ERR_RET CP")
  field(INPC, "$(P):RUN_ERR_MSG NP")
  field(FTA,  "LONG")
  field(FTB,  "STRING")
  field(FTC,  "STRING")
  field(FTVA, "STRING")
  field(NOVA, "1")
  field(OUTA, "$(P):RUN_ERR_MSG PP")
}

record(waveform, "$(P):RUN_ERR_MSG")
{
  field(DESC, "Run Error Message")
  field(NELM, "1")
  field(FTVL, "STRING")
}

record(ao, "$(P):CNTL_ERR_CODE")
{
  field(DESC, "Controller Error Code")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto errorMessage($(P)) $(STREAMS_PORT,undefined)")
}

record(waveform, "$(P):CNTL_ERR_RET")
{
  field(DESC, "Returned Controller Error Message")
  field(NELM, "1")
  field(FTVL, "STRING")
}

record(scalcout, "$(P):CNTL_MSG_CHECK")
{
  field(DESC, "Check for Non-Blank Error Message")
  field(CALC, "(A>0)?AA:''")
  field(INPA, "$(P):CNTL_ERR_CODE CP")
  field(INAA, "$(P):CNTL_ERR_RET")
  field(OUT,  "$(P):CNTL_ERR_MSG PP")
}

record(waveform, "$(P):CNTL_ERR_MSG")
{
  field(DESC, "Controller Error Message")
  field(NELM, "1")
  field(FTVL, "STRING")
}

record(genSub, "$(P):LOG_CNTL_ERROR")
{
  field(SNAM, "LogError")
  field(INPA, "$(P):CNTL_ERR_MSG CP")
  field(INPB, "$(P):CNTL_ERR_CODE PP")
  field(FTA,  "STRING")
  field(FTB,  "STRING")
}

record(ai, "$(P):GET_ERROR_2")
{
  field(DTYP, "stream")
  field(INP,  "@robotPLC.proto readErrors($(P)) $(STREAMS_PORT,undefined)")
  field(SCAN, "I/O Intr")
}

###################### Location Code Lookup #########################

record(ai, "$(P):LOCATION_CODE")
{
  field(DESC, "Robot Location Code")
  field(DTYP, "stream")

record(ao, "$(P):GENERAL_SPEED")
{
  field(DESC, "Set General Speed")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto writeVariable($(P),M_SGEN) $(STREAMS_PORT,undefined)")
  field(DRVH, "70")
  field(DRVL, "0")
  field(SDIS, "$(P):PROGRAM_READY")
}

#% archiver 1 Monitor
record(ai, "$(P):GENERAL_SPEED_RBV")
{
  field(DESC, "General Speed")
  field(DTYP, "stream")
  field(SCAN, "1 second")
  field(INP,  "@robotPLC.proto readVariable(M_SGEN) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):VARS_POLL.RVAL CP")
}



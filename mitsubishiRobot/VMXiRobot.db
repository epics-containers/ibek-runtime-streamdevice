  field(SELL, "$(P):OP_30_FORCE_OPTION.RVAL CP")
  field(VAL,  "1")
  field(OUTA, "$(P):OP_30_FORCE_ON CA")
  field(OUTB, "$(P):OP_30_NORMAL_FAN.PROC CA")
  field(OUTC, "$(P):OP_30_FORCE_OFF CA")
}

# If no force is selected, the zero is sent to
# both the force on and force off bits to reset them

record(dfanout, "$(P):OP_30_NORMAL_FAN")
{
  field(DESC, "Unforce Output Bit 30")
  field(SELM, "All")
  field(VAL,  "0")
  field(OUTA, "$(P):OP_30_FORCE_ON CA")
  field(OUTB, "$(P):OP_30_FORCE_OFF CA")  
}

# The appropriate decimal value is set for each bit
# and the sum of all bits is triggered, to send
# the forced bits of the whole port together

record(mbbo, "$(P):OP_30_FORCE_ON")
{
  field(DESC, "Force On Output Bit 30")
  field(ZRVL, "0")
  field(ONVL, "16384")
  field(ZRST, "No")
  field(ONST, "Yes")
  field(FLNK, "$(P):OP_16_ON_SUM")
}

record(mbbo, "$(P):OP_30_FORCE_OFF")
{
  field(DESC, "Force Off Output Bit 30")
  field(ZRVL, "0")
  field(ONVL, "16384")
  field(ZRST, "No")
  field(ONST, "Yes")
  field(FLNK, "$(P):OP_16_OFF_SUM")
}


{
  field(DESC, "Force Option Output Bit 31")
  field(ZRVL, "1")
  field(ONVL, "2")
  field(TWVL, "3")
  field(ZRST, "On")
  field(ONST, "No")
  field(TWST, "Off")
  field(VAL,  "1")
  field(PINI, "YES")
}


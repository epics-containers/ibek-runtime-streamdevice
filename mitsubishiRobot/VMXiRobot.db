record(calcout, "$(P):PLATE_ON_HAND_OUT_20") 
{
  field(DESC, "PLATE PRESENT to robot var")
  field(INPA, "BL02I-EA-FMLTX-02:PLATE_ON_HAND PP")
  field(INPB, "$(P):OP_PLATE_PRESENT_FORCE_ON_20 CP")
  field(INPC, "$(P):OP_PLATE_PRESENT_FORCE_OFF_20 CP")
  field(CALC, "(!(C||B) && A) || B>0 ")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto writeVariable($(P),M_PlatePresent20) $(STREAMS_PORT,undefined)")
  field(SCAN, ".1 second")
}


# Corresponding edm screens: InputsOutputs.edl & UserGUI.edl

############### Input & Output Requests #############

record(ai, "$(P):PORT_0_REQ")
{
  field(DESC, "Port 0 Status")
  field(DTYP, "stream")
  field(SCAN, "1 second")
  field(INP,  "@robotPLC.proto ioState0($(P)) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):IO_POLL.RVAL CP")
}

record(ai, "$(P):PORT_1_REQ")
{
  field(DESC, "Port 1 Status")
  field(DTYP, "stream")
  field(SCAN, ".1 second")
  field(INP,  "@robotPLC.proto ioState1($(P)) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):IO_POLL.RVAL CP")
}

################ Run & Stop Status ###################

record(mbbiDirect, "$(P):RUN_STATUS")
{
  field(DESC, "Run State in Bits")
  field(DTYP, "Soft Channel")
  field(NOBT, "8")
}

record(mbbiDirect, "$(P):STOP_STATUS")
{
  field(DESC, "Stop State in Bits")
  field(DTYP, "Soft Channel")
  field(NOBT, "8")
}

############### Gripper Control ###################

# Control of the gripper was previously handled via
# robot programs which set the relevant output bits.
# This worked fine but meant that it was not possible
# to control the gripper when in an e-stop state for
# example, as no programs can be run in this state.
# To get around this the gripper is controlled by
# directly calling the relevant output bits, outside
# of any robot programs

# XORs are used because outputs are written a bank at
# a time and we don't want to change the state of 
# any other I/O on the same bank.  Also, we want to
# avoid the gripper state from being toggled - ie if
# an open command is sent when it is already open, we
# want it to remain open (ie ignore the open request)
# and not for it to close 

# Open gripper
record(calcout, "$(P):COLO")
{
  field(DESC, "Open Gripper")
  field(INPA, "$(P):ROBOT_OP_0_BITS")
  field(INPB, "$(P):ROBOT_OP_0_BITS.B8")
  field(CALC, "(A XOR (!B * 256))")
  field(OUT,  "$(P):WRITE_OP PP")
}

# Open gripper wide
record(calcout, "$(P):COLW")
{
  field(DESC, "Open Gripper Wide")
  field(INPA, "$(P):ROBOT_OP_0_BITS")
  field(INPB, "$(P):ROBOT_OP_0_BITS.B8")
  field(INPC, "$(P):ROBOT_OP_0_BITS.B9")
  field(CALC, "(A XOR ((!B * 256) + (!C * 512)))")
  field(OUT,  "$(P):WRITE_OP PP")
}

# Close gripper
record(calcout, "$(P):COLC")
{
  field(DESC, "Close Gripper")
  field(INPA, "$(P):ROBOT_OP_0_BITS")
  field(INPB, "$(P):ROBOT_OP_0_BITS.B8")
  field(INPC, "$(P):ROBOT_OP_0_BITS.B9")
  field(CALC, "(A XOR ((B * 256) + (C * 512)))")
  field(OUT,  "$(P):WRITE_OP PP")
}

record(ao, "$(P):WRITE_OP")
{
  field(DESC, "Force Robot Output State")
  field(DTYP, "stream")
  field(VAL,  "0")
  field(OUT,  "@robotPLC.proto writeOutput($(P)) $(STREAMS_PORT,undefined)")
}


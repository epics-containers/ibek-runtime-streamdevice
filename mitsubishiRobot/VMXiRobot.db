### Port Transition ###

record(scalcout, "$(P):PORT_TRANSITION_CALC_4")
{
  field(DESC, "Port in transition state")
  field(INAA, "BL02I-EA-FMLTX-01:AUTOMATION_PORT_STATUS PP")
  field(BB,   "Ejecting")
  field(CC,   "Retracting")
  field(DD,   "Securing")
  field(CALC, "((AA==BB)||(AA==CC)||(AA==DD))?1:0")
}

### Port Open ###

record(scalcout, "$(P):PORT_FULLY_OPEN_CALC_4") 
{
  field(DESC, "Port fully open")
  field(INAA, "BL02I-EA-FMLTX-01:AUTOMATION_PORT_STATUS PP")
  field(BB,   "Ejected")
  field(CALC, "(AA==BB)?1:0")
}

#### Port Closed ####

record(calc, "$(P):PORT_FULLY_CLOSED_CALC_4") 
{
  field(DESC, "Port fully closed")
  field(INPA, "$(P):PORT_TRANSITION_CALC_4 CP")
  field(INPB, "$(P):PORT_FULLY_OPEN_CALC_4 CP")
  field(CALC, "A==1||B==1?0:1")
} 

### Final M_AutoOpen calculation###

record(calc, "$(P):PORT_CALC_FINAL_4")
{
  field(DESC, "Open and trnasition state")
  field(INPA, "$(P):PORT_TRANSITION_CALC_4 PP")
  field(INPB, "$(P):PORT_FULLY_OPEN_CALC_4 PP")
  field(CALC, "(-1*A) + (B)") 
  field(SCAN, ".1 second")
}

# Check if force on or force off is on (both for AUTO_OPEN and AUTO_CLOSE).
# If yes, ignore PORT_CALC_FINA (A) and use the value of FORCE OPEN ON (B) 
# or FORCE CLOSE OFF.
# Notice that CLOSE OFF is same as OPEN ON. 

record(calcout, "$(P):PORT_OUT_FINAL_4")
{
  field(DESC, "AutoOpen to robot var")
  field(INPA, "$(P):PORT_CALC_FINAL_4 CP")
  field(INPB, "$(P):OP_AUTO_OPEN_FORCE_ON_4.RVAL CP")
  field(INPC, "$(P):OP_AUTO_OPEN_FORCE_OFF_4.RVAL CP")
  field(INPD, "$(P):OP_AUTO_CLOSE_FORCE_ON_4.RVAL CP")
  field(INPE, "$(P):OP_AUTO_CLOSE_FORCE_OFF_4.RVAL CP") #close off is same as open on
  field(CALC, "(!(B+C+D+E)*A)+(B)+(E)" )
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto writeVariable($(P),M_AutoOpen4) $(STREAMS_PORT,undefined)")
  field(PINI, "YES")
}

record(dfanout, "BL02I-MO-ROBOT-03:LOAD")
{
  field(DESC, "LOAD Program Splitter")
  field(VAL,  "1")
  field(OUTA, "$(P):LOAD.PROC PP")
  field(OUTB, "BL02I-MO-ROBOT-02:ADD.PROC PP")
  field(OMSL, "closed_loop")
}


record(dfanout, "BL02I-MO-ROBOT-03:UNLD")
{
  field(DESC, "UNLD Program Splitter")
  field(VAL,  "1")
  field(OUTA, "$(P):UNLD.PROC PP")
  field(OUTB, "BL02I-MO-ROBOT-02:REMOVE.PROC PP")
  field(OMSL, "closed_loop")
}


record(calc, "BL02I-MO-ROBOT-03:PROGRAM_RUNNING")
{
  field(DESC, "Program Running Both Robots")
  field(INPA, "$(P):PROGRAM_RUNNING CP")
  field(INPB, "BL02I-MO-ROBOT-02:CURRENT_JOB CP")
  field(CALC, "(A|B)?1:0")
}

record(calc, "BL02I-MO-ROBOT-03:ERROR_STATE")
{
  field(DESC, "Error State Both Robots")
  field(INPA, "$(P):PRG_ERR_CODE CP")
  field(INPB, "$(P):RUN_ERR_CODE CP")
  field(INPC, "$(P):CNTL_ERR_CODE CP")
  field(INPD, "BL02I-MO-ROBOT-02:SEQ_ERROR_VAL CP")
  field(CALC, "(A|B|C|D)")
}


# Checks whether the sample position demands and
# readbacks match before running a program which
# uses the values.

# If values match, then it calls the appropriate
# program via the PROGRAM_SELECTION record.
# If values don't match, causes report of an
# error message (and the program doesn't run)

# PUCK_CHECK and PIN_CHECK are macros that are
# passed in from mitsubishi.substituions file
# They indicate whether the code should check
# whether there is a mismatch between the puck
# and pin demands and their readbacks
# 1 = Do the check, 0 = Don't do the check

record(sseq, "$(P):LOAD_SEQ")
{
  field(DESC,  "Trigger the LOAD Program")
  field(WAIT1, "Wait")
  field(DOL1,  "1")
  field(LNK1,  "$(P):LOAD_TIMEOUT CA")
}

record(bo, "$(P):LOAD_TIMEOUT")
{
  field(DESC, "Pause to Allow for Variable Write")
  field(HIGH, ".5")
}

record(calcout, "$(P):LOAD_TIMEOUT_CHECK")
{
  field(DESC, "Detect Wait Period Finished")
  field(INPA, "$(P):LOAD_TIMEOUT.RVAL CP")
  field(CALC, "A")
  field(OOPT, "Transition To Zero")
  field(OVAL, "1")
  field(DOPT, "Use OCAL")
  field(OUT,  "$(P):LOAD_CHECK_1.PROC")
}

record(calcout, "$(P):LOAD_CHECK_1")
{
  field(DESC, "Pin or Puck Variable Mismatch")
  field(INPA, "$(P):NEXT_HOTEL_RBV")
  field(INPB, "$(P):NEXT_HOTEL")
  field(INPC, "$(P):_RBV")
  field(INPD, "$(P):")
  field(CALC, "(((A-B)*1)^2)+(((C-D)*0)^2)")
  field(OUT,  "$(P):LOAD_CHECK_1_CALC.A PP")
}

record(calcout, "$(P):LOAD_CHECK_1_CALC")
{
  field(DESC, "Calculate Result of Pin & Puck Check")
  field(INPA, "$(P):LOAD_CHECK_1")
  field(CALC, "(A=0)?0:1")
  field(OUT,  "$(P):LOAD_CHECK_1_RESULT PP")
}

record(bi, "$(P):LOAD_CHECK_1_RESULT")
{
  field(DESC, "Result of Pin & Puck Check")
  field(ZNAM, "Pass")
  field(ONAM, "Fail")
  field(FLNK, "$(P):LOAD_CHECK")
}

record(calcout, "$(P):LOAD_CHECK")
{
  field(DESC, "Result of All Mismatch Checks")
  field(INPA, "$(P):LOAD_CHECK_1_RESULT")
  field(CALC, "A")  
  field(OOPT, "When Zero")
  field(DOPT, "Use OCAL")
  field(OCAL, "1")
  field(OUT,  "$(P):PROGRAM_SELECTION PP")
  field(FLNK, "$(P):VAR_MATCH_CHECK")
}



# Corresponding edm screen: WatchWindow.edl

###################################################

# Record to hold name of PV to be watched
# Used by VAR_1_REQ to request the
# named variable

record(stringout, "$(P):VAR_1")
{
  field(DESC, "Variable 1 Name")
}

# Value of the specified watched PV
# This record is populated from the reply
# to a command in the protocol file

record(stringin, "$(P):VAR_1_RBV")
{
  field(DESC, "Variable 1 Readback")
}

# Record to request named variable.
# Scan rate is Passive upon boot
# but is changed to 0.2 scan rate by
# record below if a valid variable is
# entered

record(stringout, "$(P):VAR_1_REQ")
{
  field(DESC, "Watch Variable")
  field(OMSL, "closed_loop")
  field(DOL,  "$(P):VAR_1 PP")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto watchVariable($(P),1) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):VARS_POLL.RVAL CP")
  field(SCAN, "Passive")
}

# If no variable is entered or the variable
# is invalid, don't watch (ie scan Passive), otherwise
# watch at 0.2 second scan rate

record(scalcout, "$(P):VAR_1_CALC")
{
  field(DESC, "Only Scan Valid Variables")
  field(INAA, "$(P):VAR_1 CP")
  field(INPA, "$(P):VAR_1_REQ.SEVR CP")
  field(INPB, "$(P):RESET CP")
  field(CALC, "(AA=='' || A==3)?'Passive':'.2 second'")
  field(OUT,  "$(P):VAR_1_REQ.SCAN PP")
}

# If a variable name returns mismatch (ie it's invalid)
# then set this record high (to be used by GUI)
# If the mismatch is for a blank variable name
# (can happen for a second) when a name is cleared)
# then don't mark as invalid

record(scalcout, "$(P):VAR_1_INVALID")
{
  field(DESC, "Check for Invalid Variable Name")
  field(INAA, "$(P):VAR_1 CP")
  field(INPA, "$(P):VAR_1_REQ.SEVR CP")
  field(CALC, "(AA=='' && A == 3)?0:A")
}

# Clear a variable name

record(stringout, "$(P):VAR_1_CLR")
{
  field(DESC, "Clear Variable 1")
  field(VAL,  "")
  field(OUT,  "$(P):VAR_1 PP")
}

# Clear a variable's readback
# when the variable name is cleared
# The second condition is to capture the
# situation where the variable name is cleared
# but the readback arrives a split second later
# and so wouldn't be cleared by the first condition

record(scalcout, "$(P):VAR_1_RBV_CLR")
{
  field(DESC, "Clear Variable 1 Readback")
  field(INAA, "$(P):VAR_1 CP")
  field(INBB, "$(P):VAR_1_RBV CP")
  field(CALC, "(AA==''||(AA==''&&BB!=''))?1:0")
  field(OOPT, "When Non-zero")
  field(DOPT, "Use OCAL")
  field(OCAL, "''")
  field(OUT,  "$(P):VAR_1_RBV PP")
}




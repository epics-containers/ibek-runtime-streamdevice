######################################################################

# VAR_MATCH_CHECK processing is triggered
# by the FLNK of LOAD_CHECK (from the Sequence.template)
# and checks the result of the LOAD_CHECK sequence record.
# If LOAD_CHECK spotted a mismatch between the pin or puck 
# numbers a non-zero error is generated which triggers 
# VAR_MATCH_CHECK to send error code 700 to the SET_ERROR 
# record to send the error to the M_AERR robot variable 

record(calcout, "$(P):VAR_MATCH_CHECK")
{
  field(DESC, "Report Variable Mismatch")
  field(INPA, "$(P):LOAD_CHECK")
  field(CALC, "A")
  field(OOPT, "When Non-zero")
  field(DOPT, "Use OCAL")
  field(OCAL, "700")
  field(OUT,  "$(P):SET_ERROR PP")
}

record(ao, "$(P):SET_ERROR")
{
  field(DESC, "Set Program Error Code")
  field(DTYP, "stream")
  field(VAL,  "700")
  field(OUT,  "@robotPLC.proto writeVariable($(P),M_AERR) $(STREAMS_PORT,undefined)")
}




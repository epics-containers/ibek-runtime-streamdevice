# If yes, ignore PLATE_ON_HAND (A) and use the value of FORCE ON (B). 
record(calcout, "$(P):PLATE_ON_HAND_OUT_4") 
{
  field(DESC, "PLATE PRESENT to robot var")
  field(INPA, "BL02I-EA-FMLTX-01:PLATE_ON_HAND PP")
  field(INPB, "$(P):OP_PLATE_PRESENT_FORCE_ON_4 CP")
  field(INPC, "$(P):OP_PLATE_PRESENT_FORCE_OFF_4 CP")
  field(CALC, "(!(C||B) && A) || B>0 ")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto writeVariable($(P),M_PlatePresent4) $(STREAMS_PORT,undefined)")
  field(SCAN, ".1 second")
}

record(ao, "$(P):PLATE_ON_HAND_INIT_4") 
{
  field(VAL,  "0")
  field(DTYP, "stream")
  field(OUT,  "@robotPLC.proto writeVariable($(P),M_PlatePresent4) $(STREAMS_PORT,undefined)")
  field(PINI, "YES")
}

### AutoOpen Force On/Off ####

record(mbbo, "$(P):OP_AUTO_OPEN_FORCE_OPTION_4")
{
  field(DESC, "Force Option AutoOpen")
  field(ZRVL, "1")
  field(ONVL, "2")
  field(TWVL, "3")
  field(ZRST, "On")
  field(ONST, "No")
  field(TWST, "Off")
  field(VAL,  "1")
  field(PINI, "YES")
}

record(dfanout, "$(P):OP_AUTO_OPEN_FORCE_SEL_4")
{
  field(DESC, "Force On/Off Selection")
  field(SELM, "Specified")
  field(SELL, "$(P):OP_AUTO_OPEN_FORCE_OPTION_4.RVAL CP")
  field(VAL,  "1")
  field(OUTA, "$(P):OP_AUTO_OPEN_FORCE_ON_4 CA")
  field(OUTB, "$(P):OP_AUTO_OPEN_NORMAL_FAN_4.PROC CA")
  field(OUTC, "$(P):OP_AUTO_OPEN_FORCE_OFF_4 CA")
}

record(dfanout, "$(P):OP_AUTO_OPEN_NORMAL_FAN_4")
{
  field(DESC, "Unforce AutoOpen")
  field(SELM, "All")
  field(VAL,  "0")
  field(OUTA, "$(P):OP_AUTO_OPEN_FORCE_ON_4 CA")
  field(OUTB, "$(P):OP_AUTO_OPEN_FORCE_OFF_4 CA")
}

record(mbbo, "$(P):OP_AUTO_OPEN_FORCE_ON_4")
{
  field(DESC, "Force On AutoOpen")
  field(ZRVL, "0")
  field(ONVL, "1")
  field(ZRST, "No")
  field(ONST, "Yes")
}

record(mbbo, "$(P):OP_AUTO_OPEN_FORCE_OFF_4")
{
  field(DESC, "Force Off AutoOpen")
  field(ZRVL, "0")
  field(ONVL, "1")
  field(ZRST, "No")
  field(ONST, "Yes")
}

record(ai, "$(P):AUTO_OPEN_4")
{
  field(DESC, "AutoOpen from robot var")
  field(DTYP, "stream")
  field(SCAN, "1 second")
  field(INP,  "@robotPLC.proto readVariable(M_AutoOpen4) $(STREAMS_PORT,undefined) CP")
}


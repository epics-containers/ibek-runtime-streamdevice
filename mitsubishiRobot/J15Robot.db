}

# The position is updated when the readback is refreshed

record(calcout, "$(P):F2_REFRESH")
{
  field(DESC, "Update F2 with Readback")
  field(INPA, "$(P):F2_RBV CP")
  field(CALC, "A")
  field(OUT,  "$(P):F2 PP")
}

record(ai, "$(P):F2")
{
  field(DESC, "F2 Position")
  field(VAL,  "0")
  field(PINI, "YES")
  field(SDIS, "$(P):EDIT_MODE")
}



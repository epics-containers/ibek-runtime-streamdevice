record(mbbi, "$(P):ROBOT_IP_0")
{
  field(DESC, "Robot Inputs 0-15")
  field(ZRVL, "0")
  field(ONVL, "1")
  field(TWVL, "2")
  field(THVL, "3")
  field(FRVL, "4")
  field(FVVL, "5")
  field(SXVL, "6")
  field(SVVL, "7")
  field(EIVL, "8")
  field(NIVL, "9")
  field(TEVL, "10")
  field(ELVL, "11")
  field(TVVL, "12")
  field(TTVL, "13")
  field(FTVL, "14")
  field(FFVL, "15")
  field(ZRST, "?Stop (All Slots)")
  field(ONST, "?Servo Off")
  field(TWST, "?Error Reset")
  field(THST, "?Start")
  field(FRST, "?Servo On")
  field(FVST, "?Operation Rights")
  field(SXST, "")
  field(SVST, "")
  field(EIST, "")
  field(NIST, "?Light Gate Interrupted")
  field(TEST, "")
  field(ELST, "?")
  field(TVST, "")
  field(TTST, "")
  field(FTST, "")
  field(FFST, "?")
}

record(mbbiDirect, "$(P):ROBOT_IP_0_BITS")
{
  field(DESC, "Robot Inputs 0-15 in Bits")
  field(DTYP, "Soft Channel")
  field(INP,  "$(P):ROBOT_IP_0 CP")
  field(NOBT, "16")
}



################ Robot Inputs & Outputs ################

record(mbbi, "$(P):ROBOT_IP_16")

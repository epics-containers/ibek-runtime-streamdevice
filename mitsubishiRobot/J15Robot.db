

# % gui, , edm, J15Robot.edl, P=$(P)

#################### Program Control ###################

record(ao, "$(P):SON")
{
  field(DESC, "Servo on")
  field(DTYP, "stream")
  field(OUT,  "@J15robot.proto servoOn($(P)) $(STREAMS_PORT,undefined)")
  field(MDEL, "-1")
}

record(ao, "$(P):SOFF")
{
  field(DESC, "Abort the Current Program")
  field(DTYP, "stream")
  field(OUT,  "@J15robot.proto servoOff($(P)) $(STREAMS_PORT,undefined)")
  field(MDEL, "-1")
  field(FLNK, "$(P):ABORT_MSG")
}

record(stringout, "$(P):ABORT_MSG")
{
  field(DESC, "Abort Message")
  field(VAL,  "Stop button pressed")
  field(OUT,  "$(P):LOGGING.D PP")
}

#################### Programs #####################

record(stringout, "$(P):RUN_PROGRAM")
{
  field(DESC, "Run Program")
  field(DTYP, "stream")
  field(OUT,  "@J15robot.proto runProgram($(P)) $(STREAMS_PORT,undefined)")
}

record(stringout, "$(P):LOAD_PROGRAM")
{
  field(DESC, "Load Program")
  field(DTYP, "stream")
  field(OUT,  "@J15robot.proto loadProgramToSlot($(P)) $(STREAMS_PORT,undefined)")
}


record(stringout, "$(P):RUN_ERROR_CODE")
{
  field(DESC, "runProgram error code")
  field(VAL,  "")
}

################### Program Status ###################

# All of the following records in this section
# are populated as a result of the protocol file
# response to the GET_STATE request below

record(ai, "$(P):GET_STATE")
{
  field(DESC, "Robot Program Status")
  field(DTYP, "stream")
  field(SCAN, "1 second")
  field(INP,  "@J15robot.proto getState($(P)) $(STREAMS_PORT,undefined)")
  field(SDIS, "$(P):STATUS_POLL.RVAL CP")
}

record(stringin, "$(P):PROGRAM_NAME")
{
  field(DESC, "Currently Running Program Name")
}

# Request the currently executed program line
record(ao, "$(P):LINE_NUMBER")
{
  field(DESC, "Current Program Line Number")
  field(DTYP, "stream")
  field(OUT,  "@J15robot.proto currentLine($(P)) $(STREAMS_PORT,undefined)")
}

# Display the returned error number

# This record is populated as a result 
# of the protocol file response to the 
# above LINE_NUMBER request
record(waveform, "$(P):LINE_CONTENTS")
{
  field(DESC, "Current Line Contents")
  field(NELM, "255")
  field(FTVL, "STRING")
}

record(ai, "$(P):EDIT_STATUS")
{
  field(DESC, "Edit Status")
}

record(ai, "$(P):STEP_NUMBER")
{
  field(DESC, "Execution Step Number")
}

record(ai, "$(P):MECH_INFO")
{
  field(DESC, "Mech Info")
}

record(stringin, "$(P):TASK_NAME")
{
  field(DESC, "Current Task Name")
}

record(mbbi, "$(P):TASK_MODE")
{
  field(DESC, "Operation Mode of Slot Table")
  field(DTYP, "Soft Channel")
  field(ZRST, "REP")
  field(ZRVL, "0")
  field(ONST, "CYC")
  field(ONVL, "1")
}

record(mbbi, "$(P):TASK_CONDITION")
{
  field(DESC, "Operation Mode of Slot Table")
  field(DTYP, "Soft Channel")
  field(ZRST, "START")
  field(ZRVL, "0")
  field(ONST, "ALWAYS")
  field(ONVL, "1")
  field(TWST, "ERROR")
  field(TWVL, "2")
}

record(ai, "$(P):TASK_PRIORITY")
{
  field(DESC, "Priority of Slot Table")
}

record(ai, "$(P):MECH_NUM_IN_USE")
{
  field(DESC, "Mech Number In Use")
}

################ Convenience Statuses ###################

# These records are used to give nice PV names to 
# individual status bits (rather than have nameless
# B1, B4, PVs etc)  This is done for PVs which are
# used by GDA or regularly by the user

record(bi, "$(P):TEACH_MODE")
{
  field(DESC, "Teach Mode State")
  field(INP,  "$(P):RUN_STATUS.B3 CP")
  field(ZNAM, "Exec Mode")
  field(ONAM, "Teach Mode")
}

record(bi, "$(P):SERVO_ON")
{
  field(DESC, "Servo State")
  field(INP,  "$(P):RUN_STATUS.B5 CP")
  field(ZNAM, "Servo Off")
  field(ONAM, "Servo On")
}

record(bi, "$(P):PROGRAM_RUNNING")
{
  field(DESC, "Program Running State")
  field(INP,  "$(P):RUN_STATUS.B6 CP")
  field(ZNAM, "No Program Running")
  field(ONAM, "Program Running")
}

record(bi, "$(P):CONTROL_STATE")
{
  field(DESC, "Control State")
  field(INP,  "$(P):RUN_STATUS.B7 CP")
  field(ZNAM, "Control Off")
  field(ONAM, "Control On")
}

record(bi, "$(P):PROGRAM_SELECT")
{
  field(DESC, "Program Select State")
  field(INP,  "$(P):STOP_STATUS.B4 CP")
  field(ZNAM, "Program Select Disabled")
  field(ONAM, "Program Select Enabled")
}

record(bi, "$(P):SPINNER_STATE")
{
  field(DESC, "Spinner State")
  field(INP,  "$(P):ROBOT_OP_0_BITS.BB CP")
  field(ZNAM, "Spinner Off")
  field(ONAM, "Spinner On")
}

############### Visibility / Ready PVs #################

# These records are used by the GUI or by SDIS
# fields of other records to determine that certain
# conditions are met before allowing something
# to be controlled or to be visible on the GUI

record(calcout, "$(P):PROGRAM_READY")
{
  field(DESC, "Program Ready State")
  field(INPA, "$(P):PROGRAM_RUNNING CP")
  field(INPB, "$(P):CONTROL_STATE CP")
  field(CALC, "(A|!B)?1:0")
}

############################################################

record(genSub, "$(P):LOGGING")
{
  field(SNAM, "Logging")
  field(INPA, "$(P):RUN_PROGRAM.VAL CP")
  field(FTA,  "STRING")
  field(FTD,  "STRING")
}

######################## Resets ##############################

# Pressing the reset button on the main GUI triggers
# a chain of reset events:

# 1) Reset of alarm state
# 2) Enabling control
# 3) Reset of program
# 4) Reset of program error code to zero
# 5) Reset of run error code to zero
# 6) Reset of the top level program variable to zero
######################## Resets ##############################

# Pressing the reset button on the main GUI triggers
# a chain of reset events:

# 1) Reset of alarm state
# 2) Enabling control
# 3) Reset of program
# 4) Reset of program error code to zero
# 5) Reset of run error code to zero
# 6) Reset of the top level program variable to zero

# This is achieved through a mixture of forward links
# and return statements from the protocol file

record(ai, "$(P):RESET")
{
  field(DESC, "Reset Robot State")
  field(DTYP, "stream")
  field(INP,  "@J15robot.proto openComms($(P)) $(STREAMS_PORT,undefined)")
  field(MDEL, "-1")
  field(FLNK, "$(P):RESET_ALARM")
}

record(ai, "$(P):RESET_ALARM")
{
  field(DESC, "Reset Robot Alarm")
  field(DTYP, "stream")
  field(INP,  "@J15robot.proto resetAlarm($(P)) $(STREAMS_PORT,undefined)")
  field(MDEL, "-1")
  field(FLNK, "$(P):RESET_CONTROL_ON")
}

record(stringout, "$(P):RESET_MSG")
{
  field(DESC, "Reset Message")
  field(VAL,  "Reset button pressed")
  field(OUT,  "$(P):LOGGING.D PP")
}

record(ao, "$(P):RESET_CONTROL_ON")
{
  field(DESC, "Turn Control On")
  field(DTYP, "stream")
  field(OUT,  "@J15robot.proto controlOn($(P)) $(STREAMS_PORT,undefined)")
  field(FLNK, "$(P):RESET_PROGRAM")
  field(PINI, "1")
}

record(ao, "$(P):RESET_PROGRAM")
{
  field(DESC, "Reset Program")
  field(DTYP, "stream")
  field(OUT,  "@J15robot.proto resetProgram($(P)) $(STREAMS_PORT,undefined)")
}

# The reset value of 0 is actually sent to this record
# by the protocol file during a reset procedure
# This is to avoid the error code value being 
# overwritten upon startup by the streamDevice init
# command reading a previous error code in
record(ao, "$(P):RESET_ERROR_CODE")
{
  field(DESC, "Reset Program Error Code")
  field(VAL,  "0")
  field(FLNK, "$(P):RESET_RUN_ERR")
}

record(ao, "$(P):RESET_RUN_ERR")
{
  field(DESC, "Reset Program")
  field(VAL,  "0")
  field(OUT,  "$(P):RUN_ERR_CODE PP")
  field(FLNK, "$(P):TOPPRG_ZERO")
}

# Triggered whenever a run command is sent
# Request the message associated with an error number
record(ao, "$(P):RUN_ERR_CODE")
{
  field(DESC, "Run Command Error Code")
  field(DTYP, "stream")
  field(OUT,  "@J15robot.proto runErrorMessage($(P)) $(STREAMS_PORT,undefined)")
}

# Display the returned error message
record(waveform, "$(P):RUN_ERR_RET")
{
  field(DESC, "Returned Run Error Message")
  field(NELM, "255")
  field(FTVL, "STRING")
}

record(genSub, "$(P):RUN_ERR_LOOKUP")
{
  field(SNAM, "CmdErrorLookup")
  field(INPA, "$(P):RUN_ERR_CODE NP")
  field(INPB, "$(P):RUN_ERR_RET CP")
  field(INPC, "$(P):RUN_ERR_MSG NP")
  field(FTA,  "LONG")
  field(FTB,  "STRING")
  field(FTC,  "STRING")
  field(FTVA, "CHAR")
  field(NOVA, "255")
  field(OUTA, "$(P):RUN_ERR_MSG PP")
}

record(waveform, "$(P):RUN_ERR_MSG")
{
  field(DESC, "Run Error Message")
  field(NELM, "255")
  field(FTVL, "CHAR")
}

record(ao, "$(P):CNTL_ERR_CODE")
{
  field(DESC, "Controller Error Code")
  field(DTYP, "stream")
  field(OUT,  "@J15robot.proto errorMessage($(P)) $(STREAMS_PORT,undefined)")
}

record(waveform, "$(P):CNTL_ERR_RET")
{
  field(DESC, "Returned Controller Error Message")
  field(NELM, "255")
  field(FTVL, "STRING")
}

record(scalcout, "$(P):CNTL_MSG_CHECK")
{
  field(DESC, "Check for Non-Blank Error Message")
  field(CALC, "(A>0)?AA:''")
  field(INPA, "$(P):CNTL_ERR_CODE CP")
  field(INAA, "$(P):CNTL_ERR_RET")
  field(OUT,  "$(P):CNTL_ERR_MSG PP")
}

record(waveform, "$(P):CNTL_ERR_MSG")
{
  field(DESC, "Controller Error Message")
  field(NELM, "255")
  field(FTVL, "STRING")
}

record(genSub, "$(P):LOG_CNTL_ERROR")
{
  field(SNAM, "LogError")
  field(INPA, "$(P):CNTL_ERR_MSG CP")
  field(INPB, "$(P):CNTL_ERR_CODE PP")
  field(FTA,  "STRING")
  field(FTB,  "STRING")
}

record(ai, "$(P):GET_ERROR_2")
{
  field(DTYP, "stream")
  field(INP,  "@J15robot.proto readErrors($(P)) $(STREAMS_PORT,undefined)")

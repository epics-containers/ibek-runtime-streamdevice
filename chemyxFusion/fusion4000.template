# Pump control
################################################################


record(bo, "$(P)$(R):P1:START_BASIC")
{
  field(DESC, "Start pump")
  field(DTYP, "stream")
  field(ZNAM, "0")
  field(ONAM, "1")
  field(OUT, "@fusion4000.proto start(1,0) $(PORT)")
}


# % macro, P,      PV name prefix
# % macro, R,      PV name suffix
# % macro, PORT,   asyn port
# % macro, name,   module name

# % gui, $(name=), edm, fusion4000.edl, P=$(P),R=$(R)


################################################################
# Generic Asyn record.
################################################################

record(asyn, "$(P)$(R):ASYN") {
  field(DTYP,"asynRecordDevice")
  field(PORT, "$(PORT)")
  field(ADDR,"0")
  field(OMAX,"1024")
  field(IMAX,"1024")
}


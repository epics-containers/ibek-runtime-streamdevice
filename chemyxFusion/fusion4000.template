record(mbbi, "$(P)$(R):P1:STATUS")
{
  field(DESC, "get pump status")
  field(DTYP, "stream")
  field(SCAN, "1 second")
  field(INP, "@fusion4000.proto getStatus(1) $(PORT)")
  field(ZRST, "stopped")       field(ZRVL, "0")
  field(ONST, "running")       field(ONVL, "1")
  field(TWST, "paused")        field(TWVL, "2")
  field(THST, "delayed")       field(THVL, "3")
  field(FRST, "stalled")       field(FRVL, "4")
}


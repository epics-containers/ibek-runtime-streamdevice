################################################################

# /// Pocket Label
#% autosave 1 VAL
record(stringout, "$(P):2:LABEL") {
  field(DESC, "User label for pocket")
}

# /// Regulation Type
record(mbbo, "$(P):2:FILAMENT_REG_TYPE") {
  field(DTYP, "stream")
  field(SDIS, "$(P):DISABLE")
  field(DESC, "Regulation type set")
  field(OUT, "@ebe4.proto setInt(60,$(P):RESPONSE) $(PORT) 0")
  field(ZRVL, "0")
  field(ZRST, "Current")
  field(ONVL, "1")

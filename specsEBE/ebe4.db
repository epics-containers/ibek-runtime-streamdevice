  field(DESC, "Filament flux time base get")
  field(INP, "@ebe4.proto getDouble(101) $(PORT) 0")
  field(SCAN, "$(SCAN) second")
  field(PREC, 2)
}
################################################################
#
# Specs EBE-4 pocket template file.
#
# Macros:
#   P - Prefix for PV name
#   PORT - Bus/Port Address (eg. ASYN Port).
#   SCAN - SCAN rate for read parameters.
#
################################################################

################################################################
# Builder Tags
################################################################

# Macros:
# % macro, P, Device Prefix
# % macro, PORT, Asyn Port name
# % macro, SCAN, Poll rate

################################################################
# Read Only records
################################################################

# /// Emission Regulation Status
#% archiver 10 Monitor
record(mbbi, "$(P):4:EMISSION_REG_STA") {
  field(DTYP, "stream")
  field(SDIS, "$(P):DISABLE")
  field(DESC, "Emission regulation status")
  field(INP, "@ebe4.proto getInt(116) $(PORT) 0")
  field(SCAN, "$(SCAN) second")
  field(ZRVL, "0")
  field(ZRST, "Not in Use")
  field(ONVL, "1")
  field(ONST, "In Progress")
  field(TWVL, "2")
  field(TWST, "Regulating")
}

# /// Flux Regulation Status
#% archiver 10 Monitor
record(mbbi, "$(P):4:FLUX_REG_STA") {
  field(DTYP, "stream")
  field(SDIS, "$(P):DISABLE")
  field(DESC, "Flux regulation status")
  field(INP, "@ebe4.proto getInt(124) $(PORT) 0")
  field(SCAN, "$(SCAN) second")
  field(ZRVL, "0")
  field(ZRST, "Not in Use")
  field(ONVL, "1")
  field(ONST, "In Progress")
  field(TWVL, "2")
  field(TWST, "Regulating")
}

################################################################
# Read/Write records
################################################################

# /// Pocket Label
#% autosave 1 VAL
record(stringout, "$(P):4:LABEL") {
  field(DESC, "User label for pocket")
}

# /// Regulation Type
record(mbbo, "$(P):4:FILAMENT_REG_TYPE") {
  field(DTYP, "stream")
  field(SDIS, "$(P):DISABLE")
  field(DESC, "Regulation type set")
  field(OUT, "@ebe4.proto setInt(112,$(P):RESPONSE) $(PORT) 0")
  field(ZRVL, "0")
  field(ZRST, "Current")
  field(ONVL, "1")
  field(ONST, "Emission")
  field(TWVL, "2")
  field(TWST, "Flux")
}
#% archiver 10 Monitor
record(mbbi, "$(P):4:FILAMENT_REG_TYPE_RBV") {
  field(DTYP, "stream")
  field(SDIS, "$(P):DISABLE")
  field(DESC, "Regulation type get")
  field(INP, "@ebe4.proto getInt(112) $(PORT) 0")
  field(SCAN, "$(SCAN) second")
  field(ZRVL, "0")
  field(ZRST, "Current")
  field(ONVL, "1")
  field(ONST, "Emission")
  field(TWVL, "2")
  field(TWST, "Flux")
}


  field(PINI, "NO")
  field(SCAN, "Passive")
  field(VAL, "264")
}
###################################################################################
# Start of support/laserPuckPointer/laserPuckPointerApp/Db/iSpyBWrite.template
# Original Author: Lee Hudson 2017
# 
# Runs a python script that writes the selected puck into or out of the
# ISpyB databas
# For this to work the following support modules need to be at least
# the following versions:
#
# mitsubishiRobot     2-6
# FQCRBarcodeCamera   1-2
#
# % macro, p, Prefix
# % macro, s, Suffix
# % macro, positionPV, Parent PV (BL03I-MO-ROBOT-01:PUCK_POSITION not BL03I-MO-ROBOT-01:PUCK_POSITION.A) where the last loaded / unloaded puck position will be
# % macro, bl, Beamline (used as arg in python script)
# % macro, robot, Prefix for the robot where the barcodes are stored
# % macro, version, Version used of this support module

record(aSub, "$(P):ISPYB_WRITE") {
  field(SNAM, "isbWrite")
  field(INPA, "$(P):DBDOM")
  field(INPB, "$(P):POSITION_READ CP")
  field(INPC, "$(P):INIT_ISPYB_WRITE")
  field(INPD, "$(ROBOT):FQCR_CAM:BARCODE_STORE")
  field(INPE, "$(P):ISPYB_WRITE_ENABLE")
  field(INPF, "$(P):ISPYB_DEBUG_ENABLE")
  field(INPG, "$(P):LPP_VERS")
  field(INPH, "$(P):BASE_PV")
  field(FTA, "STRING")
  field(FTB, "USHORT")
  field(FTC, "USHORT")
  field(FTD, "STRING")
  field(FTE, "USHORT")
  field(FTF, "USHORT")
  field(FTG, "STRING")
  field(FTH, "STRING")
  field(OUTA, "$(P):INIT_ISPYB_WRITE PP")
  field(FTVA, "USHORT")
  field(SCAN, "Passive")
  field(PINI, "NO")
}

record(stringin, $(P):DBDOM) {
  field(VAL, "$(BL)")
}

record(stringin, $(P):LPP_VERS) {
  field(VAL, "$(VERS)")
}

# PV to store the base of the PVs used in this template.
# This is used by the $(P):ISPYB_WRITE asub record to
# tell the assignPuck.py script what the name of the PV
# for displaying the auto collect flag will be.
record(stringin, $(P):BASE_PV) {
  field(VAL, "$(P)")
}

record(bo, $(P):INIT_ISPYB_WRITE) {
  field(VAL, "0")
}

#% autosave 1 VAL
record(ai, $(P):ISPYB_WRITE_ENABLE) {
}

#% autosave 1 VAL
record(ai, $(P):ISPYB_DEBUG_ENABLE) {
}

record(calc, $(P):POSITION_READ) {
  field(INPA, "$(DEMAND_IN) CP")
  field(INPB, "$(DEMAND_IN).A")
  field(CALC, "B")
  field(MDEL, "-1")

}


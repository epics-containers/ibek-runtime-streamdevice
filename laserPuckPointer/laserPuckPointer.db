#File: 	decoding.template
#Desc:Takes a demand input 1-64 and converts it into 4x16bit BCD values to
#command moves to pucks
record(aSub, "$(P):DEMAND_DECODE") {
  field(SNAM, "sendPuckDemand")
  field(INPA, "$(P):DEMAND CP")
  field(FTA, "LONG")
  field(OUTA, "$(P):PUCK_DEMAND:BANK01.VAL PP")
  field(OUTB, "$(P):PUCK_DEMAND:BANK02.VAL PP")
  field(OUTC, "$(P):PUCK_DEMAND:BANK03.VAL PP")
  field(OUTD, "$(P):PUCK_DEMAND:BANK04.VAL PP")
  field(FTVA, "USHORT")
  field(FTVB, "USHORT")
  field(FTVC, "USHORT")
  field(FTVD, "USHORT")
}

record(ai, "$(P):DEMAND") {
  field(PINI, "YES")
  field(VAL, "0")
  field(MDEL, "-1")
}

record(calcout, "$(P):DEMAND_FROM_VISION_SYSTEM") {
  field(INPA, "$(DEMAND_IN) CP")
  field(INPB, "$(DEMAND_IN).A")
  field(CALC, "B")
  field(OUT, "$(P):DEMAND PP")
  field(OOPT, "Every Time")
  field(MDEL, "-1")
}




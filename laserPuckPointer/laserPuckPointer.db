#File: 	manualControl.template
#Desc:	Allows direct control of Pan, Tilt, Mode and laser.
# % gui, $(name,undefined), edm, manualControl.edl, P=$(P)
record(ai, $(P):PAN_POSITION_RBV) {
  field(DESC, "Laser puck pointer pan axis readback")
  field(SCAN, "$(SCAN)")
  field(DTYP, "stream")
  field(INP, "@laserPuckPointer.proto get_pan_position() $(PORT)")
  field(PINI, "YES")
}

record(ao, $(P):PAN_POSITION_VAL) {
  field(DESC, "Laser puck pointer pan axis setpoint")
  field(PINI, "YES")
  field(DTYP, "stream")
  field(OUT, "@laserPuckPointer.proto set_pan_position() $(PORT)")
}


record(ai, $(P):TILT_POSITION_RBV) {
  field(DESC, "Laser puck pointer tilt axis readback")
  field(SCAN, "$(SCAN)")
  field(DTYP, "stream")
  field(INP, "@laserPuckPointer.proto get_tilt_position() $(PORT)")
  field(PINI, "YES")
}

record(ao, $(P):TILT_POSITION_VAL) {
  field(DESC, "Laser puck pointer tilt axis setpoint")
  field(PINI, "YES")
  field(DTYP, "stream")
  field(OUT, "@laserPuckPointer.proto set_tilt_position() $(PORT)")
}


record(bi, $(P):MODE_RBV) {
  #field(DESC, "Laser puck pointer operation mode readback")
  field(SCAN, "$(SCAN)")
  field(DTYP, "stream")
  field(INP, "@laserPuckPointer.proto get_mode() $(PORT)")
  field(PINI, "YES")
  field(ZNAM, "Local")
  field(ONAM, "Remote")
}

record(bo, $(P):MODE_VAL) {
  #field(DESC, "Laser puck pointer operation mode setpoint")
  field(PINI, "YES")
  field(DTYP, "stream")
  field(OUT, "@laserPuckPointer.proto set_mode() $(PORT)")
  field(ZNAM, "Local")
  field(ONAM, "Remote")
}

record(bi, $(P):LASER_RBV) {
  field(DESC, "Laser puck pointer laser on/off readback")
  field(SCAN, "$(SCAN)")
  field(DTYP, "stream")
  field(INP, "@laserPuckPointer.proto get_laser_status() $(PORT)")
  field(PINI, "YES")
  field(ZNAM, "Off")
  field(ONAM, "On")
}

# To turn on the laser manually and override the
record(bo, $(P):LASER_VAL_MANUAL) {
  field(DESC, "Laser puck pointer laser on/off setpoint")
  field(PINI, "YES")
  field(DTYP, "stream")
  field(OUT, "@laserPuckPointer.proto set_laser_status() $(PORT)")
  field(ZNAM, "Off")
  field(ONAM, "On")
}
###################################################################################

# File:	autoLaserOn.template
# Desc:	Turn the laser on when either axis is moved, either through a manual move or
# a puck demand
record(calcout, $(P):TRIGGER_LASER_CALC) {
  field(INPA, "$(P):DEMAND CP")
  field(INPB, "$(P):TILT_POSITION_VAL CP")
  field(INPC, "$(P):PAN_POSITION_VAL CP")
  field(OUT, "$(P):LASER_VAL PP")
  field(SCAN, "Passive")
  field(CALC, "1")

}

record(bo, $(P):LASER_VAL) {
  field(DESC, "Laser puck pointer laser on/off setpoint")
  field(PINI, "YES")
  field(DTYP, "stream")
  field(OUT, "@laserPuckPointer.proto set_laser_status() $(PORT)")
  field(ZNAM, "Off")
  field(ONAM, "On")
}
###################################################################################
# File: laserONTimer.template
# Desc: Turns laser ON after set time

# Increments counter if the laser has been turned on
# automatically. Doesn't start counting if LASER_VAL_MANUAL
# was used
record(calcout, $(P):LASER_ON_COUNTER_CALC) {
  field(INPA, "$(P):LASER_ON_TIMER")
  field(INPB, "$(P):LASER_RBV ")
  field(INPC, "$(P):LASER_VAL_MANUAL ")
  field(OUT, "$(P):LASER_ON_TIMER PP")
  field(SCAN, "1 second")
  field(CALC, "B=1&&C=0?A+1:0")

}

record(calcout, $(P):ZERO_LASER_COUNTER) {
  field(INPA, "$(P):DEMAND CP")
  field(INPB, "$(P):TILT_POSITION_VAL CP")
  field(INPC, "$(P):PAN_POSITION_VAL CP")
  field(OUT, "$(P):LASER_ON_TIMER PP")
  field(SCAN, "Passive")
  field(CALC, "0")

}

record(ai, $(P):LASER_ON_TIMER) {
   field(VAL, "0")
}

#% autosave 1 VAL
record(ai, $(P):LASER_ON_TIME_SETPOINT) {
   field(VAL, "5")
   field(PINI, "YES")
}

# Turns laser ON when LASER_ON_TIMER >= LASER_ON_TIME_SETPOINT
record(calcout, $(P):LASER_ON_TIMER_CALC) {
  field(SCAN, "Passive")
  field(INPA, "$(P):LASER_ON_TIMER CP")
  field(INPB, "$(P):LASER_ON_TIME_SETPOINT CP")
  field(OUT, "$(P):LASER_VAL PP")
  field(OOPT, "Transition To Zero")
  field(CALC, "A>=B?0:1")

}

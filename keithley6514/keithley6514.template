record(bi, "$(P)$(R)ResetTimestamp")
{
    field(DESC, "Readback")
    field(DTYP, "stream")
    field(INP,  "@keithley6514.proto cmd(SYST:TIME:RES) $(PORT) $(A)")
}

record(calc, "$(P)$(R)OverRange")
{
    field(SCAN, "Passive")
    field(INPA, "$(P)$(R)Status_RBV")
    field(CALC, "(A&(1<<0))>0")
    field(FLNK, "$(P)$(R)Averaging")

}

record(calc, "$(P)$(R)Averaging")
{
    field(SCAN, "Passive")
    field(INPA, "$(P)$(R)Status_RBV")
    field(CALC, "(A&(1<<1))>0")
    field(FLNK, "$(P)$(R)CALC1Enabled")
}

record(calc, "$(P)$(R)CALC1Enabled")
{
    field(SCAN, "Passive")
    field(INPA, "$(P)$(R)Status_RBV")
    field(CALC, "(A&(1<<2))>0")
    field(FLNK, "$(P)$(R)CALC2Enabled")
}

record(calc, "$(P)$(R)CALC2Enabled")
# Set to 1 if null for CALC2 is enabled.
{
    field(SCAN, "Passive")
    field(INPA, "$(P)$(R)Status_RBV")
    field(CALC, "(A&(1<<3))>0")
    field(FLNK, "$(P)$(R)LimitTestEnabled")
}

record(calc, "$(P)$(R)LimitTestEnabled")
{
    field(SCAN, "Passive")
    field(INPA, "$(P)$(R)Status_RBV")
    field(CALC, "(A&(1<<4))>0")
    field(FLNK, "$(P)$(R)LimTest1Failed")
}

record(calc, "$(P)$(R)LimTest1Failed")
{
    field(SCAN, "Passive")
    field(INPA, "$(P)$(R)Status_RBV")
    field(CALC, "(A&(1<<5))>0")
    field(FLNK, "$(P)$(R)LimTest2Failed")
}

record(calc, "$(P)$(R)LimTest2Failed")
{
    field(SCAN, "Passive")
    field(INPA, "$(P)$(R)Status_RBV")
    field(CALC, "(A&(1<<6))>0")
    field(FLNK, "$(P)$(R)ZchkEnabled")
}

record(calc, "$(P)$(R)ZchkEnabled")
{
    field(SCAN, "Passive")
    field(INPA, "$(P)$(R)Status_RBV")
    field(CALC, "(A&(1<<9))>0")
    field(FLNK, "$(P)$(R)ZcorEnabled")
}

record(calc, "$(P)$(R)ZcorEnabled")
{
    field(SCAN, "Passive")
    field(INPA, "$(P)$(R)Status_RBV")
    field(CALC, "(A&(1<<10))>0")
    field(FLNK, "$(P)$(R)VoltageSelected")
}

record(calc, "$(P)$(R)VoltageSelected")
{
    field(SCAN, "Passive")
    field(INPA, "$(P)$(R)Status_RBV")
    field(CALC, "((A&(1<<7))=0)&&((A&(1<<8))=0)")
    field(FLNK, "$(P)$(R)CurrentSelected")
}

record(calc, "$(P)$(R)CurrentSelected")
{
    field(SCAN, "Passive")
    field(INPA, "$(P)$(R)Status_RBV")
    field(CALC, "((A&(1<<7))>0)&&((A&(1<<8))=0)")
    field(FLNK, "$(P)$(R)ResSelected")
}

record(calc, "$(P)$(R)ResSelected")
{
    field(SCAN, "Passive")
    field(INPA, "$(P)$(R)Status_RBV")
    field(CALC, "((A&(1<<7))=0)&&((A&(1<<8))>0)")
    field(FLNK, "$(P)$(R)ChargeSelected")
}

record(calc, "$(P)$(R)ChargeSelected")
{
    field(SCAN, "Passive")
    field(INPA, "$(P)$(R)Status_RBV")
    field(CALC, "((A&(1<<7))>0)&&((A&(1<<8))>0)")
}


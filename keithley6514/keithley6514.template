# The current measurement range
record(ai, "$(P)$(R)RangeRBV")
{
    field(DESC, "Source voltage readback")
    field(DTYP, "stream")
    field(INP,  "@keithley6514.proto getRange($(P)$(R)FuncRBV) $(PORT) $(A)")
    field(PREC, "1")
    field(FLNK, "$(P)$(R)EGU_RBV")
    #field(PINI, "YES")
}

record(ai, "$(P)$(R)NPLC_RBV")
{
    field(DESC, "Readback")
    field(DTYP, "stream")
    field(INP,  "@keithley6514.proto getNPLC($(P)$(R)FuncRBV) $(PORT) $(A)")
    field(PREC, "6")
    field(PINI, "YES")
    field(FLNK, "$(P)$(R)IntegrationTime_RBV")
}

record(calc, "$(P)$(R)IntegrationTime_RBV")
{
    field(INPA,  "$(P)$(R)NPLC_RBV")
    field(INPB,  "$(P)$(R)FrequencyMode_RBV")
    field(CALC,  "A/B")
    field(EGU,   "s")
    field(PREC,  "6")
}

record(ao, "$(P)$(R)IntegrationTime")
{
    field(FLNK, "$(P)$(R)IntegrationTimeCalc")
}

record(calcout, "$(P)$(R)IntegrationTimeCalc") {
    field(OUT,  "$(P)$(R)NPLC PP")
    field(INPA, "$(P)$(R)IntegrationTime")
    field(INPB,  "$(P)$(R)FrequencyMode_RBV")
    field(CALC,  "A*B")
    field(PREC,  "6")
    field(OOPT,  "Every Time")
}


record(ao, "$(P)$(R)NPLC")
{
    field(SCAN, "Passive")
    field(DESC, "Readback")
    field(DTYP, "stream")
    field(OUT,  "@keithley6514.proto setNPLC($(P)$(R)FuncRBV) $(PORT) $(A)")
    field(PREC, "3")
    field(FLNK, "$(P)$(R)ReadSettings")
}


######### Scan and readout control ######################
#
# Two paths for polling: data poll and settings poll.
#
record(bo, "$(P)$(R)EnaPoll")
{
   field(DESC, "Enable read polling")
   field(ZNAM, "disable")
   field(ONAM, "enable")
   field(VAL, "1")
   #field(PINI, "YES")
}

record(fanout, "$(P)$(R)ReadSettings")
{
   field(DESC, "Process all read fields")
   field(LNK1, "$(P)$(R)FuncRBV")
   field(LNK2, "$(P)$(R)Disp")
   field(LNK3, "$(P)$(R)NPLC_RBV")
   field(LNK4, "$(P)$(R)FrequencyMode_RBV")
   field(LNK5, "$(P)$(R)Zchk_RBV")
   field(LNK6, "$(P)$(R)Zcor_RBV")
   field(SDIS, "$(P)$(R)EnaPoll")
   field(DISV, "0")
   field(PINI, "YES")
}


## Measurement configuration
record(mbbo, "$(P)$(R)Func")
{
    field(DESC, "Measurement function")
    field(DTYP, "stream")
    field(OUT,  "@keithley6514.proto setFunction $(PORT) $(A)")
    field(ZRVL, "0")
    field(ZRST, "Voltage")
    field(ONVL, "1")
    field(ONST, "Current")
    field(TWVL,"2")
    field(TWST,"Resistance")
    field(THVL,"3")
    field(THST,"Charge")
    field(FLNK, "$(P)$(R)ReadSettings")
}
record(mbbi, "$(P)$(R)FuncRBV")
{
    field(DESC, "Measurement function")
    field(DTYP, "stream")
    field(INP,  "@keithley6514.proto getFunction $(PORT) $(A)")
    field(ZRVL, "0")
    field(ZRST, "Voltage")
    field(ONVL, "1")
    field(ONST, "Current")
    field(TWVL,"2")
    field(TWST,"Resistance")
    field(THVL,"3")
    field(THST,"Charge")
    field(FLNK, "$(P)$(R)RangeRBV")
    field(PINI, "YES")
}




# Calculation record to identify whether the device
# is armed - and the user has enabled polling/comms.
# The measurements can only be taken if both conditions are true.
record(calc, "$(P)$(R)ArmPollCalc")
{
    field(DESC, "Check for arm and ena")
    field(INPA, "$(P)$(R)ArmContinuousRBV CP")
    field(INPB, "$(P)$(R)EnaPoll CP")
    field(CALC, "A&&B")
}


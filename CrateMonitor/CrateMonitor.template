### PolyRack SMC-2 Commands ################################

record(calcout, "$(device):POLY:VERSION")
{
	field(CALC, "1")
	field(DTYP, "stream")
	field(OUT,  "@CrateMon.proto version $(device)")
	
	field(DISV, "0")
	field(SDIS, "$(device):TYPE")
}

#-----------------------------------------------------------

record(longin, "$(device):POLY:PSUSTAT")
{
	field(DTYP, "stream")
	field(INP,  "@CrateMon.proto getPSUstatus $(device)")

	field(DISV, "0")
	field(SDIS, "$(device):TYPE")
	
	field(FLNK, "$(device):POLY:COPY")
}

record(ao, "$(device):POLY:COPY")
{
	field(OMSL, "closed_loop")
	field(DOL,  "$(device):POLY:PSUSTAT")
	field(OUT,  "$(device):PSUSTAT PP")
}

# % archiver 2 Monitor

record(longin, "$(device):PSUSTAT")
{
	field(DESC, "Indicates PSU fault")

	field(HIGH, "1")
	field(HSV,  "MINOR")
	
	field(PINI, "YES")
}

#-----------------------------------------------------------

# Determine the crate type

record(seq, "$(device):PCRATE")
{
	field(SELM, "All")
	field(PINI, "YES")

	field(DO1,  "1")
	field(LNK1, "$(device):FAN.PROC")
	field(DLY1, "1")

	field(DO2,  "1")
	field(LNK2, "$(device):FTYPE.PROC")
	field(DLY2, "2")
}

# polyrack  4U 	1 1 1 0 0 0 0	100 = 2	2 temps	
# elma      4U 	1 1 1 1 1 1 1	111 = 0	3 temps	no 5V
# polyrack 11U 	1 1 1 1 0 0 0	110 = 1	3 temps	
# elma     11U 	1 1 0 0 0 0 0	000 = 3	3 temps	

record(calc, "$(device):FTYPE")
{
	field(DESC, "")
	field(CALC, "(A=0)+(B=0)+(C=0)")
	field(INPA, "$(device):FAN3")
	field(INPB, "$(device):FAN4")
	field(INPC, "$(device):FAN5")

	field(FLNK, "$(device):TYPE")
}

# defaults to zero to inhibit newer PolyRack commands

record(calc, "$(device):TYPE")
{
	field(DESC, "1=PolyRack, 0=Elma")
	field(CALC, "(A=1||A=2)&&(B=0)")
	field(INPA, "$(device):FTYPE")
	field(INPB, "$(device):OUTLET")

	field(FLNK, "$(device):CRATE")
}

# crate type

record(mbbi, "$(device):CRATE")
{
	field(DTYP, "Soft Channel")
	field(INP,  "$(device):FTYPE")
	
	field(ZRST, "Elma 4U")
	field(ONST, "PolyRack 11U")
	field(TWST, "PolyRack 4U")
	field(THST, "Elma 11U")
	
	field(UNSV, "MINOR")
	
	field(FLNK, "$(device):MASK")
}

# set the mask in the sequence record so that we don't process records valid
# only for PolyRack crates

record(calcout, "$(device):MASK")
{
	field(CALC, "(A=1)?63:111")
	field(INPA, "$(device):TYPE")
	field(OUT,  "$(device):SEQ.SELN")
	field(OOPT, "On Change")
}

# for displaying the alarm state of both the STATUS and PSUSTAT PV
# on the overview screen

record(calc, "$(device):ALARM")
{
	field(DESC, "Alarm state")
	field(SCAN, "1 second")
	field(CALC, "(A+B+C+D+E)#0")
	field(INPA, "$(device):STATUS.SEVR")
	field(INPB, "$(device):PSUSTAT.SEVR")
	field(INPC, "$(device):STA:PSU.SEVR")
	field(INPD, "$(device):STA:TEMP.SEVR")
	field(INPE, "$(device):STA:FAN.SEVR")
}

### Elma 4U PSU status #####################################

record(calc, "$(device):ELMA:PSUSTAT")
{
	field(CALC, "A>100")
	field(INPA, "$(device):FAN8")

	field(DISV, "1")
	field(SDIS, "$(device):TYPE")

	field(FLNK, "$(device):ELMA:COPY")
}

record(ao, "$(device):ELMA:COPY")
{
	field(OMSL, "closed_loop")
	field(DOL,  "$(device):ELMA:PSUSTAT")
	field(OUT,  "$(device):PSUSTAT PP")
}

# This associates an edm screen with the template
# % gui, $(name=None), edm, CrateMon.edl, device=$(device)

record(seq, "$(device):SEQ")
{
	field(SELM, "Mask")
	field(SELN, "111")
	field(SCAN, "5 second")

	field(DOL1, "1")
	field(LNK1, "$(device):STATUS.PROC")
	field(DLY1, "0")

	field(DOL2, "1")
	field(LNK2, "$(device):FAN.PROC")
	field(DLY2, "1")

	field(DOL3, "1")
	field(LNK3, "$(device):SUPPLY.PROC")
	field(DLY3, "1")

	field(DOL4, "1")
	field(LNK4, "$(device):TEMP.PROC")
	field(DLY4, "1")
		
	field(DOL5, "1")
	field(LNK5, "$(device):POLY:PSUSTAT.PROC")
	field(DLY5, "1")
	
	field(DOL6, "1")
	field(LNK6, "$(device):FTYPE.PROC")
	field(DLY6, "0")
	
	field(DOL7, "1")
	field(LNK7, "$(device):ELMA:PSUSTAT.PROC")
	field(DLY7, "0")
}


# d2ptg_mon_scan_list.template
# Template to be instantiated by 16 times regardless of D2AFEs in use. This is to create a complete FLNK list.
# If a D2AFE is present then it will overwrite these records with records that have a function
# % macro, P, Device prefix
# % macro, NEXT, PV of CAL:MON for next D2AFE.
record(ao, "$(P,undefined):AFE:MON")
{
  field(PINI, "YES")
  field(FLNK, "$(NEXT,undefined)")
}

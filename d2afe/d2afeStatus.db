# d2afeStatus.template
# Records to trigger mon command and split the response over the relevant PVs
# Also takes care of firmware, calid and eid reading
# % macro, P, Device prefix
# % macro, ADDR, D2AFE RS485 address
# % macro, STREAMS_PORT, PTG streams port
# % macro, NEXT, PV of CAL:MON for next D2AFE.
# % gui, $(name,undefined).TOP, edm, d2afe_top.edl, P=$(P,undefined)

record(ao, "$(P,undefined):AFE:MON")
{
  field(SCAN, "Passive")
  field(PINI, "NO")
  field(DTYP, "stream")
  field(OUT,  "@d2afe.proto mon($(ADDR,undefined),$(P,undefined):AFE) $(STREAMS_PORT,undefined)")
  field(FLNK, "$(NEXT,undefined)")
}

record(ai, "$(P,undefined):AFE:CH1_TEMP"){}
record(ai, "$(P,undefined):AFE:CH2_TEMP"){}
record(ai, "$(P,undefined):AFE:CH3_TEMP"){}
record(ai, "$(P,undefined):AFE:CH4_TEMP"){}
record(ai, "$(P,undefined):AFE:RF1_DBM"){}
record(ai, "$(P,undefined):AFE:RF2_DBM"){}
record(ai, "$(P,undefined):AFE:RF3_DBM"){}
record(ai, "$(P,undefined):AFE:RF4_DBM"){}
record(ai, "$(P,undefined):AFE:RADSENSE"){}
record(ai, "$(P,undefined):AFE:12V_MON"){}
record(ai, "$(P,undefined):AFE:5V_MON"){}
record(ai, "$(P,undefined):AFE:I_MON"){}
record(ai, "$(P,undefined):AFE:UPTIME"){}
record(ai, "$(P,undefined):AFE:BUFF_PEAK"){}
record(ai, "$(P,undefined):AFE:CH1_IN_ATT_RAW_RBV"){}
record(ai, "$(P,undefined):AFE:CH1_OUT_ATT_RAW_RBV"){}
record(ai, "$(P,undefined):AFE:CH2_IN_ATT_RAW_RBV"){}
record(ai, "$(P,undefined):AFE:CH2_OUT_ATT_RAW_RBV"){}
record(ai, "$(P,undefined):AFE:CH3_IN_ATT_RAW_RBV"){}
record(ai, "$(P,undefined):AFE:CH3_OUT_ATT_RAW_RBV"){}
record(ai, "$(P,undefined):AFE:CH4_IN_ATT_RAW_RBV"){}
record(ai, "$(P,undefined):AFE:CH4_OUT_ATT_RAW_RBV"){}
record(ai, "$(P,undefined):AFE:PILOT_ATT_RAW_RBV"){}
record(ai, "$(P,undefined):AFE:CH1_IN_ATT_RBV"){}
record(ai, "$(P,undefined):AFE:CH1_OUT_ATT_RBV"){}
record(ai, "$(P,undefined):AFE:CH2_IN_ATT_RBV"){}
record(ai, "$(P,undefined):AFE:CH2_OUT_ATT_RBV"){}
record(ai, "$(P,undefined):AFE:CH3_IN_ATT_RBV"){}
record(ai, "$(P,undefined):AFE:CH3_OUT_ATT_RBV"){}
record(ai, "$(P,undefined):AFE:CH4_IN_ATT_RBV"){}
record(ai, "$(P,undefined):AFE:CH4_OUT_ATT_RBV"){}
record(ai, "$(P,undefined):AFE:PILOT_ATT_RBV"){}



######################
# Display the response for selected commands for 2 seconds before clearing
record(seq, "$(P,undefined):AFE:RESP_CLR_DELAY") {
  field(SELM, "All")
  field(DLY1, "2.0")
  field(DOL1, "1")
  field(LNK1, "$(P,undefined):AFE:RESP_CLR.PROC PP")
}

record(stringout, "$(P,undefined):AFE:RESP_CLR") {
  field(VAL, "")
  field(OUT, "$(P,undefined):AFE:RESP PP")
}

record(stringin, "$(P,undefined):AFE:RESP") {
  field(FLNK, "$(P,undefined):AFE:RESP_CLR_DELAY PP")
}

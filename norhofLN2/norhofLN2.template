###############################################################
#
# Timer records to control pump state.
# 15 minutes after STANDBY go to SLEEP.
# 2 hour after SLEEP go to OFF.
#
# This is enabled (and reset) whenever we do a WASH, SLEEP or PAUSE (ie. STANDBY).
#
###############################################################

record(calcout, "$(P):CALCSTATETIME") {
  field(CALC, "A+1")
  field(DOPT, "Use CALC")
  field(SCAN, "1 second")
  field(OOPT, "Every Time")
  field(OUT, "$(P):TIMESINCESTATE.VAL")
  field(INPA, "$(P):TIMESINCESTATE.VAL")
  field(FLNK, "$(P):TIMESINCESTATE.PROC")
  field(SDIS, "$(P):CONTROLSTATETIMER")
}

#% archiver 1 Monitor VAL
record(ai, "$(P):TIMESINCESTATE") {
  field(DTYP, "Soft Channel")
  field(SCAN, "Passive")
  field(VAL, "0")
  field(EGU, "secs")
  field(FLNK, "$(P):GOTOSLEEPACTION.PROC")
}

record(calcout, "$(P):GOTOSLEEPACTION") {
  field(CALC, "A=B")
  field(DOPT, "Use CALC")
  field(OOPT, "Transition To Non-zero")
  field(OUT, "$(P):SLEEP_NOTIMERRESET.PROC")
  field(INPA, "$(P):TIMESINCESTATE.VAL")
  field(INPB, "$(P):TIMETOSLEEP.VAL")
  field(FLNK, "$(P):GOTOOFFACTION.PROC")
}

record(calcout, "$(P):GOTOOFFACTION") {
  field(CALC, "A=B")
  field(DOPT, "Use CALC")
  field(OOPT, "Transition To Non-zero")
  field(OUT, "$(P):OFF.PROC")
  field(INPA, "$(P):TIMESINCESTATE.VAL")
  field(INPB, "$(P):TIMETOOFF.VAL")
}

#% autosave 0 VAL
record(ai, "$(P):TIMETOSLEEP") {
  field(DTYP, "Soft Channel")
  field(SCAN, "Passive")
  field(VAL, "900")
  field(EGU, "secs")
  field(PINI, "YES")
}

#% autosave 0 VAL
record(ai, "$(P):TIMETOOFF") {
  field(DTYP, "Soft Channel")
  field(SCAN, "Passive")
  field(VAL, "7200")
  field(EGU, "secs")
  field(PINI, "YES")
}

record(dfanout, "$(P):RESETSTATETIME") {
  field(DOL, "0")
  field(OUTA, "$(P):TIMESINCESTATE.VAL PP")
}

record(dfanout, "$(P):ENABLESTATETIMER") {
  field(DOL, "0")
  field(OUTA, "$(P):CONTROLSTATETIMER.VAL PP")
  field(SDIS, "$(P):DISABLETIMERCONTROL")
}

record(dfanout, "$(P):DISABLESTATETIMER") {
  field(DOL, "1")
  field(OUTA, "$(P):CONTROLSTATETIMER.VAL PP")
  field(SDIS, "$(P):DISABLETIMERCONTROL")
}

record(bo, "$(P):CONTROLSTATETIMER") {
  field(DESC, "Control state timer")
  field(PINI, "YES")
  field(VAL, "1")
  field(OMSL, "supervisory")
  field(ZNAM, "Enabled")
  field(ONAM, "Disabled")
  field(FLNK, "$(P):RESETSTATETIME.PROC")
}

##########################################################################
# Records to save the current state, and read the current state and put 
# it in a previous state record.
#
# I use the user level state names here, rather than the actual pump status.
#
##########################################################################


# /// 
# /// Previous state.
# ///
#% archiver 1 Monitor VAL
record(mbbi, "$(P):PUMP_STATUS_PREVIOUS_RBV")
{
   field(DESC, "Previous pump status")
   field(DTYP, "Soft Channel")
   field(VAL, "0")
   field(PINI, "YES")
   field(ZRVL, "0")
   field(ZRST, "OFF")
   field(ONVL, "1")     
   field(ONST, "SLEEP")
   field(TWVL, "2")
   field(TWST, "PAUSE")
   field(THVL, "3")
   field(THST, "WASH")
   field(SCAN, "Passive")
   field(SDIS, "$(P):DISABLE")
}

# /// 
# /// Current state.
# ///
#% archiver 1 Monitor VAL
record(mbbi, "$(P):PUMP_STATUS_CURRENT_RBV")
{
   field(DESC, "Current pump status")
   field(DTYP, "Soft Channel")
   field(VAL, "0")
   field(PINI, "YES")
   field(ZRVL, "0")
   field(ZRST, "OFF")
   field(ONVL, "1")     
   field(ONST, "SLEEP")
   field(TWVL, "2")
   field(TWST, "PAUSE")
   field(THVL, "3")
   field(THST, "WASH")
   field(SCAN, "Passive")
   field(SDIS, "$(P):DISABLE")
}

# /// 
# /// Save the previous state.
# ///
record(calcout, "$(P):SAVE_PREVIOUS_STATE") {
  field(CALC, "A")
  field(DOPT, "Use CALC")
  field(OOPT, "Every Time")
  field(OUT, "$(P):PUMP_STATUS_PREVIOUS_RBV.VAL PP")
  field(INPA, "$(P):PUMP_STATUS_CURRENT_RBV.VAL")
}

# /// 
# /// Set the OFF state.
# ///
record(seq, "$(P):SET_OFF_STATE") {
  field(DOL1, "1")
  field(DLY1, "0.1")
  field(LNK1, "$(P):SAVE_PREVIOUS_STATE.PROC MS")
  field(DOL2, "0")
  field(LNK2, "$(P):PUMP_STATUS_CURRENT_RBV.VAL PP MS")
}

# /// 
# /// Set the SLEEP state.
# ///
record(seq, "$(P):SET_SLEEP_STATE") {
  field(DOL1, "1")
  field(DLY1, "0.1")
  field(LNK1, "$(P):SAVE_PREVIOUS_STATE.PROC MS")
  field(DOL2, "1")
  field(LNK2, "$(P):PUMP_STATUS_CURRENT_RBV.VAL PP MS")
}

# /// 
# /// Set the PAUSE state.
# ///
record(seq, "$(P):SET_PAUSE_STATE") {
  field(DOL1, "1")
  field(DLY1, "0.1")
  field(LNK1, "$(P):SAVE_PREVIOUS_STATE.PROC MS")
  field(DOL2, "2")
  field(LNK2, "$(P):PUMP_STATUS_CURRENT_RBV.VAL PP MS")
}


# /// 
# /// Set the WASH state.
# ///
record(seq, "$(P):SET_WASH_STATE") {
  field(DOL1, "1")
  field(DLY1, "0.1")
  field(LNK1, "$(P):SAVE_PREVIOUS_STATE.PROC MS")
  field(DOL2, "3")
  field(LNK2, "$(P):PUMP_STATUS_CURRENT_RBV.VAL PP MS")
}




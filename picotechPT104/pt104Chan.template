record (calc, "$(P)$(R):$(CHNAME):Resistance") {
    field(DESC, "Measured resistance for channel $(N)")
    field(DISV, "0")
    field(SDIS, "$(P)$(R):$(CHNAME):Enable")
    field(FLNK, "$(P)$(R):$(CHNAME):TCalc")
    field(INPA, "$(P)$(R):$(CHNAME):Calib.VALA")
    field(INPB, "$(P)$(R):$(CHNAME):Meas0.VALA")
    field(INPC, "$(P)$(R):$(CHNAME):Meas1.VALA")
    field(INPD, "$(P)$(R):$(CHNAME):Meas2.VALA")
    field(INPE, "$(P)$(R):$(CHNAME):Meas3.VALA")
    field(CALC, "1E-6*A*(E-D)/(C-B)")
}

record (sub, "$(P)$(R):$(CHNAME):TCalc") {
    field(DESC, "Calculated Temperature for channel $(N)")
    field(DISV, "0")
    field(SDIS, "$(P)$(R):$(CHNAME):Enable")
    field(FLNK, "$(P)$(R):$(CHNAME):TimeoutReset")
    field(SNAM, "pt104_resToT")
    field(INPA, "$(P)$(R):$(CHNAME):Resistance")
}

# % archiver 10 Monitor
record (calc, "$(P)$(R):$(CHNAME):T") {
    field(DESC, "Calculated Temperature for channel $(N)")
    field(INPA, "$(P)$(R):$(CHNAME):TCalc MS CP")
    field(INPB, "$(P)$(R):$(CHNAME):Alarm MS CP")
    field(PREC, "3")
    field(CALC, "A")
    field(EGU,  "C")
    field(HOPR, "$(T_HOPR)")
    field(LOPR, "$(T_LOPR)")
    field(HIGH, "$(T_HIGH)")
    field(LOW,  "$(T_LOW)")
    field(HSV,  "MAJOR")
    field(LSV,  "MAJOR")
}

## Offset-corrected temperature
# % archiver 10 Monitor
record (calc, "$(P)$(R):$(CHNAME):TCorr") {
    field(DESC, "Corrected temp (T-Offset) for chan $(N)")
    field(INPA, "$(P)$(R):$(CHNAME):T MS CP")
    field(INPB, "$(P)$(R):$(CHNAME):Offset CP")
    field(PREC, "3")
    field(CALC, "A-B")
    field(EGU,  "C")
    field(HOPR, "$(T_HOPR)")
    field(LOPR, "$(T_LOPR)")
    field(HIGH, "$(T_HIGH)")
    field(LOW,  "$(T_LOW)")
    field(HSV,  "MAJOR")
    field(LSV,  "MAJOR")
}

## Timeout error generation
record (ao, "$(P)$(R):$(CHNAME):TimeoutReset") {
    field(DESC, "Reset the timer when the measurmnt comes")
    field(VAL,  "$(DELAY)")
    field(OUT,  "$(P)$(R):$(CHNAME):TimeoutTimer PP")
}

record (calc, "$(P)$(R):$(CHNAME):TimeoutTimer") {
    field(DESC, "Timer, alarm should be raised on 0")
    field(DISV, "0")
    field(SDIS, "$(P)$(R):$(CHNAME):Enable")
    field(SCAN, ".5 second")
    field(CALC, "VAL<=0?0:VAL-.5")
}

record (calc, "$(P)$(R):$(CHNAME):Alarm") {
    field(DESC, "Timeout alarm")
    field(DISV, "0")
    field(SDIS, "$(P)$(R):$(CHNAME):Enable")
    field(SCAN, "1 second")
    field(INPA, "$(P)$(R):$(CHNAME):TimeoutTimer")
    field(CALC, "A == 0 ? 1 : 0")
    field(HIHI, "1")
    field(HHSV, "MAJOR")
    field(PINI, "1")
}

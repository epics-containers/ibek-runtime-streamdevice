    field(DESC, "Converted measurement 3")
    field(SNAM, "pt104_ucharToUInt")
    field(FLNK, "$(P)$(R):$(CHNAME):Resistance")

    field(INPA, "$(P)$(R):$(CHNAME):Meas3Raw")
    field(FTA,  "UCHAR")
    field(NOA,  "4")
    field(NEA,  "4")

    field(INPB, "0")
    field(FTB,  "ULONG")
    field(NOB,  "1")
    field(NEB,  "1")


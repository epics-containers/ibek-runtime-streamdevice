# substitutions:
# % macro, P, Device prefix
# % macro, PORT, terminal server asyn serial port number

# % gui, specsXRC1000, edm, specsXRC1000.edl, P=$(P)

record(stringin, "$(P):MESSAGE") {

}

record(ai, "$(P):EmissionCurrentA_RBV") {
  field(DTYP, "stream")
  field(DESC, "Read emission current")
  field(INP, "@specsXRC1000.proto getEmissionCurrent($(P)) $(PORT) 0")
  field(SCAN, "2 second")
  field(PREC, "9")
  field(EGU, "A")
}

record(calc, "$(P):EmissionCurrent_RBV") {
  field(CALC, "A*1000.")
  field(INPA, "$(P):EmissionCurrentA_RBV")
  field(EGU, "mA")
  field(PREC, "2")
  field(SCAN, "2 second")
}

record(ao, "$(P):EmissionCurrentA") {
  field(DTYP, "stream")
  field(DESC, "Set emission current")
  field(OUT, "@specsXRC1000.proto setEmissionCurrent($(P)) $(PORT) 0")
  field(EGU, "A")
  field(DRVH, "0.0666")
  field(DRVL, "0")
}

record(calcout, "$(P):EmissionCurrent_calc") {
  field(OUT, "$(P):EmissionCurrentA")
  field(CALC, "A/1000.")
  field(INPA, "$(P):EmissionCurrent")
  field(EGU, "A")
  field(PREC, "2")
  field(FLNK, "$(P):EmissionCurrentA")
}

record(ao, "$(P):EmissionCurrent") {
  field(EGU, "mA")
  field(PREC, "2")
  field(FLNK, "$(P):EmissionCurrent_calc")
}


record(bo, "$(P):Remote") {
  field(DTYP, "stream")
  field(DESC, "Set Remote ON / OFF (Local)")
  field(OUT, "@specsXRC1000.proto setRemote($(P)) $(PORT) 0")
  field(ZNAM, "OFF")
  field(ONAM, "ON")
}

record(mbbi, "$(P):Remote_RBV") {
  field(DTYP, "stream")
  field(DESC, "Get Remote ON / OFF (Local)")

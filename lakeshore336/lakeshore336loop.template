##
## Set the output mode to use
##
record(calcout, "$(P):OM$(LOOP)") {
  field(DTYP, "stream")
  field(SDIS, "$(P):DISABLE")
  field(INPA, "$(LOOP)")
  field(INPB, "$(P):OMMODE_S$(LOOP)")
  field(INPC, "$(P):OMINPUT_S$(LOOP)")
  field(INPD, "$(P):OMPE_S$(LOOP)")
  field(SDIS, "$(P):DISABLE")
  field(OUT, "@lakeshore336.proto setOUTMODE $(PORT) $(ADDR)")
  field(FLNK, "$(P):OMREADFAN$(LOOP)")
}


record(fanout, "$(P):OMREADFAN$(LOOP)") {
  field(LNK1, "$(P):OMMODE$(LOOP).PROC CA")
  field(LNK2, "$(P):OMINPUT$(LOOP).PROC CA")
  field(LNK3, "$(P):OMPE$(LOOP).PROC CA")
}



##
## Set the type of tuning mode
##
record(mbbo, "$(P):TUNEMODE_S$(LOOP)") {
  field(SDIS, "$(P):DISABLE")
  field(ZRST, "P Only")
  field(ZRVL, "0")
  field(ONST, "P and I")
  field(ONVL, "1")
  field(TWST, "P, I and D")
  field(TWVL, "2")
}


## 
## Start the tuning process
##
record(ao, "$(P):TUNESTART$(LOOP)") {
  field(DTYP, "stream")
  field(SDIS, "$(P):DISABLE")
  field(DESC, "Start the auto tuning")
  field(OUT, "@lakeshore336.proto setATUNE($(LOOP),$(P):TUNEMODE_S$(LOOP)) $(PORT) $(ADDR)")
}


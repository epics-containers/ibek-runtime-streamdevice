################################################################
# Write records
################################################################


## 
## Set the setpoint temperature.
##
record(ao, "$(P):SETP_S$(LOOP)") {
  field(DTYP, "stream")
  field(SDIS, "$(P):DISABLE")
  field(DESC, "Setpoint temperature")
  field(OUT, "@lakeshore336.proto setSETP($(LOOP)) $(PORT) $(ADDR)")
  field(PREC, "3")
  field(FLNK, "$(P):SETP$(LOOP).PROC CA")
  field(EGU, "K")
}

## 
## Set the range parameter.
##
## Possible values are: 0, 1, 2, 3
##
record(mbbo, "$(P):RANGE_S$(LOOP)") {
  field(DTYP, "stream")
  field(ZRST, "Off")
  field(ZRVL, "0")
  field(ONST, "Low")
  field(ONVL, "1")
  field(TWST, "Medium")
  field(TWVL, "2")
  field(THST, "High")
  field(THVL, "3")
  field(SDIS, "$(P):DISABLE")
  field(OUT, "@lakeshore336.proto setRANGE($(LOOP)) $(PORT) $(ADDR)")
  field(FLNK, "$(P):RANGE$(LOOP).PROC CA")  
}


## 
## Set the ramp rate parameter.
##
## This is the desired temperate increase/decrease rate
## per second when heating/cooling.
##
## The ramp and ramp status parameters are actually one command
## for the lakeshore 340. Therefore one must pass into this
## record the existing/desired ramp status, as well as the 
## desired ramp. This is done automatically by reading the 
## PV which holds the current ramp status.
##
record(ao, "$(P):RAMP_S$(LOOP)") {
  field(DTYP, "stream")
  field(SDIS, "$(P):DISABLE")
  field(OUT, "@lakeshore336.proto setRAMP($(P):RAMPST$(LOOP),$(LOOP)) $(PORT) $(ADDR)")
  field(PREC, "3")
  field(FLNK, "$(P):RAMP$(LOOP).PROC CA")
  field(EGU, "K/min")
}

## 
## Set the ramp status parameter.
##
## 0=off
## 1=on
##
## The ramp and ramp status parameters are actually one command
## for the lakeshore 340. Therefore one must pass into this
## record the existing/desired ramp, as well as the 
## desired ramp status. This is done automatically by reading the 
## PV which holds the current ramp value.
##
record(ao, "$(P):RAMPST_S$(LOOP)") {
  field(DTYP, "stream")
  field(SDIS, "$(P):DISABLE")
  field(OUT, "@lakeshore336.proto setRAMPSTATUS($(P):RAMP$(LOOP),$(LOOP)) $(PORT) $(ADDR)")
  field(FLNK, "$(P):RAMPST$(LOOP).PROC CA")
  field(HOPR, "1")
  field(LOPR, "0")
}

## 
## Set the control loop 1 manual output value.
##
record(ao, "$(P):MOUT_S$(LOOP)") {
  field(DTYP, "stream")
  field(SDIS, "$(P):DISABLE")
  field(OUT, "@lakeshore336.proto setMOUT($(LOOP)) $(PORT) $(ADDR)")
  field(FLNK, "$(P):MOUT$(LOOP).PROC CA")
  field(PREC, "2")
}

#% autosave 0 VAL
record(mbbo, "$(P):MOUT:TRACKCL$(LOOP)") {
  field(DESC, "Enable MOUT to track CL demand")
  field(ZRST, "Disabled")
  field(ZRVL, "0")
  field(ONST, "Enabled")
  field(ONVL, "1")
  field(PINI, "YES")
}

record(calcout, "$(P):MOUT:TRACKCLC$(LOOP)") {
  field(DESC, "If tracking enabled & closed_loop")
  field(CALC, "(A=1&&B=1)?1:0")
  field(OOPT, "When Non-zero")
  field(DOPT, "Use OCAL")
  field(OCAL, "C")
  field(INPA, "$(P):MOUT:TRACKCL$(LOOP)")
  field(INPB, "$(P):OMMODE$(LOOP)")
  field(INPC, "$(P):HTR$(LOOP)")
  field(OUT, "$(P):MOUT_S$(LOOP) PP")
}


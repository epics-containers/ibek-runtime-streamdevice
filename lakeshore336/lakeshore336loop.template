# This is included in lakeshore336.template

################################################################
# Read records
################################################################


## 
## Read the heater output value.
##
#% archiver 10 Monitor
#
record(ai, "$(P):HTR$(LOOP)") {
  field(DTYP, "stream")
  field(SDIS, "$(P):DISABLE")
  field(INP, "@lakeshore336.proto getHTR($(LOOP)) $(PORT) $(ADDR)")
  field(SCAN, "$(SCAN) second")
  field(PREC, "1")
  field(EGU, "%")
  field(FLNK, "$(P):MOUT:TRACKCLC$(LOOP)")
}

## 
## Read the setpoint temperature.
##
#% archiver 10 Monitor
#
record(ai, "$(P):SETP$(LOOP)") {
  field(DTYP, "stream")
  field(SDIS, "$(P):DISABLE")
  field(INP, "@lakeshore336.proto getSETP($(LOOP)) $(PORT) $(ADDR)")
  field(SCAN, "$(TEMPSCAN) second")
  field(PREC, "3")
  field(EGU, "K")
}

## 
## Read the range parameter (the heater output power range).

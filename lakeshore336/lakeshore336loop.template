record(mbbi, "$(P):RANGE$(LOOP)") {
  field(DTYP, "stream")
  field(SDIS, "$(P):DISABLE")
  field(ZRST, "Off")
  field(ZRVL, "0")
  field(ONST, "Low")
  field(ONVL, "1")
  field(TWST, "Medium")
  field(TWVL, "2")
  field(THST, "High")
  field(THVL, "3")
  field(SCAN, "$(SCAN) second")
  field(INP, "@lakeshore336.proto getRANGE($(LOOP)) $(PORT) $(ADDR)")
}



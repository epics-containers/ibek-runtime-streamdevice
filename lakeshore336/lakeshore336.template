record(stringout, "$(P):OUT4LABEL") {
    field(DESC, "label for output 4")
    field(VAL,  "$(OUT4_label=Output 4 Control)")
    field(PINI, "YES")
}


################################################################
# Now include the loop dependant records, for PID loops 1 to 2.
# for loops 3 and 4, overwrite the heater read record (aout template)
################################################################

substitute "LOOP=1"
include "lakeshore336loop.template"

substitute "LOOP=2"
include "lakeshore336loop.template"

substitute "LOOP=3"
include "lakeshore336loop.template"
include "lakeshoreAout.template"

substitute "LOOP=4"
include "lakeshore336loop.template"
include "lakeshoreAout.template"

include "lakeshore336-FirmwareVersion.template"

##
## Generic Asyn record for reading parameters.
##
record(asyn,"$(P):ASYN")
{
    field(DTYP,"asynRecordDevice")
    field(PORT,"$(PORT)")
    field(ADDR,"$(ADDR)")
    field(OMAX,"1024")
    field(IMAX,"1024")
}

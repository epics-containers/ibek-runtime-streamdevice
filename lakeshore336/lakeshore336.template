## 
## Read the tuning status from the device.
##
record(stringin, "$(P):TUNEST") {
  field(DTYP, "stream")
  field(SDIS, "$(P):DISABLE")
  field(INP, "@lakeshore336.proto getTUNEST $(PORT) $(ADDR)")
  field(SCAN, "$(SCAN) second")
}

## 
## Read the tuning status success parameter
##
record(bi, "$(P):TUNESTSUCCESS") {
  field(DTYP, "stream")
  field(SDIS, "$(P):DISABLE")
  field(INP, "@lakeshore336.proto getTUNESTSUCCESS $(PORT) $(ADDR)")
  field(SCAN, "$(SCAN) second")
  field(ZNAM, "No Error")
  field(ONAM, "Error (see manual)")
}



################################################################
# Write records
################################################################


################################################################
# Descriptive and label records
# PINI set to YES to the PVs are not considered invalid by gui's
################################################################


record(stringout, "$(P):DESCRIPTION") {
    field(DESC, "main purpose of this device")
    field(VAL,  "$(Description=Temperature Controller)")
    field(PINI, "YES")
}


record(stringout, "$(P):KRDG0LABEL") {
    field(DESC, "label for channel 0")
    field(VAL,  "$(CH0_label=Channel 0)")
    field(PINI, "YES")
}

record(stringout, "$(P):KRDG1LABEL") {
    field(DESC, "label for channel 1")
    field(VAL,  "$(CH1_label=Channel 1)")
    field(PINI, "YES")
}

record(stringout, "$(P):KRDG2LABEL") {
    field(DESC, "label for channel 2")
    field(VAL,  "$(CH2_label=Channel 2)")
    field(PINI, "YES")
}

record(stringout, "$(P):KRDG3LABEL") {
    field(DESC, "label for channel 3")
    field(VAL,  "$(CH3_label=Channel 3)")
    field(PINI, "YES")
}


record(stringout, "$(P):OUT1LABEL") {
    field(DESC, "label for output 1")
    field(VAL,  "$(OUT1_label=Output 1 Control)")
    field(PINI, "YES")
}

record(stringout, "$(P):OUT2LABEL") {
    field(DESC, "label for output 2")
    field(VAL,  "$(OUT2_label=Output 2 Control)")
    field(PINI, "YES")
}

record(stringout, "$(P):OUT3LABEL") {
    field(DESC, "label for output 3")
    field(VAL,  "$(OUT3_label=Output 3 Control)")
    field(PINI, "YES")

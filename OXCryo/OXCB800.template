# Alarm Handling
#
# Alarm numbers are pushed into :ALARMI by the protocol file.
# This is then processed by :ALARM to lookup the alarm message
#
# Text messages generated by the alarm handler include the
# DESC field of the record in alarm state.  However, the
# :ALARM genSub record holds the alarm message in its VALA
# field so can't be used as the alh record.  Therefore the
# :COPY_ALARM_FIELDS, :COPY_STRING, and :COPY_SEVERITY records
# are used to copy the :ALARM record's alarm message into the
# DESC field of ALARM_MSG, and also set this record's severity
# in order to trigger its alarm handlers
# % archiver 1 Monitor
# %gdatag,pv,ro,$(gda_name=),ALARM,Alarm Status,<pv>.VALA
record(genSub, "$(P)$(Q):ALARM") {
  field(DESC, "Alarm Status")
  field(INPA, "$(P)$(Q):ALARMI CP")
  field(FTA, "LONG")
  field(FTVA, "STRING")
  field(BRSV, "MAJOR")
  field(SNAM, "alarmlookupProcess")
  field(FLNK, "$(P)$(Q):COPY_ALARM_FIELDS")
}

# The description is copied before the severity
# to ensure that the DESC field is updated before
# the alarm handler is triggered by the severity
record(seq, "$(P)$(Q):COPY_ALARM_FIELDS") {
  field(DESC, "Copy the alarm fields")
  field(DOL1, "1")
  field(LNK1, "$(P)$(Q):COPY_STRING.PROC CA")
  field(DOL2, "1")
  field(LNK2, "$(P)$(Q):COPY_SEVERITY.PROC CA")
}

record(scalcout, "$(P)$(Q):COPY_STRING") {
  field(INAA, "$(P)$(Q):ALARM.VALA")
  field(CALC, "AA")
  field(OUT, "$(P)$(Q):ALARM_MSG.DESC PP")
}

record(calcout, "$(P)$(Q):COPY_SEVERITY") {
  field(INPA, "$(P)$(Q):ALARM.SEVR")
  field(CALC, "A")
  field(OOPT, "Every Time")
  field(OUT, "$(P)$(Q):ALARM_MSG PP")
}


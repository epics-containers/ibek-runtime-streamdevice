# This PV keeps the GUI TURBO dropdown display in sync with the RBV
# e.g. if the IOC is restarted when the TURBOMODE is On
# TURBOMODE=1 (On) or 3 (On in Cool mode) means ON
# TURBOMODE=0 (Off) or 2 (Auto in Cool mode) means Off/Auto
record(calc, "$(P)$(Q):TURBORBV_SYNC") {
  field(DESC, "For syncing GUI only")
  field(INPA, "$(P)$(Q):TURBOMODE CP")
  field(CALC, "A==1 || A==3")
}


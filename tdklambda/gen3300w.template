record(ai, "$(P):OVER:VOLTAGE:PROT_RBV") {
    field(DESC, "Under voltage Protection limit")
    field(DTYP, "stream")
    field(SCAN, "1 second")
    field(INP, "@gen3300w.proto getOverVoltageProtection$(CMDSET=R) $(PORT)")

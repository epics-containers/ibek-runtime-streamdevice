# gen3300w.template
#
# A template for the TDK Lambda 3300W power supply
#
# 2016 - Jonathan Thompson
#

# Parameters:
# % macro,  P,       EPICS name prefix
# % macro,  PORT,    asyn port
# % macro,  CMDSET,  Command set: use 'R' for RS232(default) or 'S' for SCPI(Ethernet)
# % macro,  name,    object and gui association name

# % gui, $(name=), edm, gen3300w-full.edl, P=$(P)
# % gui, $(name=), edmembed, gen3300w-embed.edl, P=$(P)

# The device model
record(stringin, "$(P):MODEL") {
    field(DESC, "Device model")
    field(DTYP, "stream")
    field(SCAN, "10 second")
    field(INP,  "@gen3300w.proto getIdentity$(CMDSET=R) $(PORT)")
    field(FLNK, "$(P):SWVERSION")
}

# The software version
record(stringin, "$(P):SWVERSION") {
    field(DESC, "Software version")
    field(DTYP, "stream")
    field(SCAN, "Passive")
    field(INP,  "@gen3300w.proto getSwVersion$(CMDSET=R) $(PORT)")
    field(FLNK, "$(P):SERIALNUMBER")
}

# The serial number
record(stringin, "$(P):SERIALNUMBER") {
    field(DESC, "Serial number")
    field(DTYP, "stream")
    field(SCAN, "Passive")
    field(INP,  "@gen3300w.proto getSerialNumber$(CMDSET=R) $(PORT)")
    field(FLNK, "$(P):TESTDATE")
}

# The date the device was last tested
record(stringin, "$(P):TESTDATE") {
    field(DESC, "Test date")
    field(DTYP, "stream")
    field(SCAN, "Passive")
    field(INP,  "@gen3300w.proto getLastTestDate$(CMDSET=R) $(PORT)")
}

# The demand voltage
record(ao, "$(P):DEMAND:VOLTAGE") {
    field(DESC, "Demand Voltage")
    field(DTYP, "stream")
    field(SCAN, "Passive")
    field(OUT, "@gen3300w.proto setDemandVoltage$(CMDSET=R) $(PORT)")
    field(PREC, "4")
    field(EGU, "V")
    field(PINI, "1")
}
record(ai, "$(P):DEMAND:VOLTAGE_RBV") {
    field(DESC, "Demand voltage read back")
    field(DTYP, "stream")
    field(SCAN, "1 second")
    field(INP, "@gen3300w.proto getDemandVoltage$(CMDSET=R) $(PORT)")
    field(PREC, "4")
    field(EGU, "V")
}
 
# The demand current
record(ao, "$(P):DEMAND:CURRENT") {
    field(DESC, "Demand Current")
    field(DTYP, "stream")
    field(SCAN, "Passive")
    field(OUT, "@gen3300w.proto setDemandCurrent$(CMDSET=R) $(PORT)")
    field(PREC, "4")
    field(EGU, "A")
    field(PINI, "1")
}
record(ai, "$(P):DEMAND:CURRENT_RBV") {
    field(DESC, "Demand current read back")
    field(DTYP, "stream")
    field(SCAN, "1 second")
    field(INP, "@gen3300w.proto getDemandCurrent$(CMDSET=R) $(PORT)")
    field(PREC, "4")
    field(EGU, "A")
}

# Actual voltage
record(ai, "$(P):ACTUAL:VOLTAGE") {
    field(DESC, "Actual voltage")
    field(DTYP, "stream")
    field(SCAN, "1 second")
    field(INP, "@gen3300w.proto getActualVoltage$(CMDSET=R) $(PORT)")
    field(PREC, "4")
    field(EGU, "V")
}

# Actual current
record(ai, "$(P):ACTUAL:CURRENT") {
    field(DESC, "Actual current")
    field(DTYP, "stream")
    field(SCAN, "1 second")
    field(INP, "@gen3300w.proto getActualCurrent$(CMDSET=R) $(PORT)")
    field(PREC, "4")
    field(EGU, "A")
}

# Output state
record(bo, "$(P):OUTPUT") {
    field(DESC, "Output state")
    field(DTYP, "stream")
    field(SCAN, "Passive")
    field(OUT, "@gen3300w.proto setOutputState$(CMDSET=R) $(PORT)")
    field(ZNAM, "Off")
    field(ONAM, "On")
    field(PINI, "1")
}
record(bi, "$(P):OUTPUT_RBV") {
    field(DESC, "Output state")
    field(DTYP, "stream")
    field(SCAN, "1 second")
    field(INP, "@gen3300w.proto getOutputState$(CMDSET=R) $(PORT)")
    field(ZNAM, "Off")
    field(ONAM, "On")
}


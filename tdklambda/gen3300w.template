# Autorestart mode
record(bo, "$(P):AUTO:RESTART") {
    field(DESC, "Auto restart mode")
    field(DTYP, "stream")
    field(SCAN, "Passive")
    field(OUT, "@gen3300w.proto setAutoRestartMode$(CMDSET=R) $(PORT)")
    field(ZNAM, "Off")
    field(ONAM, "On")
    field(PINI, "1")
}
record(bi, "$(P):AUTO:RESTART_RBV") {
    field(DESC, "Auto restart mode")
    field(DTYP, "stream")
    field(SCAN, "1 second")
    field(INP, "@gen3300w.proto getAutoRestartMode$(CMDSET=R) $(PORT)")
    field(ZNAM, "Off")
    field(ONAM, "On")
}

# Current operating mode
record(mbbi, "$(P):MODE") {
    field(DESC, "Operating mode")
    field(DTYP, "stream")
    field(SCAN, "1 second")
    field(INP, "@gen3300w.proto getOperatingMode$(CMDSET=R) $(PORT)")
    field(ZRVL, "0")
    field(ONVL, "1")
    field(TWVL, "2")
    field(ZRST, "Off")
    field(ONST, "Voltage")
    field(TWST, "Current")
}

# Set the address
record(longout, "$(P):SETADDRESS") {
    field(VAL, "6")
    field(DESC, "Set the device address")
    field(DTYP, "stream")
    field(SCAN, "Passive")
    field(OUT, "@gen3300w.proto onConnect$(CMDSET=R) $(PORT)")
    field(PINI, "1")
}

record(mbbiDirect, "$(P):FAULT:EVENT:REG") {
    field(DESC, "Read fault reg")
    field(DTYP, "stream")
    field(SCAN, "1 second")
    field(INP, "@gen3300w.proto getFaultEventReg$(CMDSET=R) $(PORT)")
}

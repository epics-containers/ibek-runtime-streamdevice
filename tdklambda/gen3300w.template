record(bo, "$(P):FOLDBACK") {
    field(DESC, "Foldback protection")
    field(DTYP, "stream")
    field(SCAN, "Passive")
    field(OUT, "@gen3300w.proto setFoldbackProtection$(CMDSET=R) $(PORT)")
    field(ZNAM, "Off")
    field(ONAM, "On")
    field(PINI, "1")
}
record(bi, "$(P):FOLDBACK_RBV") {
    field(DESC, "Output state")
    field(DTYP, "stream")
    field(SCAN, "1 second")
    field(INP, "@gen3300w.proto getFoldbackProtection$(CMDSET=R) $(PORT)")
    field(ZNAM, "Off")

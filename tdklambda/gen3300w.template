record(ao, "$(P):UNDER:VOLTAGE") {
    field(DESC, "Under Voltage Limit")
    field(DTYP, "stream")
    field(SCAN, "Passive")
    field(OUT, "@gen3300w.proto setUnderVoltageLimit$(CMDSET=R) $(PORT)")
    field(PREC, "4")
    field(EGU, "V")
    field(PINI, "1")
}
record(ai, "$(P):UNDER:VOLTAGE_RBV") {
    field(DESC, "Under voltage limit")
    field(DTYP, "stream")
    field(SCAN, "1 second")
    field(INP, "@gen3300w.proto getUnderVoltageLimit$(CMDSET=R) $(PORT)")
    field(PREC, "4")

# % macro, name, Object name
# % macro, P, Device prefix 1
# % macro, R, Device prefix 2
# % macro, PORT, Asyn PORT name
# % gui, $(name), edm, dmm6500.edl, P=$(P), R=$(R)
########################################################################
# Function selection
# Desc: Measurement and digitize functions options

record(mbbo, "$(P)$(R)MeasFnc-Sel"){
  field(DESC, "Measurement function selection")
  field(ZRST, "DC_VOLTAGE")
  field(ONST, "AC_VOLTAGE")
  field(TWST, "DC_CURRENT")
  field(THST, "AC_CURRENT")
  field(FRST, "RESISTANCE")
  field(FVST, "4W_RESISTANCE")
  field(SXST, "ACV_FREQUENCY")
  field(SVST, "ACV_PERIOD")
  field(DTYP, "stream")
  field(OUT, "@dmm6500.proto meas_func_set $(PORT)")
  field(FLNK, "$(P)$(R)AuxCalc1")
}

record(calcout, "$(P)$(R)AuxCalc1"){
  field(ASG, "Reserved")
  field(DESC, "Waits a second while function changes")
  field(CALC, "1")
  field(ODLY, "1")
  field(OUT, "$(P)$(R)MeasFnc-Sts.PROC")
  field(FLNK, "$(P)$(R)Visibility-sel")
}

# Auto-get parameters values when function selection
record(fanout, "$(P)$(R)Visibility-sel"){
  field(SELM, "All")
  field(SELL, "$(P)$(R)AuxCalc1.VAL")
  field(LNK1, "$(P)$(R)AutoZ-Visib")
  field(LNK2, "$(P)$(R)AutoR-Visib")
  field(LNK3, "$(P)$(R)FilterEnbl-Sts")
  field(LNK4, "$(P)$(R)FilterCnt-RB")
  field(LNK5, "$(P)$(R)FilterTyp-Sts")
  field(LNK6, "$(P)$(R)FilterWind-RB")
  field(FLNK, "$(P)$(R)Visibility-sel1")
}
record(fanout, "$(P)$(R)Visibility-sel1"){
  field(SELM, "All")
  field(SELL, "$(P)$(R)AuxCalc1.VAL")
  field(LNK1, "$(P)$(R)MMathEnbl-Sts")
  field(LNK2, "$(P)$(R)MMathOp-Sts")
  field(LNK3, "$(P)$(R)MMathBFactor-RB")
  field(LNK4, "$(P)$(R)MMathMFactor-RB")
  field(LNK5, "$(P)$(R)MMathPercRef-RB")
}

# AutoZero Visibility & Auto-get autozero when function selection
record(calcout, "$(P)$(R)AutoZ-Visib"){
  field(SCAN, "Passive")
  field(INPA, "$(P)$(R)MeasFnc-Sel.VAL")
  field(CALC, "(A=0||A=2||A=4||A=5)?2:0")
  field(OOPT, "When Non-zero")
  field(OUT, "$(P)$(R)AutoZero-Sts.PROC")
}

# AutoRange Visibility & Auto-get autoRange when function selection
record(calcout, "$(P)$(R)AutoR-Visib"){
  field(SCAN, "Passive")
  field(INPA, "$(P)$(R)MeasFnc-Sel.VAL")
  field(CALC, "(A=0||A=1||A=2||A=3||A=4||A=5)?2:0")
  field(OOPT, "When Non-zero")
  field(OUT, "$(P)$(R)MAutoRange-Sts.PROC")
}

record(mbbi, "$(P)$(R)MeasFnc-Sts"){
  field(ASG, "Reserved")
  field(DESC, "Measurement function selection Sts")
  field(ZRST, "NONE")
  field(ONST, "DC_VOLTAGE")
  field(TWST, "AC_VOLTAGE")
  field(THST, "DC_CURRENT")
  field(FRST, "AC_CURRENT")
  field(FVST, "RESISTANCE")
  field(SXST, "4W_RESISTANCE")
  field(SVST, "DIODE")
  field(EIST, "CAPACITANCE")
  field(NIST, "TEMPERATURE")
  field(TEST, "CONTINUITY")
  field(ELST, "ACV_FREQUENCY")
  field(TVST, "ACV_PERIOD")
  field(TTST, "DCV_RATIO")
  field(DTYP, "stream")
  field(INP, "@dmm6500.proto meas_func_get $(PORT)")
}

########################################################################
# Autozero
# Desc: Autozero function enable/disable and once command.
#	Only some measurement functions allow the use of autozero.

# The protocol enables/disables autozero for the SELECTED MEASUREMENT
record(bo, "$(P)$(R)AutoZero-Sel"){
  field(DESC, "Enable/disalbe Autozero")
  field(ZNAM, "OFF")
  field(ONAM, "ON")
  field(DTYP, "stream")
  field(OUT, "@dmm6500.proto azero_en_set $(PORT)")
  field(FLNK, "$(P)$(R)AutoZero-Sts")
}

record(bi, "$(P)$(R)AutoZero-Sts"){
  field(ASG, "Reserved")
  field(DESC, "Enable/disalbe Autozero Sts")
  field(ZNAM, "OFF")
  field(ONAM, "ON")
  field(DTYP, "stream")
  field(INP, "@dmm6500.proto azero_en_get $(PORT)")
}

record(bo, "$(P)$(R)AZeroOnce-Cmd"){
  field(DESC, "Autozero once command")
  field(ZNAM, "OFF")
  field(ONAM, "ON")
  field(HIGH, "0.5")
  field(FLNK, "$(P)$(R)AZeroOnceCalc")
}

record(calcout, "$(P)$(R)AZeroOnceCalc"){
  field(ASG, "Reserved")
  field(DESC, "Autozero once calc")
  field(INPA, "$(P)$(R)AZeroOnce-Cmd.VAL")
  field(CALC, "A")
  field(OOPT, "When Non-zero")
  field(DTYP,"stream")
  field(OUT, "@dmm6500.proto azero_once_set $(PORT)")
}


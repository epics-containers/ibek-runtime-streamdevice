  field(DESC, "Num. of readings in defbuffer1")
  field(EGU, "rdgs")
  field(DTYP, "stream")
  field(INP, "@dmm6500.proto trace_cnt_get(1) $(PORT)")
  field(ADEL, "-1")
  field(MDEL, "-1")
  field(FLNK, "$(P)$(R)StartBuff1-Mon")
}

record(longin, "$(P)$(R)StartBuff1-Mon"){
  field(DESC, "Defbuffer1 start index")
  field(ADEL, "-1")
  field(MDEL, "-1")
  field(DTYP, "stream")
  field(INP, "@dmm6500.proto trace_start_get(1) $(PORT)")
  field(FLNK, "$(P)$(R)EndBuff1-Mon")
}

record(longin, "$(P)$(R)EndBuff1-Mon"){
  field(DESC, "Defbuffer1 end index")
  field(ADEL, "-1")

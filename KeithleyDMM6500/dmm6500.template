  field(FLNK, "$(P)$(R)SizeBuff1-RB")
}

record(longout, "$(P)$(R)StartRead1-SP"){
  field(DESC, "Defbuffer1 reading request start index")
  field(DRVL, "1")
  field(VAL, "1")
}


record(longout, "$(P)$(R)EndRead1-SP"){
  field(DESC, "Defbuffer1 reading request end index")
  field(DRVL, "1")
  field(VAL, "1")
  field(FLNK, "$(P)$(R)HighVEndIn")
}

record(calcout, "$(P)$(R)HighVEndIn"){
  field(DESC, "Calc DRVH Buffer1 reading end index")
  field(INPA, "$(P)$(R)EndRead1-SP.VAL")
  field(INPB, "$(P)$(R)EndBuff1-Mon.VAL")
  field(CALC, "(A>B)?B:A")
  field(OUT, "$(P)$(R)EndRead1-RB.VAL PP")
}

record(longin, "$(P)$(R)EndRead1-RB") {
  field(DESC, "Buffer1 reading end index")  
  field(VAL, "10000")
}


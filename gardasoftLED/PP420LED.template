record(fanout, "$(P):LOAD_PROFILE")
{
  field(DESC, "Load Selected Profile")
  field(SELM, "Specified")
  field(LNK1, "$(P):PR1:LOAD")
  field(LNK2, "$(P):PR2:LOAD")
  field(LNK3, "$(P):PR3:LOAD")
  field(LNK4, "$(P):PR4:LOAD")
  field(LNK5, "$(P):PR5:LOAD")
  field(LNK6, "$(P):PR6:LOAD")
}

record(sseq, "$(P):APPLY_PROFILE")
{
  field(DESC, "Load and Apply Selected Profile")
  field(DOL1, "1")
  field(LNK1, "$(P):LOAD_PROFILE.PROC CA")
  field(WAIT1,"Wait")
  field(DOL2, "1")
  field(LNK2, "$(P):APPLY CA")
  field(WAIT2, "Wait")
}




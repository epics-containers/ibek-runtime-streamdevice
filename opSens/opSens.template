record(bo, "$(device):STOP")
{
    field(DTYP, "stream")
    field(OUT,  "@opSensTempSens.proto stop() $(tty)")
}

record(ai, "$(device):CHANS")
{
    field(DTYP, "stream")
    field(INP, "@opSensTempSens.proto getChanCount() $(tty)")
    field(SCAN, "Passive")
}

record(ai, "$(device):CH1OFF")
{
    field(DTYP, "stream")
    field(INP, "@opSensTempSens.proto getOff1() $(tty)")
    field(SCAN, "Passive")
}

record(ai, "$(device):CHECK")
{
    field(DTYP, "stream")
    field(INP, "@opSensTempSens.proto commCheck() $(tty)")
    field(SCAN, "Passive")
}

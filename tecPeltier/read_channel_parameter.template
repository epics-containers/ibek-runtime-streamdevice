    field(FTA, "STRING")
    field(SNAM, "$(CONVERT)")
    field(OUTA, "$(P):$(PARAM)2_RBV PP")
    field(FTVA, "$(FORMAT)")
}

record(ao, $(P):$(PARAM)2_RBV){
    field(PREC, "$(PREC)")
    field(EGU, "$(EGU)")
}
# End of support/tecPeltier/tecPeltier/Db/read_channel_parameter.template

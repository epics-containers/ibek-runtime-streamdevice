##### Target RBV updating (signal from autocontroller template) #####

# Receive and forward signal to refresh program targets
record(bo, "$(P):$(PROG):FETCH") {
    field(DESC, "refresh program targets")
    field(DOL, "$(P):FETCH PP")
    field(FLNK, "$(P):$(PROG):UPDATE")
}

# Top-level fanout to refresh program targets
record(fanout, "$(P):$(PROG):UPDATE") {
    field(DESC, "top-level refresh block")
    field(LNK1, "$(P):$(PROG):COL_1")
    field(LNK2, "$(P):$(PROG):COL_2")
    field(LNK3, "$(P):$(PROG):COL_3")
}

# First bottom-level fanout to refresh program targets
record(fanout, "$(P):$(PROG):COL_1") {
    field(DESC, "first refresh block")
    field(LNK1, "$(P):$(PROG):GS1_RBV")
    field(LNK2, "$(P):$(PROG):GS2_RBV")
    field(LNK3, "$(P):$(PROG):GS3_RBV")
    field(LNK4, "$(P):$(PROG):GS4_RBV")
    field(LNK5, "$(P):$(PROG):BMI_RBV")
    field(LNK6, "$(P):$(PROG):BMV_RBV")
}

# Second bottom-level fanout to refresh program targets
record(fanout, "$(P):$(PROG):COL_2") {
    field(DESC, "second refresh block")
    field(LNK1, "$(P):$(PROG):ACI_RBV")
    field(LNK2, "$(P):$(PROG):ACV_RBV")
    field(LNK3, "$(P):$(PROG):CHI_RBV")
    field(LNK4, "$(P):$(PROG):CHSI_RBV")
    field(LNK5, "$(P):$(PROG):DSI_RBV")
    field(LNK6, "$(P):$(PROG):DSV_RBV")
}

# Third bottom-level fanout to refresh program targets
record(fanout, "$(P):$(PROG):COL_3") {
    field(DESC, "third refresh block")
    field(LNK1, "$(P):$(PROG):EEI_RBV")
    field(LNK2, "$(P):$(PROG):EEV_RBV")
    field(LNK3, "$(P):$(PROG):FHI_RBV")
    field(LNK4, "$(P):$(PROG):FHSI_RBV")
    field(LNK5, "$(P):$(PROG):LFI_RBV")
    field(LNK6, "$(P):$(PROG):KPI_RBV")
}

# programParameters.template
#
# Program template for the Kaufman & Robinson ion beam auto controller.
# Assumed to be using streamDevice
#
# Author: Nicoletta De Maio
# Date:   July 2017
#

# Parameters:
# % macro, P,       EPICS PV prefix
# % macro, PORT,    asyn port
# % macro, PROG,    program number
# % macro, name,    object and gui association name
# % gui, $(name=), edm, programParameters.edl, P=$(P), TITLE=$(name=)

##### Parameter level (program control) #####

# Get gas channel 1 target flow value
record(ai, "$(P):$(PROG):GS1_RBV") {
    field(DTYP, "stream")
    field(DESC, "target gas flow 1")
    field(EGU, "SCCM")
    field(INP, "@kriIonBeam.proto getT($(P),GS1,$(PROG)) $(PORT)")
    field(PINI, "1")
    field(PREC, "1")
}

# Set gas channel 1 target flow value
record(ao, "$(P):$(PROG):GS1") {
    field(DTYP, "stream")
    field(DESC, "target gas flow 1")
    field(EGU, "SCCM")
    field(OUT, "@kriIonBeam.proto setT($(P),GS1,$(PROG)) $(PORT)")
    field(FLNK, "$(P):$(PROG):GS1_RBV")
    field(PREC, "1")
}


##### Target RBV updating #####

# Signal that parameter targets need to be refreshed
# (used in DOL field in records from other templates)
record(bo, "$(P):FETCH") {
    field(DESC, "dummy record for process forwarding")
}

##### Generic response handling #####

# Catch-all response field to display protocol mismatches
record(stringin, "$(P):RESPONSE") {
    field(DESC, "response from device")
}

# Direct access to the communication channel; useful for monitoring and debugging
record(asyn, "$(P):ASYN") {
    field(DESC, "direct line for monitoring and debugging")
    field(DTYP,"asynRecordDevice")
    field(PORT,"$(PORT)")
    field(ADDR,"0")
    field(OMAX,"80")
    field(IMAX,"80")
    field(OEOS,"\r")
    field(IEOS,"\r")
}

# Poll current program
record(mbbi, "$(P):PROG_RBV") {
    field(DTYP, "stream")
    field(DESC, "current program")
    field(INP, "@kriIonBeam.proto getProg($(P)) $(PORT)")
    field(SCAN, "1 second")
    field(ZRST, "Scratchpad")
    field(ONST, "Program 1")
    field(TWST, "Program 2")
    field(THST, "Program 3")
    field(FRST, "Program 4")
    field(PINI, "1")
}

# Set current program
record(mbbo, "$(P):PROG") {
    field(DTYP, "stream")
    field(DESC, "set ops mode")
    field(OUT, "@kriIonBeam.proto setProg($(P)) $(PORT)")
    field(ZRVL, "1")
    field(ZRST, "1")
    field(ONVL, "2")
    field(ONST, "2")
    field(TWVL, "3")
    field(TWST, "3")
    field(THVL, "4")
    field(THST, "4")
    field(FLNK, "$(P):FETCH")
}


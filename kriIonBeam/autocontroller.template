# autocontroller.template
#
# Top-level template for the Kaufman & Robinson ion beam auto controller.
# Assumed to be using streamDevice
#
# Author: Nicoletta De Maio
# Date:   July 2017
#

# Parameters:
# % macro, P,       EPICS PV prefix
# % macro, PORT,    asyn port
# % macro, name,    object and gui association name
# % gui, $(name=), edm, kriIonBeam.edl, P=$(P), TITLE=$(name=)

##### Controller level #####

# Poll remote control status
record(bi, "$(P):REMOTE_RBV") {
    field(DTYP, "stream")
    field(DESC, "current control mode")
    field(INP, "@kriIonBeam.proto getRemote($(P)) $(PORT)")
    field(SCAN, "1 second")
    field(ZNAM, "Local")
    field(ONAM, "Remote")
    field(PINI, "1")
}

# Set to remote or local control
record(mbbo, "$(P):REMOTE") {
    field(DTYP, "stream")
    field(DESC, "set control mode")
    field(OUT, "@kriIonBeam.proto setRemote($(P)) $(PORT)")
    field(ZRST, "Set Remote")
    field(ONST, "Set Local")
    field(VAL, "1")
}

# Poll controller identity
record(stringin, "$(P):IDENT") {
    field(DTYP, "stream")
    field(DESC, "controller identity")
    field(INP, "@kriIonBeam.proto getIdent() $(PORT)")
    field(SCAN, "10 second")
    field(PINI, "1")
}

# Reset the controller to Standby and Terse output mode
record(bo, "$(P):RESET") {
    field(DTYP, "stream")
    field(DESC, "reset controller")
    field(OUT, "@kriIonBeam.proto reset($(P)) $(PORT)")
}

# Poll error state
record(mbbi, "$(P):ERRSTATE") {
    field(DTYP, "stream")
    field(DESC, "most recent error")
    field(INP, "@kriIonBeam.proto getLastError($(P)) $(PORT)")
    field(SCAN, "1 second")
    field(ZRVL, "0")
    field(ZRST, "No error")
    field(ONVL, "2")
    field(ONST, "Open interlock")
    field(TWVL, "3")
    field(TWST, "Broken LFN filament")
    field(THVL, "4")
    field(THST, "Unit not ready")
    field(FRVL, "9")
    field(FRST, "No modbus comms")
    field(FVVL, "10")
    field(FVST, "Start fault")
    field(SXVL, "11")
    field(SXST, "Run fault")
    field(SVVL, "12")
    field(SVST, "Gas fault")
    field(EIVL, "13")
    field(EIST, "Internal comms error")
    field(NIVL, "25")
    field(NIST, "Broken neutr filament")
    field(TEVL, "26")
    field(TEST, "Grid supply beam fault")
    field(ELVL, "27")
    field(ELST, "Grid supply discharge flt")
    field(TVVL, "28")
    field(TVST, "Broken cathode")
    field(TTVL, "29")
    field(TTST, "Emission fault")
    field(PINI, "1")
}

# Poll beam and discharge system output state
record(mbbi, "$(P):OUTPUT_RBV") {
    field(DTYP, "stream")
    field(DESC, "current output state")
    field(INP, "@kriIonBeam.proto getOutput($(P)) $(PORT)")
    field(SCAN, "1 second")
    field(ZRVL, "0")
    field(ZRST, "Both standby")
    field(ONVL, "1")
    field(ONST, "No beam, Discharge on")
    field(TWVL, "11")
    field(TWST, "Both enabled")
    field(PINI, "1")
}

# Set beam and discharge system output state
record(mbbo, "$(P):OUTPUT") {
    field(DTYP, "stream")
    field(DESC, "set output state")
    field(OUT, "@kriIonBeam.proto setOutput($(P)) $(PORT)")
    field(ZRVL, "0")
    field(ZRST, "Both standby")
    field(ONVL, "1")
    field(ONST, "No beam, Discharge on")
    field(TWVL, "11")
    field(TWST, "Both enabled")
}


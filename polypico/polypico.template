##### StrobeA del ####

record(ai, "$(P):STROBE_A_DEL_RBV"){
  field(DESC, "Read strobe A del")
  field(VAL,  "")
}

record(calc, "$(P):STROBE_A_DEL_UM_RBV"){
  field(DESC, "Calc rbv strobe A del in um")
  field(A, "16") # 16.0 MHz  clock of the strobe timer 
  field(INPB, "$(P):STROBE_A_DEL_RBV CP")
  field(CALC, "B/A")
  field(PREC, "1")
}

record(ao, "$(P):STROBE_A_DEL_UM") {
  field(DESC, "SET strob A del in um")
  field(VAL,  "10")
  field(PREC, "1") 
  field(PINI, "YES")
}


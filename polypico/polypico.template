# % macro, P, Domain
# % macro, PORT, Asyn port name for stream device

#### Ping board #####

record(calcout, "$(P):PING_OK")
{
  field(DESC, "Ping works ok")
  field(INPA, "$(P):PING_BOARD.STAT CP")
  field(B, "")
  field(CALC, "A=B?1:0")
}

record(bo, "$(P):PING_BOARD") {
  field(DESC, "Ping board")
  field(DTYP, "stream")
  field(SCAN, "1 second")
  field(VAL,  "")
  field(PINI, "YES")
  field(OUT, "@polypico.proto ping_board($(P)) $(PORT) PP")
}

##### Frequency #####

record(ai, "$(P):FREQ_RBV"){
  field(DESC, "Read frequency")
  field(VAL,  "")
}

record(ao, "$(P):FREQ") {
  field(DESC, "Set frequency")
  field(DTYP, "stream")
  field(VAL,  "10") 
  field(PINI, "YES")
  field(OUT, "@polypico.proto set_frequency($(P)) $(PORT) PP")
}

##### Amplitude #####

record(ai, "$(P):AMPLITUDE_RBV"){
  field(DESC, "Store amplitude")
  field(VAL,  "")
}

record(calc, "$(P):AMPLITUDE_PRCTG_RBV"){
  field(DESC, "Calc rbv amplitude in percentage")
  field(A, "10")
  field(INPB, "$(P):AMPLITUDE_RBV CP")
  field(CALC, "B/A")
  field(PREC, "1")
}

record(ao, "$(P):AMPLITUDE_PRCTG"){
  field(DESC, "Set amplitude in prercentage")
  field(PINI, "YES")
  field(VAL, "10") 
  field(PREC, "1")
}

record(calcout, "$(P):AMPLITUDE_CALC"){
  field(DESC, "Calculate amplitude")
  field(A, "10")
  field(DTYP, "stream")
  field(INPB, "$(P):AMPLITUDE_PRCTG CP")
  field(CALC, "(A*B)")
  field(OUT, "@polypico.proto set_amplitude($(P)) $(PORT) PP")
  field(OOPT, "Every Time")
  field(DOPT, "Use CALC")
}


## \}
## \name Syringe soft mootor
## \{
##  \brief Soft motor record representing the syringe
##
record(motor, "$(P)$(R):LEFT:MOTOR") {
  field(DESC, "LEFT syringe")
  field(DTYP, "Soft Channel")
  field(DINP, "$(P)$(R):LEFT:DMOV NPP NMS")
# Input link for DMOV
  field(OUT, "$(P)$(R):LEFT:GO PP NMS")
# Link to "seq" record to set speed and write demand
  field(RDBL, "$(P)$(R):LEFT:POSTOEGU")
# Readback location
  field(STOO, "$(P)$(R):STOP PP NMS")
# STOP output link
  field(URIP, "1")
# Use readback from RDBL
  field(DIR, "0")
# Direction positive
  field(SCAN, "Passive")
  field(VBAS, "50")
# Minimum velocity
  field(VMAX, "$(LEFTSYRINGEVOL)")
# Maximum velocity is 1 second per full stroke = 1 syringe per second
  field(VELO, "50")
# Default velocity on startup
  field(EGU, "uL")
  field(PREC, "1")
  field(VAL, "0")
# Initialise VAL field to zero
# Fixed resolution: conversion performed in separate record
  field(MRES, "1")
  field(RRES, "1")
# Soft limits
  field(DHLM, "$(LEFTSYRINGEVOL)")
# High soft limit = full syringe volume
  field(DLLM, "0")
}

##
##  \brief Hack to set motor RRES = MRES.
##  Processed once at startup
##
record(ao, "$(P)$(R):LEFT:SETRRES") {
  field(DESC, "Set RRES = MRES")
  field(DOL, "$(P)$(R):LEFT:MOTOR.MRES NPP NMS")
  field(OMSL, "closed_loop")
  field(OUT, "$(P)$(R):LEFT:MOTOR.RRES CA")
}

##
## \brief Start move from soft motor
## \details This record gets processed when a move is initiated from the motor record
## It sets the velocity and writes the position demand
##
record(seq, "$(P)$(R):LEFT:GO") {
  field(DESC, "LEFT syringe: write velocity and demand")
# Calculate (then write) velocity
  field(DOL1, "1")
  field(LNK1, "$(P)$(R):LEFT:VELTORAW.PROC")
# Write demand
  field(DOL2, "1")
  field(LNK2, "$(P)$(R):LEFT:POSTORAW PP NMS")
}

## \}
##
## \brief Convert velocity from EGUs per second to seconds per full stroke
## ...and pass on to be written to device
##
record(calcout, "$(P)$(R):LEFT:VELTORAW") {
  field(DESC, "LEFT convert velocity")
  field(INPA, "$(P)$(R):LEFT:MOTOR.VELO NPP")
  field(INPB, "$(LEFTSYRINGEVOL)")
# Syringe volume
  field(CALC, "B/A")
# velocity (s per full stroke) = Syringe volume / velocity (volume per second)
  field(OUT, "$(P)$(R):LEFT:SETSPEED.VAL PP NMS")
# Write converted velocity
  field(SCAN, "Passive")
  field(EGU, "s/stroke")
  field(TPRO, "1")
}

##
## \brief Read in raw speed in seconds per full stroke
## ... and pass on to be written to device
##
record(longin, "$(P)$(R):LEFT:GETSPEED") {
  field(DTYP, "stream")
  field(INP, "@microlab500.proto getSpeed(B) $(PORT)")
  field(FLNK, "$(P)$(R):LEFT:VELTOEGU.PROC")
  field(EGU, "s/stroke")
}

##
## \brief Convert velocity from seconds per full stroke to EGUs per second
##
record(calcout, "$(P)$(R):LEFT:VELTOEGU") {
  field(DESC, "LEFT convert velocity")
  field(INPA, "$(P)$(R):LEFT:GETSPEED NPP")
  field(INPB, "$(LEFTSYRINGEVOL)")
# Syringe volume
  field(CALC, "B/A")
# velocity (volume per second) = Syringe volume / velocity (s per full stroke)
  field(SCAN, "Passive")
  field(EGU, "uL/s")
}

##
##  \name Set the syringe volume
##  \{
## Set syringe volume
record(longout, "$(P)$(R):LEFT:SVOL") {
  field(VAL, "$(LEFTSYRINGEVOL)")
  field(FLNK, "$(P)$(R):LEFT:DISTSVOL.PROC")
  field(EGU, "uL")
  field(DRVL, "1")
# Avoid division by zero
  field(DRVH, "1000000")
}

## Read back syringe volume
record(longin, "$(P)$(R):LEFT:SVOL:RBV") {
  field(VAL, "0")
  field(EGU, "uL")
}

## Distribute new volume to everywhere it's required
record(seq, "$(P)$(R):LEFT:DISTSVOL") {
# Syringe volume readback
  field(DOL1, "$(P)$(R):LEFT:SVOL NPP")
  field(LNK1, "$(P)$(R):LEFT:SVOL:RBV PP")
# Make sure offset is zero
  field(DO2, "0")
  field(DLY2, "1")
  field(LNK2, "$(P)$(R):LEFT:MOTOR.OFF NPP")
# Velocity calculations
  field(DOL3, "$(P)$(R):LEFT:SVOL")
  field(LNK3, "$(P)$(R):LEFT:VELTORAW.B PP")
  field(DOL4, "$(P)$(R):LEFT:SVOL")
  field(LNK4, "$(P)$(R):LEFT:VELTOEGU.B PP")
  field(DOL5, "$(P)$(R):LEFT:SVOL")
  field(LNK5, "$(P)$(R):LEFT:MOTOR.VMAX NPP")
  field(DOL6, "$(P)$(R):LEFT:SVOL")
  field(LNK6, "$(P)$(R):LEFT:MOTOR.DHLM NPP")
  field(DO7, "1")
  field(LNK7, "$(P)$(R):LEFT:MOTOR.SYNC")
}

## \}
## \name Greedy write of velocity from motor record
## \{
##  Monitor the VELO field of the soft motor
##  and write it staright to hardware when it changes
##  so that we can see the readback from the hardware
##  straight away and know it's happy with the value
##
record(calcout, "$(P)$(R):LEFT:COPYVELO") {
  field(DESC, "Write speed when VELO changes")
  field(INPA, "$(P)$(R):LEFT:MOTOR.VELO NPP")
  field(SCAN, ".1 second")
  field(CALC, "A")
  field(OOPT, "On Change")
  field(DOPT, "Use CALC")
  field(OUT, "$(P)$(R):LEFT:VELTORAW PP")
}

##
##  Same as above but runs once on init
##    Workaround because "On Change" DOPT doesn't seem to 
##    let me process once on init 
##
record(calcout, "$(P)$(R):LEFT:STARTUPVELO") {
  field(DESC, "Write velocity on startup")
  field(INPA, "$(P)$(R):LEFT:MOTOR.VELO NPP")
  field(SCAN, "Passive")
  field(CALC, "A")
  field(OOPT, "Every Time")
  field(DOPT, "Use CALC")
  field(OUT, "$(P)$(R):LEFT:VELTORAW PP")
  field(TPRO, "1")
}

## \}
## \name Convert between EGUs and counts
## \{
record(calcout, "$(P)$(R):LEFT:POSTOEGU") {
  field(DESC, "Convert position to EGU")
  field(INPA, "$(P)$(R):LEFT:GETSPOS CP")
  field(INPB, "$(P)$(R):LEFT:SVOL CP")
# Syringe volume
  field(INPC, "$(STROKESIZE)")
# Steps per stroke
  field(CALC, "A*B/C")
# position (volume) = position (steps) / steps per stroke * volume per stroke
  field(SCAN, "Passive")
  field(EGU, "uL/s")
}

record(calcout, "$(P)$(R):LEFT:POSTORAW") {
  field(DESC, "Convert position to steps")
  field(INPA, "$(P)$(R):LEFT:MOTOR.RVAL NPP")
  field(INPB, "$(P)$(R):LEFT:SVOL CP")
# Syringe volume
  field(INPC, "$(STROKESIZE)")
# Steps per stroke
  field(CALC, "A/B*C")
# position (steps) = position (volume) / volume per stroke * steps per stroke
  field(SCAN, "Passive")
  field(EGU, "steps")
  field(OUT, "$(P)$(R):LEFT:POSITION PP NMS")
}


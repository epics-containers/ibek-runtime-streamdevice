  field(OUT, "$(P)$(R):RIGHT:MOVOUT.VAL PP")
  field(FLNK, "$(P)$(R):RIGHT:MOVOUT")
  field(DOL, "$(P)$(R):RIGHT:CALC.VAL PP")
  field(OMSL, "closed_loop")
}

## \}
##
## \name To implement "Dispense" button
## \{
##
record(bo, "$(P)$(R):RIGHT:DISPENSE") {
  field(FLNK, "$(P)$(R):RIGHT:DISPENSEA")
}

record(ao, "$(P)$(R):RIGHT:DISPENSEA") {
  field(DESC, "drives syringe dispense")
  field(DTYP, "Soft Channel")
  field(OUT, "$(P)$(R):RIGHT:MOVIN.VAL")
  field(FLNK, "$(P)$(R):RIGHT:MOVIN")
  field(DOL, "$(P)$(R):RIGHT:CALC.VAL PP")
  field(OMSL, "closed_loop")
}

## \}
##
## \name Get valve position
## \{
##
record(longin, "$(P)$(R):RIGHT:GETVPOSA") {
  field(DTYP, "stream")
  field(INP, "@microlab500.proto positionV(C) $(PORT)")
}

## Make valve position readback human-readable
record(mbbi, "$(P)$(R):RIGHT:GETVPOS") {
  field(DESC, "Get valve position")
  field(DTYP, "Raw Soft Channel")
  field(INP, "$(P)$(R):RIGHT:GETVPOSA PP")
  field(ZRVL, "1")
  field(ONVL, "3")
  field(TWVL, "4")
  field(ONST, "Wash")
  field(TWST, "Ouput")
  field(VAL, "0")
  field(ZRST, "Input")
}

## \}
##
## \name Set valve position:
## \{
## Translate valve position for device
record(mbbo, "$(P)$(R):RIGHT:SETVPOS") {
  field(DESC, "Set valve position")
  field(DTYP, "Raw Soft Channel")
  field(OUT, "$(P)$(R):RIGHT:SETVPOSA PP")
  field(ZRVL, "1")
  field(ONVL, "3")
  field(TWVL, "4")
  field(ONST, "Wash")
  field(TWST, "Output")
  field(VAL, "0")
  field(ZRST, "Input")
}

## Write valve position to device
record(longout, "$(P)$(R):RIGHT:SETVPOSA") {
  field(DTYP, "stream")
  field(VAL, "0")
  field(OUT, "@microlab500.proto setvalve(C) $(PORT)")
  field(OMSL, "closed_loop")
}

## \}
##   Tasks required on startup
record(seq, "$(P)$(R):RIGHT:STARTUP") {
  field(LNK1, "$(P)$(R):RIGHT:RETURN.PROC")
#
#  Make sure the motor record is initialised properly
#
  field(DO2, "1")
  field(LNK2, "$(P)$(R):RIGHT:MOTOR.SYNC NPP")
#  field(LNK3, "$(P)$(R):$(SIDE):MOTOR.PROC")
#
#  Make sure velocity is written immediately
#
  field(DLY3, "0.1")
  field(LNK3, "$(P)$(R):RIGHT:VELTORAW.PROC")
}

##  \brief Performs polling
##  Disabled when DISABLEPOLL is set
record(fanout, "$(P)$(R):RIGHTSCAN") {
  field(SCAN, "1 second")
  field(SDIS, "$(P)$(R):DISABLEPOLL")
  field(LNK1, "$(P)$(R):RIGHT:GETSPOS")
  field(LNK2, "$(P)$(R):RIGHT:GETVPOS")
  field(LNK3, "$(P)$(R):RIGHT:GETSPEED")
}

##
## \name Write raw position:
## \{
## User input
record(longout, "$(P)$(R):RIGHT:POSITION") {
  field(OUT, "$(P)$(R):RIGHT:SETPOSITION PP")
  field(EGU, "Steps")
}

## Write raw absolute position to device
record(longout, "$(P)$(R):RIGHT:SETPOSITION") {
  field(DESC, "Control absolute position")
  field(DTYP, "stream")
  field(OUT, "@microlab500.proto move(C) $(PORT)")
  field(EGU, "steps")
}

## \}
##
##  \name Following records control the pumping mechanism
##    Move back and forth over the whole range until told to stop
## \{
##
record(seq, "$(P)$(R):RIGHT:PUMPSEQ") {
  field(SCAN, "Passive")
  field(SELM, "All")
  field(DOL1, "0")
  field(LNK1, "$(P)$(R):RIGHT:SETVPOS PP")
  field(DLY2, "1")
  field(DOL2, "1000")
  field(LNK2, "$(P)$(R):RIGHT:POSITION PP")
}

record(bo, "$(P)$(R):RIGHT:PUMP") {
  field(VAL, "1")
  field(ZNAM, "Pumping")
  field(ONAM, "Start Pump")
}

record(seq, "$(P)$(R):RIGHT:PUMPSEQ2") {
  field(SCAN, "Passive")
  field(SELM, "All")
  field(DOL1, "2")
  field(LNK1, "$(P)$(R):RIGHT:SETVPOS PP")
  field(DLY2, "1")
  field(DOL2, "0")
  field(LNK2, "$(P)$(R):RIGHT:POSITION PP")
}

record(calcout, "$(P)$(R):RIGHT:PUMPCTL") {
  field(SCAN, ".5 second")
  field(SDIS, "$(P)$(R):RIGHT:PUMP")
  field(CALC, "A=0 && B=0")
  field(INPA, "$(P)$(R):RIGHT:GETSPOS")
  field(INPB, "$(P)$(R):RIGHT:PUMP")
  field(OUT, "$(P)$(R):RIGHT:PUMPSEQ PP")
  field(OOPT, "Transition To Non-zero")
}

record(calcout, "$(P)$(R):RIGHT:PUMPCTL2") {
  field(SCAN, ".5 second")
  field(SDIS, "$(P)$(R):RIGHT:PUMP")
  field(CALC, "A=1000 && B=0")
  field(INPA, "$(P)$(R):RIGHT:GETSPOS")
  field(INPB, "$(P)$(R):RIGHT:PUMP")
  field(OUT, "$(P)$(R):RIGHT:PUMPSEQ2 PP")
  field(OOPT, "Transition To Non-zero")
}

## \}
## \name Syringe soft mootor
## \{
##  \brief Soft motor record representing the syringe
##
record(motor, "$(P)$(R):RIGHT:MOTOR") {
  field(DESC, "RIGHT syringe")
  field(DTYP, "Soft Channel")
  field(DINP, "$(P)$(R):RIGHT:DMOV NPP NMS")
# Input link for DMOV
  field(OUT, "$(P)$(R):RIGHT:GO PP NMS")
# Link to "seq" record to set speed and write demand
  field(RDBL, "$(P)$(R):RIGHT:POSTOEGU")
# Readback location
  field(STOO, "$(P)$(R):STOP PP NMS")
# STOP output link
  field(URIP, "1")
# Use readback from RDBL
  field(DIR, "0")
# Direction positive
  field(SCAN, "Passive")
  field(VBAS, "50")
# Minimum velocity
  field(VMAX, "$(RIGHTSYRINGEVOL)")
# Maximum velocity is 1 second per full stroke = 1 syringe per second
  field(VELO, "50")
# Default velocity on startup
  field(EGU, "uL")
  field(PREC, "1")
  field(VAL, "0")
# Initialise VAL field to zero
# Fixed resolution: conversion performed in separate record
  field(MRES, "1")
  field(RRES, "1")
# Soft limits
  field(DHLM, "$(RIGHTSYRINGEVOL)")
# High soft limit = full syringe volume
  field(DLLM, "0")
}

##
##  \brief Hack to set motor RRES = MRES.
##  Processed once at startup
##
record(ao, "$(P)$(R):RIGHT:SETRRES") {
  field(DESC, "Set RRES = MRES")
  field(DOL, "$(P)$(R):RIGHT:MOTOR.MRES NPP NMS")
  field(OMSL, "closed_loop")
  field(OUT, "$(P)$(R):RIGHT:MOTOR.RRES CA")
}

##
## \brief Start move from soft motor
## \details This record gets processed when a move is initiated from the motor record
## It sets the velocity and writes the position demand
##
record(seq, "$(P)$(R):RIGHT:GO") {
  field(DESC, "RIGHT syringe: write velocity and demand")
# Calculate (then write) velocity
  field(DOL1, "1")
  field(LNK1, "$(P)$(R):RIGHT:VELTORAW.PROC")
# Write demand
  field(DOL2, "1")
  field(LNK2, "$(P)$(R):RIGHT:POSTORAW PP NMS")
}

## \}
##
## \brief Convert velocity from EGUs per second to seconds per full stroke
## ...and pass on to be written to device
##
record(calcout, "$(P)$(R):RIGHT:VELTORAW") {
  field(DESC, "RIGHT convert velocity")
  field(INPA, "$(P)$(R):RIGHT:MOTOR.VELO NPP")
  field(INPB, "$(RIGHTSYRINGEVOL)")
# Syringe volume
  field(CALC, "B/A")
# velocity (s per full stroke) = Syringe volume / velocity (volume per second)
  field(OUT, "$(P)$(R):RIGHT:SETSPEED.VAL PP NMS")
# Write converted velocity
  field(SCAN, "Passive")
  field(EGU, "s/stroke")
  field(TPRO, "1")
}

##
## \brief Read in raw speed in seconds per full stroke
## ... and pass on to be written to device
##
record(longin, "$(P)$(R):RIGHT:GETSPEED") {
  field(DTYP, "stream")
  field(INP, "@microlab500.proto getSpeed(C) $(PORT)")
  field(FLNK, "$(P)$(R):RIGHT:VELTOEGU.PROC")
  field(EGU, "s/stroke")
}

##
## \brief Convert velocity from seconds per full stroke to EGUs per second
##
record(calcout, "$(P)$(R):RIGHT:VELTOEGU") {
  field(DESC, "RIGHT convert velocity")
  field(INPA, "$(P)$(R):RIGHT:GETSPEED NPP")
  field(INPB, "$(RIGHTSYRINGEVOL)")
# Syringe volume
  field(CALC, "B/A")
# velocity (volume per second) = Syringe volume / velocity (s per full stroke)
  field(SCAN, "Passive")
  field(EGU, "uL/s")
}

##
##  \name Set the syringe volume
##  \{
## Set syringe volume
record(longout, "$(P)$(R):RIGHT:SVOL") {
  field(VAL, "$(RIGHTSYRINGEVOL)")
  field(FLNK, "$(P)$(R):RIGHT:DISTSVOL.PROC")
  field(EGU, "uL")
  field(DRVL, "1")
# Avoid division by zero
  field(DRVH, "1000000")
}

## Read back syringe volume
record(longin, "$(P)$(R):RIGHT:SVOL:RBV") {
  field(VAL, "0")
  field(EGU, "uL")
}

## Distribute new volume to everywhere it's required
record(seq, "$(P)$(R):RIGHT:DISTSVOL") {
# Syringe volume readback
  field(DOL1, "$(P)$(R):RIGHT:SVOL NPP")
  field(LNK1, "$(P)$(R):RIGHT:SVOL:RBV PP")
# Make sure offset is zero
  field(DO2, "0")
  field(DLY2, "1")
  field(LNK2, "$(P)$(R):RIGHT:MOTOR.OFF NPP")
# Velocity calculations
  field(DOL3, "$(P)$(R):RIGHT:SVOL")
  field(LNK3, "$(P)$(R):RIGHT:VELTORAW.B PP")
  field(DOL4, "$(P)$(R):RIGHT:SVOL")
  field(LNK4, "$(P)$(R):RIGHT:VELTOEGU.B PP")
  field(DOL5, "$(P)$(R):RIGHT:SVOL")
  field(LNK5, "$(P)$(R):RIGHT:MOTOR.VMAX NPP")
  field(DOL6, "$(P)$(R):RIGHT:SVOL")
  field(LNK6, "$(P)$(R):RIGHT:MOTOR.DHLM NPP")
  field(DO7, "1")
  field(LNK7, "$(P)$(R):RIGHT:MOTOR.SYNC")
}

## \}
## \name Greedy write of velocity from motor record
## \{
##  Monitor the VELO field of the soft motor
##  and write it staright to hardware when it changes
##  so that we can see the readback from the hardware
##  straight away and know it's happy with the value
##
record(calcout, "$(P)$(R):RIGHT:COPYVELO") {
  field(DESC, "Write speed when VELO changes")
  field(INPA, "$(P)$(R):RIGHT:MOTOR.VELO NPP")
  field(SCAN, ".1 second")
  field(CALC, "A")
  field(OOPT, "On Change")
  field(DOPT, "Use CALC")
  field(OUT, "$(P)$(R):RIGHT:VELTORAW PP")
}

##
##  Same as above but runs once on init
##    Workaround because "On Change" DOPT doesn't seem to 
##    let me process once on init 
##
record(calcout, "$(P)$(R):RIGHT:STARTUPVELO") {
  field(DESC, "Write velocity on startup")
  field(INPA, "$(P)$(R):RIGHT:MOTOR.VELO NPP")
  field(SCAN, "Passive")
  field(CALC, "A")
  field(OOPT, "Every Time")
  field(DOPT, "Use CALC")
  field(OUT, "$(P)$(R):RIGHT:VELTORAW PP")
  field(TPRO, "1")
}

## \}
## \name Convert between EGUs and counts
## \{
record(calcout, "$(P)$(R):RIGHT:POSTOEGU") {
  field(DESC, "Convert position to EGU")
  field(INPA, "$(P)$(R):RIGHT:GETSPOS CP")
  field(INPB, "$(P)$(R):RIGHT:SVOL CP")
# Syringe volume
  field(INPC, "$(STROKESIZE)")
# Steps per stroke
  field(CALC, "A*B/C")
# position (volume) = position (steps) / steps per stroke * volume per stroke
  field(SCAN, "Passive")
  field(EGU, "uL/s")
}

record(calcout, "$(P)$(R):RIGHT:POSTORAW") {
  field(DESC, "Convert position to steps")
  field(INPA, "$(P)$(R):RIGHT:MOTOR.RVAL NPP")
  field(INPB, "$(P)$(R):RIGHT:SVOL CP")
# Syringe volume
  field(INPC, "$(STROKESIZE)")
# Steps per stroke
  field(CALC, "A/B*C")
# position (steps) = position (volume) / volume per stroke * steps per stroke
  field(SCAN, "Passive")
  field(EGU, "steps")
  field(OUT, "$(P)$(R):RIGHT:POSITION PP NMS")
}


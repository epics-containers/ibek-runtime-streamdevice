# Ensure polling is enabled
  field(DLY5, "1.0")
  field(DO5, "0")
  field(LNK5, "$(P)$(R):DISABLEPOLL")
# Notify connecting finished
  field(DO6, "0")
  field(LNK6, "$(P)$(R):CONNECTING PP")
  field(PINI, "RUN")
}

## Bit to show we're starting up, used on screen
record(bo, "$(P)$(R):CONNECTING") {
  field(DESC, "Starting up status bit")
  field(VAL, "0")
}


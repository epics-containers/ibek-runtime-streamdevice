# % macro, P, Device prefix
# % macro, R, Device suffix
# % macro, PORT, Asyn port name for comms
# % gui, $(name=), edm, debenOF.edl, device=$(P)$(R)

## \name Interface for Zebra
## \{

## (deprecated) Dummy soft motor for the purpose of telling Zebra what the resolution is
record(motor, "$(P)$(R):DUMMYMOTOR") {
    field(DESC, "Dummy motor to give zebra MRES")
    field(DTYP, "Soft Channel")
    field(MRES, "0.001")
    field(ERES, "0.001")
    field(EGU, "deg")
    field(OFF, "0")
}

## Required for Zebra to read position from encoder
record(stringout, "$(P)$(R):TOP:MOTOR:SCALE") {
    field(PINI, "YES")
    field(VAL, "1")
}
## Required for Zebra to read position from encoder
record(stringout, "$(P)$(R):BOT:MOTOR:SCALE") {
    field(PINI, "YES")
    field(VAL, "1")
}
## Required for Zebra to read position from encoder
record(stringout, "$(P)$(R):LIN:MOTOR:SCALE") {
    field(PINI, "YES")
    field(VAL, "1")
}

## \}

## \name Global commands & readbacks
## \{

## \brief Full system reset
## \details ! Power off servos first or you'll end up in a bad state and 
## will have to power cycle the controller
record(bo, "$(P)$(R):RESET") {
	field(DESC, "Full system reset")
	field(DTYP, "stream")
 	field(OUT, "@debenOF.proto reset $(PORT)")
}
## Power on all servos
record(bo, "$(P)$(R):SERVOON") {
	field(DESC, "Power on servos")
	field(DTYP, "stream")
 	field(OUT, "@debenOF.proto servoOn $(PORT)")
}
## Power off all servos
record(bo, "$(P)$(R):SERVOOFF") {
	field(DESC, "Power off servos")
	field(DTYP, "stream")
 	field(OUT, "@debenOF.proto servoOff $(PORT)")
}
## Read timestamp from streamed data
record(longin, "$(P)$(R):TIMESTAMP") {
	field(DESC, "Read timestamp")
    field(EGU, "ms")
}
## Read tension force from streamed data
# % archiver 10 Monitor
record(ai, "$(P)$(R):TENSIONFORCE") {
    field(DESC, "Read tension force")
    field(EGU, "N")
    field(SCAN, "Passive")
    field(PREC, "4")
}
## Read torsion force from streamed data
# % archiver 10 Monitor
record(ai, "$(P)$(R):TORSIONFORCE") {
    field(DESC, "Read torsion force")
    field(EGU, "N")
    field(PREC, "4")
}

## Parse global status
record(longin, "$(P)$(R):STATUS") {
    field(DESC, "Parse status")
    field(DTYP, "stream")
    field(SCAN, "I/O Intr")
    field(INP, "@debenOF.proto wholeStatus($(P)$(R)) $(PORT)")
    field(FLNK, "$(P)$(R):CALCSTAT")
}
## Extract Done Moving bits from global status
record(seq, "$(P)$(R):CALCSTAT") {
	field(DESC, "Calculate DMOVs")
	field(LNK1, "$(P)$(R):TOP:DMOV.PROC")
	field(SCAN, "Passive")
	field(LNK2, "$(P)$(R):BOT:DMOV.PROC")
	field(SCAN, "Passive")
	field(LNK3, "$(P)$(R):LIN:DMOV.PROC")
	field(SCAN, "Passive")
}

## Gloabl stop command
record(bo, "$(P)$(R):STOP") {
    field(DESC, "Stop all motion")
    field(DTYP, "stream")
    field(OUT, "@debenOF.proto stop $(PORT)")
}
## \}

## \name Control of top rotation
## \{

## Read top position from streamed data
record(ai, "$(P)$(R):TOP:RBV") {
    field(DESC, "Read top position")
    field(EGU, "deg")
    field(PREC, "4")
}
## Set top rotation demand and start move
record(ao, "$(P)$(R):TOP:SETPOS") {
    field(DESC, "Top rotation")
    field(DTYP, "stream")
    field(EGU, "deg")
    field(PREC, "4")
    field(OUT, "@debenOF.proto moveTop $(PORT)")
}

## Soft motor for top rotation
record(motor, "$(P)$(R):TOP:MOTOR") {
	field(DESC, "Top rotation")
	field(DTYP, "Soft Channel")
	field(DINP, "$(P)$(R):TOP:DMOVA NPP")
	field(OUT, "$(P)$(R):TOP:GO PP")
	field(RDBL, "$(P)$(R):TOP:RBV.VAL") # Readback location
	field(STOO, "$(P)$(R):STOP PP NMS") # STOP output link
	field(URIP, "1") # Use readback from RDBL
	field(DIR, "0") # Direction positive
	field(VBAS, "0.1") # Minimum velocity
	field(VMAX, "360")
	field(VELO, "10") # Default velocity on startup
	field(EGU, "deg")
	field(PREC, "4")
	field(MRES, "-0.001")
	field(ERES, "0.001")
	field(RRES, "1")
# Soft limits
	field(DHLM, "999999999") 
	field(DLLM, "-999999999")
	field(RTRY, "0")
}

## Write velocity and position demands 
record(seq, "$(P)$(R):TOP:GO"){
  field(DESC, "Top: write demands")
# Write velocity
  field(DOL1, "$(P)$(R):TOP:MOTOR.VELO NPP")
  field(LNK1, "$(P)$(R):TOP:SETSPEED PP")
# Write demand
  field(DLY2, "0.1")
  field(DOL2, "$(P)$(R):TOP:MOTOR.DVAL NPP")
  field(LNK2, "$(P)$(R):TOP:SETPOS PP")
}
## Extract done moving bit for top rotation
record(calcout, "$(P)$(R):TOP:DMOV") {
	field(DESC, "Top done moving calc")
	field(INPA, "$(P)$(R):STATUS NPP")
	field(INPB, "8")
	field(DTYP, "Soft Channel")
	field(CALC, "(A&B)==8")
	field(OOPT, "On Change")
	field(DOPT, "Use CALC")
	field(OUT, "$(P)$(R):TOP:DMOVA PP")
}
## bi to hold result of :TOP:DMOV
record(bi, "$(P)$(R):TOP:DMOVA") {
	field(DESC, "Top done moving")
	field(ZNAM, "Moving")
	field(ONAM, "Done")
}
## Write speed for top
record(ao, "$(P)$(R):TOP:SETSPEED") {
    field(DESC, "Set top speed")
    field(DTYP, "stream")
    field(EGU, "deg/s")
    field(PREC, "4")
    field(OUT, "@debenOF.proto setSpeedTop $(PORT)")
}
## Zero top position
record(bo, "$(P)$(R):TOP:SETORIGIN") {
    field(DESC, "Set top origin")
    field(DTYP, "stream")
    field(OUT, "@debenOF.proto setOriginTop $(PORT)")
}

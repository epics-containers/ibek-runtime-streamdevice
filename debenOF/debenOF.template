# Parse response to a register read.
record(aSub, "$(P)$(R):PARSEREPLY") {
	field(DESC, "Parse response")
#	field(INPA, "$(P)$(R):REPLY.VAL NPP")
	field(FTA, "UCHAR")
	field(NOA, "256")
	field(INAM, "mySubInit")
	field(SNAM, "parseStatusString")
	field(FTVA, "LONG")
	field(FTVB, "FLOAT")
	field(NOVA, "1")
	field(NOVB, "1")
	field(OUTA, "$(P)$(R):REGNUM PP")
	field(OUTB, "$(P)$(R):REGVAL PP")
#	field(TPRO, "1")
}

record(longout, "$(P)$(R):REGNUM") {
    field(DESC, "Register number")
}
record(ao, "$(P)$(R):REGVAL") {
    field(DESC, "Register value")
}














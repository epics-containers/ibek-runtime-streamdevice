## \name Control of linear motion
## \{

## Read linear position from streamed data
record(ai, "$(P)$(R):LIN:RBV") {
    field(DESC, "Read linear position")
    field(EGU, "um")
    field(PREC, "4")
}

## Extract done moving bit for linear motion
record(calcout, "$(P)$(R):LIN:DMOV") {
	field(DESC, "Lin done moving calc")
	field(INPA, "$(P)$(R):STATUS NPP")
	field(INPB, "32768")
	field(DTYP, "Soft Channel")
	field(CALC, "(A&B)==32768")
	field(OOPT, "On Change")
	field(DOPT, "Use CALC")
	field(OUT, "$(P)$(R):LIN:DMOVA PP")
}
## bi to hold result of :LIN:DMOV
record(bi, "$(P)$(R):LIN:DMOVA") {
	field(DESC, "Lin done moving")
	field(ZNAM, "Moving")
	field(ONAM, "Done")
}
## Soft motor for linear motion
# % archiver 10 Monitor
record(motor, "$(P)$(R):LIN:MOTOR") {
	field(DESC, "Linear motion")
	field(DTYP, "Soft Channel")
	field(DINP, "$(P)$(R):LIN:DMOVA NPP")
	field(OUT, "$(P)$(R):LIN:GO PP")
	field(RDBL, "$(P)$(R):LIN:RBV.VAL") # Readback location
	field(STOO, "$(P)$(R):STOP PP NMS") # STOP output link
	field(URIP, "1") # Use readback from RDBL
	field(DIR, "0") # Direction positive
	field(VBAS, "0.1") # Minimum velocity
	field(VMAX, "360")
	field(VELO, "0.1") # Default velocity on startup
	field(EGU, "mm")
	field(PREC, "4")
	field(MRES, "0.0001")
	field(ERES, "0.0001")
	field(RRES, "1")
# Soft limits
	field(DHLM, "999999999") 
	field(DLLM, "-999999999")
	field(RTRY, "0")
}
## Calibrate velocity demand
record(calcout, "$(P)$(R):LIN:VELOC") {
	field(DESC, "Calibrate velocity")
	field(INPA, "$(P)$(R):LIN:MOTOR.VELO NPP")
	field(INPB, "1000.0")
	field(CALC, "A*B")
	field(OOPT, "Every Time")
	field(DOPT, "Use CALC")
	field(OUT, "$(P)$(R):LIN:SETSPEED PP")
}
## Write velocity and position demands for linear motion
record(seq, "$(P)$(R):LIN:GO"){
  field(DESC, "Lin: write demands")
# Calibrate and write velocity
  field(DOL1, "1")
  field(LNK1, "$(P)$(R):LIN:VELOC.PROC")
# Write demand
  field(DLY2, "0.1")
  field(DOL2, "$(P)$(R):LIN:MOTOR.DVAL NPP")
  field(LNK2, "$(P)$(R):LIN:SETPOS PP")
}
## Write linear position demand
record(ao, "$(P)$(R):LIN:SETPOS") {
    field(DESC, "Linear position")
    field(DTYP, "stream")
    field(EGU, "mm")
    field(PREC, "4")
    field(OUT, "@debenOF.proto moveLinear $(PORT)")
}
## Write linear speed demand
record(ao, "$(P)$(R):LIN:SETSPEED") {
    field(DESC, "Set linear speed")
    field(DTYP, "stream")
    field(EGU, "um/s")
    field(PREC, "4")
    field(OUT, "@debenOF.proto setSpeedLinear $(PORT)")
}

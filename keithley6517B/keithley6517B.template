
# Macros:
#% macro, P, Device Prefix
#% macro, R, Device Suffix
#% macro, PORT, Asyn Port name
#% macro, A, Timeout
# This associates the template with an edm screen
# % gui, $(PORT), edm, keithley6517B.edl, P=$(P),R=$(R)



#
# Basic SCPI (IEEE488.2) commands
#
record(waveform, "$(P)$(R)IDN")
{
    field(DESC, "SCPI identification string")
    field(DTYP, "stream")
    field(INP,  "@keithley6517B.proto getIDN(119) $(PORT) $(A)")
    #field(PINI, "YES")
    field(FTVL, "CHAR")
    field(NELM, "120")
}
record(bo, "$(P)$(R)RST")
{
    field(DESC, "SCPI Reset")
    field(DTYP, "stream")
    field(OUT,  "@keithley6517B.proto cmd(*RST) $(PORT) $(A)")
}

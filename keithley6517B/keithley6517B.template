    field(ONST, "Zero Check Enabled")
    field(TWVL, "2")
    field(TWST, "Overflow")
    field(THVL, "3")
    field(THST, "Underflow")
    field(FRVL, "4")
    field(FRST, "Reference (Rel)")
    field(FVVL, "5")
    field(FVST, "Out of Limit")
    #field(PINI, "YES")
}


# The current measurement range
record(ai, "$(P)$(R)RangeRBV")
{
    field(DESC, "Source voltage readback")

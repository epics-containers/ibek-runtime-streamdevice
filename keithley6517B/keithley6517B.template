record(bo, "$(P)$(R)ArmContinuous")
{
    field(DESC, "Arm device continuously")
    field(DTYP, "stream")
    field(OUT,  "@keithley6517B.proto setArmContinuous(OUTP:STAT) $(PORT) $(A)")
    field(ZNAM, "Off")
    field(ONAM, "On")
    field(FLNK, "$(P)$(R)ReadSettings")
}
record(bi, "$(P)$(R)ArmContinuousRBV")
{
    field(DESC, "Arm device continuously?")
    field(DTYP, "stream")
    field(INP,  "@keithley6517B.proto getArmContinuous(OUTP:STAT) $(PORT) $(A)")
    field(ZNAM, "Off")
    field(ONAM, "On")
    #field(PINI, "YES")
}

# Calculation record to identify whether the device
# is armed - and the user has enabled polling/comms.
# The measurements can only be taken if both conditions are true.
record(calc, "$(P)$(R)ArmPollCalc")
{
    field(DESC, "Check for arm and ena")
    field(INPA, "$(P)$(R)ArmContinuousRBV CP")
    field(INPB, "$(P)$(R)EnaPoll CP")
    field(CALC, "A&&B")
}

record(ai, "$(P)$(R)Measurement")
{
    field(DESC, "Measure current")
    field(DTYP, "stream")
    field(INP,  "@keithley6517B.proto freshMeasurement($(P)$(R)) $(PORT) $(A)")
    field(PREC, "5")
    field(SDIS, "$(P)$(R)ArmPollCalc")
    field(DISV, "0")
}

# Measurement units
record(mbbi, "$(P)$(R)EGU")
{
    field(DESC, "Measurement units")
    field(ZRVL, "0")
    field(ZRST, "Volt")
    field(ONVL, "1")
    field(ONST, "Amps")
    field(TWVL, "2")
    field(TWST, "Ohms")
    field(THVL, "3")
    field(THST, "OHMCM (Volume)")
    field(FRVL, "4")
    field(FRST, "OHMSQ (Surface)")
    field(FVVL, "5")
    field(FVST, "%/V")
    field(SXVL, "6")
    field(SXST, "Coulombs")
    #field(PINI, "YES")
}

# Measurement status
record(mbbi, "$(P)$(R)STAT")
{
    field(DESC, "Measurement units")
    field(ZRVL, "0")
    field(ZRST, "Normal")

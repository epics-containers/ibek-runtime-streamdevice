######### Scan and readout control ######################
#
# Two paths for polling: data poll and settings poll.
#
record(bo, "$(P)$(R)EnaPoll")
{
   field(DESC, "Enable read polling")
   field(ZNAM, "disable")
   field(ONAM, "enable")
   field(VAL, "1")
   #field(PINI, "YES")
}

record(fanout, "$(P)$(R)ReadSettings")
{
   field(DESC, "Process all read fields")
   field(LNK1, "$(P)$(R)FuncRBV")
   field(LNK2, "$(P)$(R)SourceEnableRBV")
   field(LNK3, "$(P)$(R)SourceVoltageRBV")
   field(LNK4, "$(P)$(R)VSourceRangeRBV")
   field(LNK5, "$(P)$(R)ArmContinuousRBV")
   field(LNK6, "$(P)$(R)RangeRBV")
   field(FLNK, "$(P)$(R)ReadSettings2")
   field(SDIS, "$(P)$(R)EnaPoll")
   field(DISV, "0")
}
record(fanout, "$(P)$(R)ReadSettings2")
{
   field(DESC, "Process all read fields")
   field(LNK1, "$(P)$(R)DispTop")
   field(LNK2, "$(P)$(R)DispBottom")
   field(LNK3, "$(P)$(R)IntRBV")
   #field(LNK4, "$(P)$(R)")
   #field(LNK5, "$(P)$(R)")
   #field(LNK6, "$(P)$(R)")
}


## Measurement configuration
record(mbbo, "$(P)$(R)Func")
{
    field(DESC, "Measurement function")
    field(DTYP, "stream")
    field(OUT,  "@keithley6517B.proto setFunction $(PORT) $(A)")
    field(ZRVL, "0")
    field(ZRST, "Voltage")
    field(ONVL, "1")
    field(ONST, "Current")
    field(TWVL,"2")
    field(TWST,"Resistance")
    field(THVL,"3")
    field(THST,"Charge")
    field(FLNK, "$(P)$(R)ReadSettings")
}
record(mbbi, "$(P)$(R)FuncRBV")
{
    field(DESC, "Measurement function")
    field(DTYP, "stream")
    field(INP,  "@keithley6517B.proto getFunction $(PORT) $(A)")
    field(ZRVL, "0")
    field(ZRST, "Voltage")
    field(ONVL, "1")
    field(ONST, "Current")
    field(TWVL,"2")
    field(TWST,"Resistance")
    field(THVL,"3")
    field(THST,"Charge")
    #field(PINI, "YES")
}

record(ao, "$(P)$(R)Int")

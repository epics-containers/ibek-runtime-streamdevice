# File pfeifferTC400.template
#
# % macro, __doc__, Support for Pfeiffer TC400 & TC110 turbo pump controllers supplied as part of Pfeiffer turbo pumps like the HiPace series.
#
# Linda Pratt, March 2015
#
# Pfeiffer has "Control command" parameters, "Status request" parameters
# and "Set value settings" parameters, name component, CTL, STS, SVS respectively.
#
# % macro, P,            Mandatory. Device prefix for record names.
# % macro, R,            Mandatory. Record name prefix.
# % macro, port,         Mandatory. Name of the serial port the device is on.
# % macro, TC110,        Optional.  Whether actually a TC110, which lacks some features.          0 or 1.     Defaults to zero (i.e. assumes TC400).
# % macro, unitaddr,     Optional.  Three decimal digit unit number in the RS 485 addressing.     001 to 255. Defaults to 001.
# % macro, pump_model,   Optional.  Model of the pump.  For GUI information, makes no difference.             Defaults to Unknown.
# % macro, pump_descr,   Optional.  Description string for the pump.  Record location, function, etc.         Defaults to Pfeiffer turbo pump.
# % macro, DISABLED,     Optional.  Set to 1 to disable comms.  Defaults to 0 (enabled).
# % macro, name,         object and gui association name
# % gui, $(name=), edm, pfeifferTC400_Monitoring.edl, P=$(P), R=$(R)
#
# This one is not currently required afterall.
# % macro, paramno_display, Optional.  Whether to display parameter nos on status and control screens. 0 or 1.   Defaults to zero.  Part of Expert Mode.
#
# *******************************************************
# START OF MODEL SET UP
#
# Record to allow template written for TC400 to be extended to
# support TC110, which lacks a few features compared to the TC400.
# This stops the processing of some records, which would otherwise
# lead to error replies from the TC110 via SDIS fields on the
# appropriate records.  So far, this is the configuration of the 3
# relays via the connector, (TC110 does not have relays) and one
# temperature record.
#
# This information is readback dynamically as a version info PV but it
# seems more robust and simpler to already know what model to expect at
# build time.
#
# If we need to handle more models in future, might need to split the
# template but this will do for now.
#
record(bo, "$(P)$(R):MODEL") {
  field(ZNAM, "TC400")
  field(ONAM, "TC110")
  field(VAL, "$(TC110=0)")
  field(PINI, "YES")
}

# END OF MODEL SET UP.
# *******************************************************
# START OF EXPERT
#
# Record to support Entering Expert mode and firing up Expert screen.
# Default to non-expert.
# 
record(bo, "$(P)$(R):EXPERT") {
  field(ZNAM, "Non-Expert")
  field(ONAM, "Expert")
  field(VAL, "0")
  field(PINI, "YES")
}

# END OF EXPERT.
# *******************************************************
# START OF READBACK OF CONTROL AND STATUS PARAMETERS REGARDING ACCESS.
#
# Readback which control interface has priority.
# Parameter 060 Datatype 7
#
record(mbbi, "$(P)$(R):RBV:CTL:INTSEL") {
  field(DESC, "Current control interface.")
  field(DTYP, "stream")
  field(SCAN, "Passive")
  field(INP, "@pfTC400.proto getControlViaInt($(unitaddr=001),$(P)$(R)) $(port)")
  field(ZRST, "Unknown")
  field(ZRVL, "0")
  field(ZRSV, "NO_ALARM")
  field(ONST, "Remote")
  field(ONVL, "1")
  field(ONSV, "NO_ALARM")
  field(TWST, "RS-485")
  field(TWVL, "2")
  field(TWSV, "NO_ALARM")
  field(THST, "PV.can")
  field(THVL, "4")
  field(THSV, "NO_ALARM")
  field(FRST, "Field Bus")
  field(FRVL, "8")
  field(FRSV, "NO_ALARM")
  field(FVST, "E74")
  field(FVVL, "16")
  field(FVSV, "NO_ALARM")
# This value is probably not meaningful as a readback, but the underlying parameter can also be written to.
  field(SXST, "Unlock Interface")
  field(SXVL, "255")
  field(SXSV, "NO_ALARM")
}

#
# Readback whether control interface selection is currently locked.
# This one effectively reports whether the PLC has priority over
# command functions via the hardware interface or EPICS serial has
# priority.  It is on the veto list because EPICS must not lock out
# the PLC.  Therefore DO NOT create a SET record for it.
# Parameter 061 Datatype 0
#
record(bi, "$(P)$(R):RBV:CTL:INTSELLCKD") {
  field(DESC, "Control interface selection locked?")
  field(DTYP, "stream")
  field(SCAN, "Passive")
  field(INP, "@pfTC400.proto getIntSelLckd($(unitaddr=001),$(P)$(R)) $(port)")
  field(ZNAM, "Unlocked")
  field(ONAM, "Locked")
}

#
# Readback of whether the remote interface has priority.
# Parameter 300  Datatype 0
#
record(bi, "$(P)$(R):RBV:STS:REMOTEPRIO") {
  field(DESC, "Interface Remote has priority?")
  field(DTYP, "stream")
  field(SCAN, "Passive")
  field(INP, "@pfTC400.proto getRemotePrio($(unitaddr=001),$(P)$(R)) $(port)")
  field(ZNAM, "No")
  field(ONAM, "Yes")
}

# Fans out the processing for all the control access records.
record(fanout, "$(P)$(R):FAN:RBV:CTL:ACCESSALL") {
  field(DESC, "Control access info fanout")
  field(SCAN, "Passive")
  field(LNK1, "$(P)$(R):RBV:CTL:INTSEL PP MS")
  field(LNK2, "$(P)$(R):RBV:CTL:INTSELLCKD PP MS")
  field(LNK3, "$(P)$(R):RBV:STS:REMOTEPRIO PP MS")
}
# END OF RECORDS FOR CONTROL AND STATUS PARAMETERS REGARDING ACCESS.
# *******************************************************

  field(CALC, "B=1?0:1")
  field(OOPT, "When Non-zero")
  field(OCAL, "C")
  field(DOPT, "Use OCAL")
  field(INPA, "$(P)$(R):QRY:PARAM:PARAMNO PP")
  field(INPB, "$(P)$(R):STS:ACS:VETOED" )
  field(INPC, "$(P)$(R):DMD:PARAM:DATATYPE7.RVAL PP")
  field(OUT, "@pfTC400.proto setParamDatatype7($(unitaddr=001),$(P)$(R)) $(port)")
}


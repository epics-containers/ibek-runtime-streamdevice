# END OF RECORDS FOR GENERIC PARAMETER DATATYPES.
# *******************************************************
# START OF PARAMETER ACCESS CHECKING
#
# At present the only checking we do is based on the veto list.
# These are additional support for generic data type setting.
# There are some parameters we want to bar writing to from
# the IOC because they are in the dominion of the PLC.
#
# No checking is done based on what we think the write
# permission of the parameter on the pfeiffer might be.
# Neither do we check the PLC has ceded remote control
# and allowed RS-485 control.
# Also we cannot apply DRVH and DRVL to realistic values
# or anything like that.
#
# The veto library routine has the table of vetoed parameter
# numbers hardcoded.
#
record(aSub, "$(P)$(R):CLC:ACS:VETOLISTCHK") {
  field(DESC, "Check param not on write vetolist")
  field(SNAM, "pfeifferParamSetVetolistCheck")
  field(FTA, "SHORT")
  field(INPA, "$(P)$(R):QRY:PARAM:PARAMNO")
  field(FTVB, "SHORT")
  field(OUTB, "$(P)$(R):STS:ACS:VETOED PP")
  field(FTVC, "STRING")
  field(OUTC, "$(P)$(R):STS:ACS:EXPLANATION PP")
}

# The integer flag returned by the veto list check.
# Use this for visibility of demand value box.
#
record(bi, "$(P)$(R):STS:ACS:VETOED") {
  field(DESC, "Whether write is vetoed")
  field(ZNAM, "Allowed")
  field(ONAM, "Vetoed")
}

# The constructed explanation string returned by the veto list check.
record(stringin, "$(P)$(R):STS:ACS:EXPLANATION") {
  field(DESC, "Explanation of last vetolist check." )
}

# END OF PARAMETER ACCESS CHECKING
# *******************************************************
# START OF ERROR CODE HANDLING
#
# NOTE: "Error code" refers to a value held in the Pfeiffer ErrorCode
# Parameter.  They are NOT the errors returned in error message
# telegrams, which are different in format and interpretation and
# attempted to be handled below.  Error codes can be queried and the
# reply received successfully without an error telegram being
# involved.
#
# NOTE: A History of upto 10 previous error code parameters is
# available but not requested as a requirement.
#
# Readback of current error code.
# Parameter 303
#
record(stringin, "$(P)$(R):RBV:ERR:ERRCODE") {
  field(DESC, "Readback current error code")
  field(DTYP, "stream")
  field(SCAN, "Passive")
  field(INP,  "@pfTC400.proto getErrorCode($(unitaddr=001),$(P)$(R)) $(port)")
  field(FLNK, "$(P)$(R):CLC:ERR:ERRCODEPARSE")
}

# The parser routine has tables of error and warning codes.
record(aSub, "$(P)$(R):CLC:ERR:ERRCODEPARSE") {
  field(DESC, "Interpret current error code")
  field(SNAM, "pfeifferErrorCodeParse")
  field(FTA, "STRING")
  field(INPA, "$(P)$(R):RBV:ERR:ERRCODE")
  field(FTVB, "STRING")
  field(OUTB, "$(P)$(R):STS:ERR:CODEEXPLANATION PP")
  field(FTVC, "SHORT")
  field(OUTC, "$(P)$(R):STS:ERR:CODENUM PP")
  field(FTVD, "SHORT")
  field(OUTD, "$(P)$(R):STS:ERR:CODETYPE PP")
}

# The Explanation returned by the parser.
record(stringin, "$(P)$(R):STS:ERR:CODEEXPLANATION") {
  field(DESC, "Meaning of current error/warning code." )
}

# The integer number returned by the parser.
record(ai, "$(P)$(R):STS:ERR:CODENUM") {
  field(DESC, "Error code number.")
}

# The code type returned by the parser.
record(mbbi, "$(P)$(R):STS:ERR:CODETYPE") {
  field(DESC, "Error code type.")
  field(ZRVL, "0")
  field(ZRST, "None")
  field(ONVL, "1")
  field(ONST, "Warning")
  field(TWVL, "2")
  field(TWST, "Error")
}

# END OF ERROR CODE HANDLING
# *******************************************************
# START OF ERROR RESPONSE HANDLING
#
# NOTE: "Error response" refers to the content of an error message
# telegram sent by the Pfeiffer instead of either the answer to a
# query message telegram of the acknowledgement of a command telegram.
# They are NOT the Pfeiffer error code parameters which are handled
# above and are not involved in error telegrams (unless there is an
# error trying to query one...)  They are caught by the mismatch
# handler(s), so these records are stream device ones, even though
# they make no call to the protocol.
#
# The parameter reported to be causing the error.  It is extracted by the
# stream device protocol and placed in this record.
record(ai, "$(P)$(R):RTN:ERR:ERRPARAMNO")
{
#  field(DTYP, "stream")
  field(DTYP, "Soft Channel")
  field(DESC, "Last err msg concerned this param no")
#  field(PINI, "YES" )
#  field(VAL, "0")
}

# The error message relating to the problem parameter.  It is extracted
# by the stream device protocol and placed in this record.
#
record(stringin, "$(P)$(R):RTN:ERR:ERRMESS")
{
#  field(DTYP, "stream")
  field(DTYP, "Soft Channel")
  field(DESC, "Last error message.")
}

# The parser routine has a table of known error messages.
# It takes the short message string and constructs a longer
# explanation, unfortunately restricted to 39 characters.
#
record(aSub, "$(P)$(R):CLC:ERR:ERRMESSPARSE") {
  field(DESC, "Interpret error message")
  field(SNAM, "pfeifferErrorMessageParse")
  field(FTA, "STRING")
  field(INPA, "$(P)$(R):RTN:ERR:ERRMESS CP")
  field(FTB, "SHORT")
  field(INPB, "$(P)$(R):RTN:ERR:ERRPARAMNO")
  field(FTVC, "STRING")
  field(OUTC, "$(P)$(R):RTN:ERR:MESSEXPLANATION PP")
}

# The constructed explanation string for the message returned by the parser.
record(stringin, "$(P)$(R):RTN:ERR:MESSEXPLANATION") {
  field(DESC, "Meaning of last error message." )
}

# Record to test error response handling - need a way to deliberately provoke
# an error message from the controller.  This parameter would appear to be
# non existent and that appears from the possible values of error listed in
# the manual to be a condition which will provoke an error response.
# This record is not scanned or displayed.
#
# Parameter 099
#
record(ai, "$(P)$(R):RBV:ERR:TESTERR") {
  field(DESC, "Provoke duff param error response.")
  field(DTYP, "stream")
  field(SCAN, "Passive")
  field(INP,  "@pfTC400.proto getTestError($(unitaddr=001),$(P)$(R)) $(port)")
}

# Need to clear the last error message, otherwise it hangs around
# indefinitely and makes it look like things failed which have
# actually succeeded, so provide some records to do this.
#
# Null error message.
#
record(stringout, "$(P)$(R):DFT:ERR:ERRMESS") {
  field(DESC, "Default error string at init/reset")
  field(OUT, "$(P)$(R):RTN:ERR:ERRMESS PP")
  field(VAL, "")
  field(PINI, "YES")
}

# Provide null error message parameter number and provoke
# processing of null error message.  The transform is a glorified
# fanout, but it gives control over the processing order,
# which is important, because want the message parser
# to automatically pick up that the reset has happened
# records have to be updated for the parser to parse
# successfully. Also allows use of fixed value of field INPA to
# save the need for a separate record to hold the null param
# number.
#
record(transform, "$(P)$(R):TFM:ERR:ERRMESSCLEAR") {
  field(DESC, "Clear last error message and paramno")
  field(INPA, "0")
  field(INPB, "1")
  field(OUTA, "$(P)$(R):RTN:ERR:ERRPARAMNO PP")
  field(OUTB, "$(P)$(R):DFT:ERR:ERRMESS.PROC PP")
}

# END OF ERROR RESPONSE HANDLING
# *******************************************************
# START OF RECORDS FOR SCANNING CONTROL
#
# Put these last for the sake of the pini fanout.
#
# % autosave 1 VAL
# This record needed to stop various records scanning and generating lots
# of error messages if the box is unplugged - this tends to be needed
# for end station IOCs.
#
record(bo, "$(P)$(R):DISABLE") {
  field(DESC, "Disable comms")
  field(PINI, "YES")
  field(VAL, "$(DISABLED=0)")
  field(OMSL, "supervisory")
  field(ZNAM, "Enabled")
  field(ONAM, "Disabled")
}

# To provide PINI control.  The info retrieved on initialisation - stuff that's useful
# to know, but should not change.  Might also used for some refresh buttons.
#
record(fanout, "$(P)$(R):FAN:PINI1") {
  field(DESC, "PINI processing fanout 1")
  field(SCAN, "Passive")
  field(PINI, "YES")
  field(LNK1, "$(P)$(R):FAN:RBV:VSN:ALL")
#  field(FLNK, "$(P)$(R):FAN:PINI2 PP")
}

# To provide control over the scanning rate of the "faster changing" stuff.
record(fanout, "$(P)$(R):FAN:SCANFAST1") {
  field(DESC, "Fast scan processing fanout 1")
  field(SCAN, "1 second")
#  field(SCAN, "Passive")
  field(SDIS, "$(P)$(R):DISABLE")
  field(LNK1, "$(P)$(R):FAN:RBV:CTL:ALL")
  field(LNK2, "$(P)$(R):FAN:RBV:STS:SPDALL")
#  field(FLNK, "$(P)$(R):FAN:SCANFAST2 PP")
}

# To provide control over the scanning rate of the "slowly changing" stuff.
record(fanout, "$(P)$(R):FAN:SCANSLOW1") {
  field(DESC, "Slow scan processing fanout 1")
  field(SCAN, "10 second")
#  field(SCAN, "Passive")
  field(SDIS, "$(P)$(R):DISABLE")
  field(LNK1, "$(P)$(R):RBV:ERR:ERRCODE")
  field(LNK2, "$(P)$(R):FAN:RBV:CTL:ACCESSALL")
  field(LNK3, "$(P)$(R):FAN:RBV:STS:TIVLALL")
  field(LNK4, "$(P)$(R):FAN:RBV:SVS:ALL")
#  field(FLNK, "$(P)$(R):FAN:SCANSLOW2 PP")
}


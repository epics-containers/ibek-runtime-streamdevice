#
record(ai, "$(P)$(R):RBV:STS:NOMSPDHZ") {
  field(DESC, "The nominal rot speed (Hz)")
  field(DTYP, "stream")
  field(SCAN, "Passive")
  field(INP, "@pfTC400.proto getNominalSpdHz($(unitaddr=001),$(P)$(R)) $(port)")
  field(EGU, "Hz")
}

# Calculate the current actual percentage speed from the current
# actual speed over the nominal speed in the same speed units.  Have
# the choice of whether to use Hz or RPM PVs as the input to the
# calculation and have plumped for Hz.
#
record(calcout, "$(P)$(R):CLC:STS:SPEEDPERCENT") {
  field(DESC, "Calculate %age speed")
  field(INPA, "$(P)$(R):RBV:STS:SPEEDHZ")
  field(INPB, "$(P)$(R):RBV:STS:NOMSPDHZ")
  field(CALC, "100*A/B")
  field(OUT, "$(P)$(R):RBV:STS:SPEEDPERCENT PP MS")
}

# Calculated current actual percentage speed.
#
# % archiver 10 monitor
#
record(ai, "$(P)$(R):RBV:STS:SPEEDPERCENT") {
  field(DESC, "Current %age speed")
  field(EGU, "%")
  field(PREC, "0")
}


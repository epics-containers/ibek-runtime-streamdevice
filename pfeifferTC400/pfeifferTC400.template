# Parameter 309 Datatype 1
# Forward link to update the percentage speed calculation when this updates.
#
# % archiver 10 monitor
#
record(ai, "$(P)$(R):RBV:STS:SPEEDHZ") {
  field(DESC, "Current rotational speed (Hz).")
  field(DTYP, "stream")
  field(SCAN, "Passive")
  field(INP, "@pfTC400.proto getActualSpdHz($(unitaddr=001),$(P)$(R)) $(port)")
  field(EGU, "Hz")

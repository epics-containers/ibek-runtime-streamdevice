# START OF RECORDS FOR GENERIC HANDLING OF PARAMETER DATATYPES.
# 
# Not all the parameters have implemented protocols.
# Vacuum group want to be able to do occasional things.
#
# These records support direct interaction with a parameter
# provided type and number of the parameter are known.
#
# They are not scanned by default, their scanning is controlled
# from a GUI or with a caput and they are processed on demand only.
#
#  0       06           False /true                 000000 or 111111
#  1       06           Positive integer number     000000 to 999999
#  2       06           Positive fixed comma number 001571 equal to 15.71
#  4       06           Symbol chain                TC_400
#  7       03           Positive integer number     000 to 999
# 10       06           Exponential value           100023 equal to 1.0 times ten to the power of three. 
#                                                   ???Really??? Fortunately we seem to have none.
# 11       16           Symbol chain                BrezelBier&Wurst
#
# Have not implemented datatype 10 - see protocol file for comment on why not.
#

# Parameter number to scan or set.  This is shared amongst all the data types.
record(ai, "$(P)$(R):QRY:PARAM:PARAMNO") {
  field(DESC, "Desired parameter number.")
  field(PINI, "YES")
# NOTE: The parameter number will be padded with zeros to 3 digits, but we do not want EPICS to think we mean Octal.
# Parameter 023 is called MotorPump 1 for on, 0 for off.
  field(VAL, "23")
  field(FLNK, "$(P)$(R):CLC:ACS:VETOLISTCHK PP")
}

# Parameter type of parameter to scan or set.  This is mostly to help
# the GUI, but shall also need it to stop the parameter being scanned
# as multiple datatypes at the same time, a recipe for error messages
# and confusion.
#
record(mbbi, "$(P)$(R):QRY:PARAM:DATATYPE") {
  field(DESC, "Datatype of desired parameter.")
  field(PINI, "YES")
  field(VAL, "0")
  field(ZRST, "Datatype0")
  field(ZRVL, "0")
  field(ONST, "Datatype1")
  field(ONVL, "1")
  field(TWST, "Datatype2")
  field(TWVL, "2")
  field(THST, "Datatype4")
  field(THVL, "4")
  field(FRST, "Datatype7")
  field(FRVL, "7")
  field(FVST, "Datatype11")
  field(FVVL, "11")
  field(FLNK, "$(P)$(R):TFM:PARAM:SCANRATE PP")
}

# Turn on the scanning for the getter record for the selected datatype
# and and turn off the scanning on the getter records for all the
# other datatypes.  Had to comment out the links for string datatypes 4
# and 11 because are not currently able to build the support for them.
#
# This is required because life gets very confusing
# if multiple datatype getters are scanning at the same time because
# they share the query parameter number.  At least one of the getters
# is likely to result in regular errors, even if one of the others is
# successful.  If more than one succeeds, the values can be
# inconsistent, since they are not synchronous.
#
# 0 is scan Passive
# 6 is scan 1 second - set in field B
#
# The values field A is tested against are the possible numeric values
# of the datatype record above, they are not the datatype number.
#
record(transform, "$(P)$(R):TFM:PARAM:SCANRATE") {
  field(DESC, "Datatype record scanning control")
  field(INPA, "$(P)$(R):QRY:PARAM:DATATYPE")
  field(INPB, "6")
  field(CLCC, "A=0?B:0")
  field(OUTC, "TS-VA-TURBO-03:GET:PARAM:DATATYPE0.SCAN")
  field(CLCD, "A=1?B:0")
  field(OUTD, "TS-VA-TURBO-03:GET:PARAM:DATATYPE1.SCAN")
  field(CLCE, "A=2?B:0")
  field(OUTE, "TS-VA-TURBO-03:GET:PARAM:DATATYPE2.SCAN")
  field(CLCF, "A=3?B:0")
#  field(OUTF, "TS-VA-TURBO-03:GET:PARAM:DATATYPE4.SCAN")
  field(CLCG, "A=4?B:0")
  field(OUTG, "TS-VA-TURBO-03:GET:PARAM:DATATYPE7.SCAN")
  field(CLCH, "A=5?B:0")
#  field(OUTH, "TS-VA-TURBO-03:GET:PARAM:DATATYPE11.SCAN")
}

# Need a transform record here to make sure only 1 datatype record scans based on the DATATYPE record.

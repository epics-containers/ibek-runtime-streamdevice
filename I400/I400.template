record(transform, "$(P):SETMAX") {
  field(DESC, "Set limits on max hv")
  field(A, "$(MAXSIG)")
  field(CLCB, "A>0?A:0")
  field(OUTB, "$(P):SETSMH.DRVH")
  field(CLCC, "A<0?A:0")
  field(OUTC, "$(P):SETSMH.DRVL")
  field(D, "$(MAXEXT)")
  field(CLCE, "D>0?D:0")
  field(OUTE, "$(P):SETEMH.DRVH")
  field(CLCF, "D<0?D:0")
  field(OUTF, "$(P):SETEMH.DRVL")
  field(PINI, "YES")
}


  field(INPB, "$(P):CURR2.VAL MS")
  field(CMTC, "Quad Y-")
  field(INPC, "$(P):CURR3.VAL MS")
  field(CMTD, "Quad X+")
  field(INPD, "$(P):CURR4.VAL MS")
  field(CMTE, "Y gain")
  field(INPE, "$(P):YGAIN")
  field(CMTF, "X gain")
  field(INPF, "$(P):XGAIN")
  field(CMTG, "Total Intensity")
  field(CLCG, "A+B+C+D")
  field(OUTG, "$(P):INTEN PP")

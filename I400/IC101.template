  field(EGU,  "V")
}

record(longin, "$(P):HV:MAX_RBV") {
  field(DESC, "Max external HV")
  field(DTYP, "stream")
  field(INP,  "@IC101.proto getMaxExtHV() $(port) 0")
  field(SCAN, "1 second")
  field(EGU,  "V")
  field(SDIS, "$(P):RUNNING")
}

record(longout, "$(P):HV") {
  field(DESC, "Set external HV")
  field(DTYP, "stream")
  field(OUT,  "@IC101.proto setExtHV() $(port) 0")
  field(EGU,  "V")
}

record(longin, "$(P):HV_RBV") {
  field(DESC, "External HV")
  field(DTYP, "stream")
  field(INP,  "@IC101.proto getExtHV() $(port) 0")
  field(SCAN, "1 second")
  field(EGU,  "V")
  field(SDIS, "$(P):RUNNING")

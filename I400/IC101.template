# Integration period

# % autosave 2 VAL
record(ao, "$(P):PERIOD") {
  field(DESC, "Set integration period")
  field(DTYP, "stream")
  field(OUT,  "@IC101.proto setIntPeriod() $(port) 0")
  field(PREC, "4")
  field(EGU,  "s")
  field(DRVH, "65")
  field(DRVL, "5e-6")
}

record(ai, "$(P):PERIOD_RBV") {
  field(DESC, "Integration period")
  field(DTYP, "stream")
  field(INP,  "@IC101.proto getIntPeriod() $(port) 0")
  field(SCAN, "1 second")
  field(PREC, "4")
  field(EGU,  "s")
  field(SDIS, "$(P):RUNNING")
}

# Current range

record(ao, "$(P):RANGE") {
  field(DESC, "Set current range")
  field(DTYP, "stream")
  field(OUT,  "@IC101.proto setCurrRange() $(port) 0")
  field(PREC, "5")
  field(EGU,  "s")
}

record(ai, "$(P):RANGE_RBV") {
  field(DESC, "Current range")
  field(DTYP, "stream")
  field(INP,  "@IC101.proto getCurrRange() $(port) 0")

# MISCELLANEOUS

# Manual messaging

record(stringout, "$(P):MESSAGE") {
  field(DESC, "Send message")
  field(DTYP, "stream")
  field(OUT,  "@IC101.proto sendMessage() $(port) 0")
}

record(stringin, "$(P):MESSAGE_RBV") {
  field(DESC, "Read message reply")
  field(DTYP, "stream")
  field(INP,  "@IC101.proto readMessage() $(port) 0")
  field(SCAN, "I/O Intr")
}

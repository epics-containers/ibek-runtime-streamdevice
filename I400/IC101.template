#==============================================================================
# IC101 Template
#
# Ben Bradnick, Diamond Light Source
#
#
# MACROS
# % macro, name,   GUI object name
# % macro, P,      Device prefix
# % macro, port,   Asyn port
# % macro, MAXEXT, Limit maximum external voltage
# % macro, CAP0,   Capacitor 0 string
# % macro, CAP1,   Capacitor 1 string
#
#
# GUI
# % gui, $(name), edm, IC101-top.edl, P=$(P)
include "IC101_detail.template"
#
#==============================================================================

# IDENTITY

record(stringin, "$(P):MANUFACTURER") {
  field(DESC, "Manufacturer")
  field(DTYP, "stream")
  field(INP,  "@IC101.proto manufacturer() $(port) 0")
  field(PINI, "YES")
}

record(stringin, "$(P):MODEL") {
  field(DESC, "Model")
  field(DTYP, "stream")
  field(INP,  "@IC101.proto model() $(port) 0")
  field(SCAN, "I/O Intr")
}

record(stringin, "$(P):SERIAL") {
  field(DESC, "Serial number")
  field(DTYP, "stream")
  field(INP,  "@IC101.proto serial() $(port) 0")
  field(SCAN, "I/O Intr")
}

record(stringin, "$(P):FIRMWARE") {
  field(DESC, "Firmware version")
  field(DTYP, "stream")
  field(INP,  "@IC101.proto firmware() $(port) 0")
  field(SCAN, "I/O Intr")
}


# SYSTEM

# Admin

record(longout, "$(P):ADMIN") {
  field(DESC, "Admin password")
  field(DTYP, "stream")
  field(OUT,  "@IC101.proto admin($(P):ADMIN_RBV) $(port) 0")
}

record(longin, "$(P):ADMIN_RBV") {
  field(DESC, "Admin reply status")
  field(DTYP, "Soft Channel")
}

record(calcout, "$(P):ADMIN_CALC") {
  field(DESC, "Check if admin pass was correct")
  field(INPA, "$(P):ADMIN_RBV CP")
  field(CALC, "A=6?1:0")
  field(OUT,  "$(P):ADMIN_STATUS PP")
  field(OOPT, "Every Time")
}

record(bi, "$(P):ADMIN_STATUS") {
  field(DESC, "Admin status")
  field(ZNAM, "Disabled")
  field(ONAM, "Enabled")
}

record(seq, "$(P):SEQPASS_RESET") {
  field(DESC, "Reset password")
  field(DOL1, "0")
  field(LNK1, "$(P):ADMIN PP")
}

# Settings

record(bo, "$(P):SAVE") {
  field(DESC, "Save settings")
  field(DTYP, "stream")
  field(OUT, "@IC101.proto save() $(port) 0")
  field(VAL, "1")
}

record(bo, "$(P):RECALL") {
  field(DESC, "Recall settings")
  field(DTYP, "stream")
  field(OUT, "@IC101.proto recall() $(port) 0")
  field(VAL, "1")
}

record(seq, "$(P):SEQRESET") {
  field(DESC, "Reset amplifier")
  field(DOL1, "1")
  field(LNK1, "$(P):RUNNING PP")
  field(DLY2, "0.1")
  field(LNK2, "$(P):RESET.PROC PP")
  field(DLY3, "5.0")
  field(LNK3, "$(P):SEQINIT.PROC PP")
}

# Reset

record(bo, "$(P):RESET") {
  field(DESC, "Reset device")
  field(DTYP, "stream")
  field(OUT, "@IC101.proto reset() $(port) 0")
  field(VAL, "1")
}

# Communication settings

record(seq, "$(P):COMMS") {
  field(DESC, "Initialise comm settings")
  field(DLY1, "0.1")
  field(DOL1, "12345")
  field(LNK1, "$(P):ADMIN PP")
  field(DLY2, "0.1")
  field(LNK2, "$(P):TIMEOUT.PROC PP")
  field(DLY3, "0.1")
  field(LNK3, "$(P):CHECKSUM.PROC PP")
}

record(longout, "$(P):CHECKSUM") {
  field(DESC, "Disable checksums")
  field(DTYP, "stream")
  field(OUT, "@IC101.proto check() $(port) 0")
}

record(longout, "$(P):TIMEOUT") {
  field(DESC, "Disable timeout")
  field(DTYP, "stream")
  field(OUT, "@IC101.proto timeout() $(port) 0")
}


# INITIALISATION

record(bo, "$(P):RUNNING") {
  field(DESC, "Gate for initialising")
  field(DTYP, "Soft Channel")
  field(ZNAM, "Running")
  field(ONAM, "Disabled")
  field(VAL,  "1")
}

record(seq, "$(P):SEQINIT") {
  field(DESC, "Initialise amplifier")
  field(PINI, "YES")
  field(DOL1, "1")
  field(LNK1, "$(P):RUNNING PP")
  field(DLY2, "0.5")
  field(LNK2, "$(P):COMMS.PROC PP")
  field(DLY3, "0.5")
  field(LNK3, "$(P):RECALL.PROC PP")
  field(DLY4, "0.5")
  field(LNK4, "$(P):RECALLCALIB.PROC PP")
  field(DLY5, "0.5")
  field(LNK5, "$(P):INIT.PROC PP")
  field(DLY6, "1.0")
  field(DOL6, "0")
  field(LNK6, "$(P):RUNNING PP")
  field(FLNK, "$(P):SEQPASS_RESET PP")
}

record(bo, "$(P):INIT") {
  field(DESC, "Initialise device")
  field(DTYP, "stream")
  field(OUT,  "@IC101.proto init() $(port) 0")
  field(VAL,  "1")
}

record(bo, "$(P):ABORT") {
  field(DESC, "Abort measurement")
  field(DTYP, "stream")
  field(OUT,  "@IC101.proto abort() $(port) 0")
  field(VAL,  "1")
}

# CALIBRATION

record(bo, "$(P):CALIB") {
  field(DESC, "Calibrate device")
  field(DTYP, "stream")
  field(OUT,  "@IC101.proto doCalib() $(port) 0")
  field(VAL,  "1")
}

record(bo, "$(P):SAVECALIB") {
  field(DESC, "Save calibration settings")
  field(DTYP, "stream")
  field(OUT,  "@IC101.proto saveCalib() $(port) 0")
  field(VAL,  "1")
}

record(bo, "$(P):RECALLCALIB") {
  field(DESC, "Recall calibration settings")
  field(DTYP, "stream")
  field(OUT,  "@IC101.proto recallCalib() $(port) 0")
  field(VAL,  "1")
}

# Internal source

record(bo, "$(P):SOURCE") {
  field(DESC, "Set calibration source")
  field(DTYP, "stream")
  field(OUT,  "@IC101.proto setSource() $(port) 0")
  field(ZNAM, "Off")
  field(ONAM, "On")
}

record(bi, "$(P):SOURCE_RBV") {
  field(DESC, "Calibration source")
  field(DTYP, "stream")
  field(INP,  "@IC101.proto getSource() $(port) 0")
  field(SCAN, "1 second")
  field(ZNAM, "Off")
  field(ONAM, "On")
  field(SDIS, "$(P):RUNNING")
}

# Gain values

record(ai, "$(P):GAIN1") {
  field(DESC, "Gain for first channel")
  field(DTYP, "stream")
  field(INP,  "@IC101.proto getFirstGain() $(port) 0")
  field(SCAN, "1 second")
  field(PREC, "4")
  field(SDIS, "$(P):RUNNING")
}

record(ai, "$(P):GAIN2") {
  field(DESC, "Gain for second channel")
  field(DTYP, "stream")
  field(INP,  "@IC101.proto getSecondGain() $(port) 0")
  field(SCAN, "I/O Intr")
  field(PREC, "4")
  field(SDIS, "$(P):RUNNING")
}

# CONFIGURATION

# Capacitors

# % autosave 2 VAL
record(bo, "$(P):CAP") {
  field(DESC, "Set capacitor")
  field(DTYP, "stream")
  field(OUT,  "@IC101.proto setCap() $(port) 0")
  field(ZNAM, "$(CAP0)")
  field(ONAM, "$(CAP1)")
}

record(bi, "$(P):CAP_RBV") {
  field(DESC, "Capacitor")
  field(DTYP, "stream")
  field(INP,  "@IC101.proto getCap() $(port) 0")
  field(SCAN, "1 second")
  field(ZNAM, "$(CAP0)")
  field(ONAM, "$(CAP1)")
  field(SDIS, "$(P):RUNNING")
}

record(ai, "$(P):CAP:VALUE") {
  field(DESC, "Capacitance value")
  field(DTYP, "stream")
  field(INP,  "@IC101.proto getCapValue() $(port) 0")
  field(SCAN, "I/O Intr")
  field(PREC, "2")
  field(EGU,  "F")
  field(SDIS, "$(P):RUNNING")
}

# External voltages

# % autosave 2 VAL
record(longout, "$(P):HV:MAX") {
  field(DESC, "Set max external HV")
  field(DTYP, "stream")
  field(OUT,  "@IC101.proto setMaxExtHV() $(port) 0")
